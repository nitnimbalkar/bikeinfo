```html
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BikeInfo</title>

<link rel="stylesheet" href="style.css">
</head>

<body>

<!-- NAVBAR -->
<div class="navbar">
    <div class="logo">BikeInfo</div>

    <label class="switch">
        <input type="checkbox" id="darkToggle">
        <span class="slider"></span>
    </label>
</div>

<!-- PROFILE -->
<div class="profile">

    <div class="profile-left">

        <div class="profile-image">
            <img
                id="profileImg"
                src="https://i.pravatar.cc/300?img=12"
                alt="Profile">
        </div>

        <div>
            <h2 id="fullName">Rahul Sharma</h2>
            <p id="username">@riderx</p>

            <button
                class="edit-btn"
                onclick="openProfileModal()">
                Edit Profile
            </button>
        </div>

    </div>

    <div class="profile-extra">

        <div id="age">
            🎂 Age: 24
        </div>

        <div id="city">
            📍 City: Pune
        </div>

        <div id="email">
            📧 Email: rahul@gmail.com
        </div>

    </div>

</div>

<!-- GARAGE -->
<div class="section">

    <div class="section-header">

        <h2>🏍 My Garage</h2>

        <button
            class="add-btn"
            onclick="openBikeModal()">
            + Add Bike
        </button>

    </div>

    <div
        class="bike-grid"
        id="bikeGrid">
    </div>

</div>

<!-- POSTS -->
<div class="section">

    <div class="section-header">

        <h2>📝 My Posts</h2>

        <button
            class="add-btn"
            onclick="openPostModal()">
            + Add Post
        </button>

    </div>

    <div id="postContainer"></div>

</div>

<!-- REVIEWS -->
<div class="section">

    <div class="section-header">

        <h2>⭐ My Reviews</h2>

        <button
            class="add-btn"
            onclick="openReviewModal()">
            + Add Review
        </button>

    </div>

    <div id="reviewContainer"></div>

</div>

<!-- PROFILE MODAL -->
<div class="modal" id="profileModal">

    <div class="modal-box">

        <h3>Edit Profile</h3>

        <input
            id="firstName"
            placeholder="First Name">

        <input
            id="lastName"
            placeholder="Last Name">

        <input
            id="userNameInput"
            placeholder="Username">

        <input
            id="emailInput"
            placeholder="Email">

        <input
            id="ageInput"
            placeholder="Age">

        <input
            id="cityInput"
            placeholder="City">

        <input
            type="file"
            id="profileUpload"
            accept="image/*">

        <button onclick="saveProfile()">
            Save Profile
        </button>

    </div>

</div>

<!-- BIKE MODAL -->
<div class="modal" id="bikeModal">

    <div class="modal-box">

        <h3>Add Bike</h3>

        <input
            id="bikeName"
            placeholder="Bike Name">

        <input
            id="bikeType"
            placeholder="Bike Type">

        <input
            id="bikeImage"
            placeholder="Bike Image URL">

        <button onclick="saveBike()">
            Save Bike
        </button>

    </div>

</div>

<!-- POST MODAL -->
<div class="modal" id="postModal">

    <div class="modal-box">

        <h3>Add Post</h3>

        <textarea
            id="postText"
            rows="5"
            placeholder="Write your post"></textarea>

        <button onclick="savePost()">
            Save Post
        </button>

    </div>

</div>

<!-- REVIEW MODAL -->
<div class="modal" id="reviewModal">

    <div class="modal-box">

        <h3>Add Review</h3>

        <input
            id="reviewBike"
            placeholder="Bike Name">

        <input
            id="reviewRating"
            type="number"
            min="1"
            max="5"
            placeholder="Rating (1-5)">

        <textarea
            id="reviewText"
            rows="5"
            placeholder="Write review"></textarea>

        <button onclick="saveReview()">
            Save Review
        </button>

    </div>

</div>

<script src="script.js"></script>

</body>
</html>
```
