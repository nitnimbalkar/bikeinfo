<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>Steam Bike Garage - Fully Working</title>

<style>

:root{
  --bg:#f5f6f8;
  --card:#ffffff;
  --text:#111;
  --sub:#666;
  --border:#d9dbe1;
  --accent:#4c8bf5;
}

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  background:var(--bg);
  font-family:Arial;
  color:var(--text);
}

/* PROFILE */

.container{
  max-width:1200px;
  margin:auto;
  padding:40px 20px;
}

.profile-top{
  display:flex;
  gap:50px;
  align-items:center;
  border-bottom:1px solid var(--border);
  padding-bottom:25px;
}

.profile-image{
  width:130px;
  height:130px;
  border-radius:50%;
  overflow:hidden;
  border:3px solid var(--border);
}

.profile-image img{
  width:100%;
  height:100%;
  object-fit:cover;
}

.username{
  font-size:28px;
  font-weight:700;
}

.meta{
  color:var(--sub);
  font-size:14px;
}

/* GARAGE */

.showcase{
  margin-top:40px;
}

.garage-title{
  font-size:22px;
  font-weight:700;
  margin-bottom:15px;
}

/* GRID */

.bike-grid{
  display:flex;
  gap:15px;
  overflow-x:auto;
  padding-bottom:10px;
  align-items:stretch;
}

/* CARD */

.bike-card{
  width:220px;
  height:300px;
  flex-shrink:0;

  background:#fff;
  border:1px solid var(--border);
  border-radius:14px;
  overflow:hidden;

  cursor:pointer;

  display:flex;
  flex-direction:column;

  transition:.2s;
}

.bike-card:hover{
  transform:translateY(-6px);
}

.bike-card img{
  width:100%;
  height:170px;
  object-fit:cover;
}

.bike-info{
  padding:10px;
  flex:1;
  display:flex;
  flex-direction:column;
  justify-content:space-between;
}

.bike-name{
  font-weight:700;
  font-size:14px;
}

.bike-desc{
  font-size:12px;
  color:var(--sub);
  margin-top:6px;
}

/* ADD TILE */

.add-tile{
  width:220px;
  height:300px;
  flex-shrink:0;

  border:2px dashed #bbb;
  border-radius:14px;

  display:flex;
  align-items:center;
  justify-content:center;

  cursor:pointer;
  background:#fafafa;

  transition:.2s;
}

.add-tile:hover{
  border-color:var(--accent);
  background:#eef5ff;
}

.add-plus{
  font-size:40px;
  color:#888;
}

/* MODALS */

.modal{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.6);
  display:none;
  justify-content:center;
  align-items:center;
  z-index:999;
}

.modal-box{
  width:350px;
  background:#fff;
  padding:20px;
  border-radius:12px;
}

.modal-box input,
.modal-box textarea{
  width:100%;
  margin-bottom:10px;
  padding:10px;
  border:1px solid #ddd;
  border-radius:8px;
}

.save{
  background:var(--accent);
  color:#fff;
  border:none;
  padding:10px;
  border-radius:8px;
  width:100%;
  cursor:pointer;
}

/* INSPECT MODAL */

.inspect{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.7);
  display:none;
  justify-content:center;
  align-items:center;
  z-index:1000;
}

.inspect-box{
  width:420px;
  background:#fff;
  border-radius:14px;
  overflow:hidden;
}

.inspect-box img{
  width:100%;
  height:220px;
  object-fit:cover;
}

.inspect-content{
  padding:15px;
}

.inspect-title{
  font-size:18px;
  font-weight:700;
}

.inspect-desc{
  font-size:13px;
  color:var(--sub);
  margin-top:8px;
}

.actions{
  display:flex;
  justify-content:space-between;
  margin-top:12px;
}

.btn{
  padding:6px 10px;
  border:none;
  border-radius:6px;
  cursor:pointer;
}

.del{background:#ef4444;color:#fff;}
.edit{background:#e5e7eb;}

</style>
</head>

<body>

<div class="container">

  <div class="profile-top">

    <div class="profile-image">
      <img src="https://i.pravatar.cc/400?img=12">
    </div>

    <div>
      <div class="username">Rider_X</div>
      <div class="meta">Mumbai • Steam Garage System</div>
    </div>

  </div>

  <div class="showcase">
    <div class="garage-title">Bike Garage</div>
    <div class="bike-grid" id="grid"></div>
  </div>

</div>

<!-- ADD / EDIT MODAL -->

<div class="modal" id="modal">

  <div class="modal-box">

    <input id="name" placeholder="Bike Name">
    <input id="img" placeholder="Image URL">
    <textarea id="desc" placeholder="Description"></textarea>

    <button class="save" onclick="saveBike()">SAVE</button>

  </div>

</div>

<!-- INSPECT MODAL -->

<div class="inspect" id="inspect" onclick="closeInspect(event)">

  <div class="inspect-box">

    <img id="iimg">

    <div class="inspect-content">

      <div class="inspect-title" id="ititle"></div>
      <div class="inspect-desc" id="idesc"></div>

      <div class="actions">

        <button class="btn edit" onclick="editBike()">Edit</button>
        <button class="btn del" onclick="deleteBike()">Delete</button>

      </div>

    </div>

  </div>

</div>

<script>

let bikes = JSON.parse(localStorage.getItem("bikes")) || [
  {name:"KTM Duke 390",img:"https://images.unsplash.com/photo-1558981806-ec527fa84c39",desc:"Street performance beast"},
  {name:"BMW G 310 GS",img:"https://images.unsplash.com/photo-1609630875171-b1321377ee65",desc:"Adventure touring machine"},
  {name:"Yamaha R15 V4",img:"https://images.unsplash.com/photo-1580310614729-ccd69652491d",desc:"Light supersport"},
  {name:"Ninja 400",img:"https://images.unsplash.com/photo-1625047509168-a7026f36de04",desc:"Balanced sport bike"},
  {name:"GT 650",img:"https://images.unsplash.com/photo-1606220838315-056192d5e927",desc:"Classic cruiser"}
];

let currentIndex = null;

function saveStorage(){
  localStorage.setItem("bikes", JSON.stringify(bikes));
}

/* RENDER */

function render(){

  const grid=document.getElementById("grid");
  grid.innerHTML="";

  bikes.forEach((b,i)=>{

    const card=document.createElement("div");
    card.className="bike-card";

    card.onclick=()=>openInspect(i);

    card.innerHTML=`
      <img src="${b.img}">
      <div class="bike-info">
        <div class="bike-name">${b.name}</div>
        <div class="bike-desc">${b.desc}</div>
      </div>
    `;

    grid.appendChild(card);

  });

  // ADD TILE LAST
  const add=document.createElement("div");
  add.className="add-tile";
  add.innerHTML=`<div class="add-plus">+</div>`;
  add.onclick=openModal;

  grid.appendChild(add);
}

/* MODAL */

function openModal(){
  modal.style.display="flex";
}

function saveBike(){

  if(currentIndex!==null){
    bikes[currentIndex]={
      name:name.value,
      img:img.value,
      desc:desc.value
    };
    currentIndex=null;
  }else{
    bikes.push({
      name:name.value,
      img:img.value,
      desc:desc.value
    });
  }

  saveStorage();
  render();
  modal.style.display="none";
}

/* INSPECT */

function openInspect(i){

  currentIndex=i;

  let b=bikes[i];

  ititle.innerText=b.name;
  idesc.innerText=b.desc;
  iimg.src=b.img;

  inspect.style.display="flex";
}

function closeInspect(e){
  if(e.target.id==="inspect"){
    inspect.style.display="none";
  }
}

function deleteBike(){

  bikes.splice(currentIndex,1);
  saveStorage();
  render();
  inspect.style.display="none";
}

function editBike(){

  let b=bikes[currentIndex];

  name.value=b.name;
  img.value=b.img;
  desc.value=b.desc;

  inspect.style.display="none";
  modal.style.display="flex";
}

render();

</script>

</body>
</html>