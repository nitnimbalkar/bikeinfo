        <div class="card-content">
          <div class="card-tag">News</div>
          <div class="card-title">Product Launch This Week</div>
          <div class="card-desc">Latest announcements and updates.</div>
        </div>

      </div>

      <div
        class="card"
        tabindex="0"
        data-type="modal"
        data-title="Global Rollout Begins"
        data-image="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?q=80&w=600&auto=format&fit=crop"
        data-text="Early rollout has started globally with performance improvements and UI redesign being tested."
      >

        <img
          class="card-image"
          loading="lazy"
          alt="Global Rollout"
          src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?q=80&w=600&auto=format&fit=crop">

        <div class="card-content">
          <div class="card-tag">News</div>
          <div class="card-title">Global Rollout Begins</div>
          <div class="card-desc">Users testing new improvements.</div>
        </div>

      </div>

      <div
        class="card"
        tabindex="0"
        data-type="modal"
        data-title="Community Reactions"
        data-image="https://images.unsplash.com/photo-1520607162513-77705c0f0d4a?q=80&w=600&auto=format&fit=crop"
        data-text="Community engagement is rapidly increasing with discussions and feedback across platforms."
      >

        <img
          class="card-image"
          loading="lazy"
          alt="Community Reactions"
          src="https://images.unsplash.com/photo-1520607162513-77705c0f0d4a?q=80&w=600&auto=format&fit=crop">

        <div class="card-content">
          <div class="card-tag">News</div>
          <div class="card-title">Community Reactions</div>
          <div class="card-desc">User feedback growing rapidly.</div>
        </div>

      </div>

    </div>

  </div>

  <!-- REVIEWS -->
  <div class="tab-content" id="reviews">

    <div class="cards">

      <div
        class="card"
        tabindex="0"
        data-type="modal"
        data-title="Interface Design Review"
        data-image="https://images.unsplash.com/photo-1516321497487-e288fb19713f?q=80&w=600&auto=format&fit=crop"
        data-text="Experts highlight improved usability, clean UI and better accessibility across the platform."
      >

        <img
          class="card-image"
          loading="lazy"
          alt="Interface Design"
          src="https://images.unsplash.com/photo-1516321497487-e288fb19713f?q=80&w=600&auto=format&fit=crop">

        <div class="card-content">
          <div class="card-tag">Expert Reviews</div>
          <div class="card-title">Interface Design</div>
          <div class="card-desc">Clean UI improvements.</div>
        </div>

      </div>

      <div
        class="card"
        tabindex="0"
        data-type="modal"
        data-title="Performance Boost Review"
        data-image="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?q=80&w=600&auto=format&fit=crop"
        data-text="Performance upgrades result in faster loading, smoother navigation and improved stability."
      >

        <img
          class="card-image"
          loading="lazy"
          alt="Performance Boost"
          src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?q=80&w=600&auto=format&fit=crop">

        <div class="card-content">
          <div class="card-tag">Expert Reviews</div>
          <div class="card-title">Performance Boost</div>
          <div class="card-desc">Speed improvements tested.</div>
        </div>

      </div>

      <div
        class="card"
        tabindex="0"
        data-type="modal"
        data-title="Future Scope Review"
        data-image="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=600&auto=format&fit=crop"
        data-text="Experts discuss scalability, roadmap direction and long-term platform evolution."
      >

        <img
          class="card-image"
          loading="lazy"
          alt="Future Scope"
          src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=600&auto=format&fit=crop">

        <div class="card-content">
