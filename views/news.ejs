    </div>

  </div>

  <!-- VIDEOS -->

  <div class="tab-content" id="videos">

    <div class="cards">

      <div class="card">

        <img 
          class="card-image"
          src="https://images.unsplash.com/photo-1492619375914-88005aa9e8fb?q=80&w=1200&auto=format&fit=crop"
          alt="Video"
        >

        <div class="card-content">

          <div class="card-tag">Video</div>

          <div class="card-title">
            Full Feature Walkthrough Now Available
          </div>

          <div class="card-desc">
            Watch a complete guided overview showcasing all major updates and interface improvements.
          </div>

        </div>

      </div>

      <div class="card">

        <img 
          class="card-image"
          src="https://images.unsplash.com/photo-1516321165247-4aa89a48be28?q=80&w=1200&auto=format&fit=crop"
          alt="Video"
        >

        <div class="card-content">

          <div class="card-tag">Video</div>

          <div class="card-title">
            Behind the Scenes Development Insights
          </div>

          <div class="card-desc">
            The product team explains engineering challenges and future plans in detail.
          </div>

        </div>

      </div>

      <div class="card">

        <img 
          class="card-image"
          src="https://images.unsplash.com/photo-1521737604893-d14cc237f11d?q=80&w=1200&auto=format&fit=crop"
          alt="Video"
        >

        <div class="card-content">

          <div class="card-tag">Video</div>

          <div class="card-title">
            Quick Tips and Productivity Tutorials
          </div>

          <div class="card-desc">
            Learn practical workflows and hidden tricks to make the most out of the latest release.
          </div>

        </div>

      </div>

    </div>

  </div>

</div>

<script>

const tabs = document.querySelectorAll(".tab-btn");
const contents = document.querySelectorAll(".tab-content");

tabs.forEach(tab => {

  tab.addEventListener("click", () => {

    tabs.forEach(btn => btn.classList.remove("active"));
    contents.forEach(content => content.classList.remove("active"));

    tab.classList.add("active");

    document
      .getElementById(tab.dataset.tab)
      .classList.add("active");

  });

});

</script>

</body>
</html>