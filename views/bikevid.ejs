<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>Instagram Explore Module</title>

<style>

/* =========================
   GLOBAL
========================= */

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{

  background:#111;

  display:flex;
  justify-content:center;
  align-items:center;

  height:100vh;

  font-family:Arial, sans-serif;

  overflow:hidden;

}

/* =========================
   FIXED MODULE
========================= */

.insta-module{

  width:60%;
  height:620px;

  background:#1a1a1a;

  border:2px solid #333;

  border-radius:20px;

  overflow:hidden;

  padding:8px;

}

/* =========================
   4x2 GRID
========================= */

.grid{

  width:100%;
  height:100%;

  display:grid;

  grid-template-columns:
  repeat(4, 1fr);

  grid-template-rows:
  repeat(2, 1fr);

  gap:8px;

}

/* =========================
   CARD
========================= */

.card{

  position:relative;

  width:100%;
  height:100%;

  overflow:hidden;

  border-radius:12px;

  cursor:pointer;

}

/* IMAGE + VIDEO */

.card img,
.card video{

  width:100%;
  height:100%;

  object-fit:cover;

  display:block;

  transition:0.3s;

}

.card:hover img,
.card:hover video{

  transform:scale(1.05);

}

/* =========================
   PLAY ICON
========================= */

.play{

  position:absolute;

  top:10px;
  right:10px;

  background:rgba(0,0,0,0.6);

  color:white;

  border-radius:50%;

  padding:5px 8px;

  font-size:11px;

}

/* =========================
   VIDEO MODAL
========================= */

.modal{

  position:fixed;

  inset:0;

  background:black;

  display:none;

  justify-content:center;
  align-items:center;

  z-index:999;

}

.modal video{

  width:100%;
  height:100%;

  object-fit:contain;

}

.close{

  position:absolute;

  top:20px;
  right:30px;

  color:white;

  font-size:35px;

  cursor:pointer;

  z-index:1000;

}

/* =========================
   MOBILE
========================= */

@media(max-width:1000px){

  .insta-module{

    width:95%;
    height:90vh;

  }

  .grid{

    grid-template-columns:
    repeat(2,1fr);

    grid-template-rows:
    repeat(4,1fr);

  }

}

</style>
</head>

<body>

<!-- MODULE -->

<div class="insta-module">

  <div class="grid">

    <!-- 8 ITEMS ONLY -->

    <div class="card">
      <img src="https://picsum.photos/400?1">
    </div>

    <div class="card">
      <video muted>
        <source src="https://www.w3schools.com/html/mov_bbb.mp4">
      </video>
      <div class="play">▶</div>
    </div>

    <div class="card">
      <img src="https://picsum.photos/400?2">
    </div>

    <div class="card">
      <img src="https://picsum.photos/400?3">
    </div>

    <div class="card">
      <video muted>
        <source src="https://interactive-examples.mdn.mozilla.net/media/cc0-videos/flower.mp4">
      </video>
      <div class="play">▶</div>
    </div>

    <div class="card">
      <img src="https://picsum.photos/400?4">
    </div>

    <div class="card">
      <img src="https://picsum.photos/400?5">
    </div>

    <div class="card">
      <video muted>
        <source src="https://www.w3schools.com/html/movie.mp4">
      </video>
      <div class="play">▶</div>
    </div>

  </div>

</div>

<!-- VIDEO MODAL -->

<div class="modal" id="modal">

  <div class="close"
  id="closeBtn">

    ✖

  </div>

  <video controls autoplay
  id="modalVideo"></video>

</div>

<script>

/* =========================
   VIDEO POPUP
========================= */

const videos =
document.querySelectorAll(".card video");

const modal =
document.getElementById("modal");

const modalVideo =
document.getElementById("modalVideo");

const closeBtn =
document.getElementById("closeBtn");

videos.forEach(video=>{

  video.addEventListener("click", ()=>{

    modal.style.display = "flex";

    modalVideo.src =
    video.querySelector("source").src;

    modalVideo.play();

  });

});

closeBtn.addEventListener("click", ()=>{

  modal.style.display = "none";

  modalVideo.pause();

});

</script>

</body>
</html>