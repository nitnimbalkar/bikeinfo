<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>BikeInfo</title>

<style>

/* RESET */
* { margin:0; padding:0; box-sizing:border-box; }

body {
  font-family: Arial, sans-serif;
  background:#fff;
  color:#000;
  padding-top:60px;
}

/* NAVBAR */
.navbar {
  position:fixed;
  top:0;
  width:100%;
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:12px 20px;
  background:rgba(34,34,34,0.92);
  color:white;
  z-index:1000;
}

.logo { font-weight:bold; }

/* SWITCH */
.switch {
  position:relative;
  width:50px;
  height:26px;
}
.switch input { display:none; }

.slider {
  position:absolute;
  inset:0;
  background:#ccc;
  border-radius:30px;
  cursor:pointer;
}

.slider:before {
  content:"";
  position:absolute;
  width:20px;
  height:20px;
  left:3px;
  top:3px;
  background:white;
  border-radius:50%;
  transition:0.3s;
}

input:checked + .slider {
  background:#4CAF50;
}

input:checked + .slider:before {
  transform:translateX(24px);
}

/* PROFILE */
.profile {
  width:60%;
  margin:20px auto;
  border:1px solid #ddd;
  border-radius:14px;
  padding:18px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  background:#fafafa;
}

.profile-left {
  display:flex;
  align-items:center;
  gap:15px;
}

.profile-image {
  width:70px;
  height:70px;
  border-radius:50%;
  overflow:hidden;
  border:2px solid #ddd;
}

.profile-image img {
  width:100%;
  height:100%;
  object-fit:cover;
}

.profile-extra {
  display:flex;
  flex-direction:column;
  gap:6px;
  text-align:right;
  font-size:13px;
}

/* EDIT BUTTON */
.edit-btn {
  padding:6px 12px;
  border:none;
  background:#4CAF50;
  color:white;
  border-radius:8px;
  cursor:pointer;
  margin-bottom:8px;
}

/* GARAGE */
.garage {
  width:60%;
  margin:20px auto;
  border:1px solid #ddd;
  border-radius:14px;
  padding:18px;
  background:#fafafa;
}

.garage-top {
  display:flex;
  justify-content:space-between;
  align-items:center;
}

.garage-title {
  font-size:20px;
  font-weight:bold;
}

.add-btn {
  background:#4CAF50;
  color:white;
  border:none;
  padding:8px 12px;
  border-radius:8px;
}

/* GRID */
.bike-grid {
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:12px;
  margin-top:12px;
}

.bike-card {
  border:1px solid #ddd;
  border-radius:10px;
  overflow:hidden;
  background:#fff;
}

.bike-card img {
  width:100%;
  height:90px;
  object-fit:cover;
}

.bike-info {
  padding:8px;
}

.bike-name { font-size:13px; font-weight:bold; }
.bike-type { font-size:11px; color:#666; }

/* ================= PROFILE MODAL ================= */
.modal {
  position:fixed;
  inset:0;
  background:rgba(0,0,0,0.6);
  display:none;
  justify-content:center;
  align-items:center;
  z-index:1000;
}

.modal-box {
  width:340px;
  background:white;
  border-radius:16px;
  padding:20px;
}

.modal-box input {
  width:100%;
  padding:10px;
  margin:7px 0;
  border:1px solid #ddd;
  border-radius:10px;
}

.modal-box button {
  width:100%;
  padding:10px;
  background:#4CAF50;
  color:white;
  border:none;
  border-radius:10px;
}

/* ================= CROPPER ================= */
.cropper {
  position:fixed;
  inset:0;
  background:rgba(0,0,0,0.85);
  display:none;
  justify-content:center;
  align-items:center;
  z-index:2000;
  flex-direction:column;
}

.crop-circle {
  width:260px;
  height:260px;
  border-radius:50%;
  overflow:hidden;
  border:3px solid white;
  position:relative;
  background:#111;
}

.crop-img {
  position:absolute;
  width:400px;
  top:0;
  left:0;
  cursor:grab;
  user-select:none;
}

.zoom-control {
  margin-top:15px;
  width:200px;
}

.crop-actions {
  margin-top:15px;
  display:flex;
  gap:10px;
}

.crop-actions button {
  padding:8px 12px;
  border:none;
  border-radius:8px;
  cursor:pointer;
}

.save-btn { background:#4CAF50; color:white; }
.cancel-btn { background:#999; color:white; }

</style>
</head>

<body>

<!-- NAVBAR -->
<div class="navbar">
  <div class="logo">BikeInfo</div>
  <label class="switch">
    <input type="checkbox" id="darkToggle">
    <span class="slider"></span>
  </label>
</div>

<!-- PROFILE -->
<div class="profile">

  <div class="profile-left">
    <div class="profile-image">
      <img id="profileImg" src="https://i.pravatar.cc/300?img=12">
    </div>

    <div>
      <h2 id="fullName">Rahul Sharma</h2>
      <p>@riderx</p>
      <button class="edit-btn" onclick="openModal()">Edit Profile</button>
    </div>
  </div>

  <div class="profile-extra">
    <div id="age">🎂 Age: 24</div>
    <div id="city">📍 City: Pune</div>
    <div id="email">📧 Email: rahul@gmail.com</div>
  </div>

</div>

<!-- GARAGE -->
<div class="garage">
  <div class="garage-top">
    <div class="garage-title">My Garage</div>
    <button class="add-btn">+ Add Bike</button>
  </div>

  <div class="bike-grid" id="grid"></div>
</div>

<!-- PROFILE MODAL -->
<div class="modal" id="modal">
  <div class="modal-box">

    <input id="first" placeholder="First Name">
    <input id="last" placeholder="Last Name">
    <input id="ageInput" placeholder="Age">
    <input id="cityInput" placeholder="City">

    <input type="file" id="imgInput" accept="image/*" onchange="openCrop(event)">

    <button onclick="saveProfile()">Save</button>

  </div>
</div>

<!-- CROPPER -->
<div class="cropper" id="cropper">

  <div class="crop-circle">
    <img id="cropImg" class="crop-img">
  </div>

  <input type="range" min="1" max="2" step="0.01" value="1" class="zoom-control" id="zoom">

  <div class="crop-actions">
    <button class="cancel-btn" onclick="closeCrop()">Cancel</button>
    <button class="save-btn" onclick="applyCrop()">Crop & Save</button>
  </div>

</div>
<div class="profileModule_container">

  <!-- TABS -->
  <div class="profileModule_tabHeader">
    <button class="profileModule_tab active" data-tab="posts">Posts</button>
    <button class="profileModule_tab" data-tab="reviews">Bike Reviews</button>
  </div>

  <!-- POSTS -->
  <div id="postsTab">

    <div class="profileModule_topBar">
      <button class="profileModule_addBtn" id="addPostBtn">+</button>
    </div>

    <div id="postGrid" class="profileModule_postGrid"></div>
  </div>

  <!-- REVIEWS (UPDATED) -->
  <div id="reviewsTab" class="profileModule_hidden">

    <div class="profileModule_topBar">
      <button class="profileModule_addBtn" id="addReviewBtn">+</button>
    </div>

    <div id="reviewGrid" class="profileModule_reviewGrid"></div>
  </div>

</div>

<!-- MODAL -->
<div id="modal" class="profileModule_modalBackdrop profileModule_hidden">
  <div class="profileModule_modal">

    <h3 id="modalTitle">Add</h3>

    <input type="text" id="titleInput" placeholder="Title / Bike Name">
    <input type="text" id="locationInput" placeholder="Location (only for posts)">
    <textarea id="textInput" placeholder="Review Text (only for reviews)"></textarea>

    <input type="file" id="fileInput" accept="image/*">

    <button id="saveBtn">Save</button>
    <button id="closeBtn">Cancel</button>

  </div>
</div>

<script>

let cropImg = document.getElementById("cropImg");
let cropper = document.getElementById("cropper");
let zoom = document.getElementById("zoom");

let posX = 0, posY = 0;
let scale = 1;
let dragging = false;
let startX = 0, startY = 0;

/* OPEN CROPPER */
function openCrop(e){
  let file = e.target.files[0];
  let reader = new FileReader();

  reader.onload = function(ev){
    cropImg.src = ev.target.result;
    cropper.style.display = "flex";

    posX = 0; posY = 0; scale = 1;
    zoom.value = 1;
    updateTransform();
  }

  reader.readAsDataURL(file);
}

/* DRAG */
cropImg.addEventListener("mousedown", (e)=>{
  dragging = true;
  startX = e.clientX;
  startY = e.clientY;
  cropImg.style.cursor="grabbing";
});

document.addEventListener("mousemove",(e)=>{
  if(!dragging) return;

  posX += e.clientX - startX;
  posY += e.clientY - startY;

  startX = e.clientX;
  startY = e.clientY;

  updateTransform();
});

document.addEventListener("mouseup",()=>{
  dragging=false;
  cropImg.style.cursor="grab";
});

/* ZOOM */
zoom.addEventListener("input",()=>{
  scale = zoom.value;
  updateTransform();
});

function updateTransform(){
  cropImg.style.transform =
    `translate(${posX}px,${posY}px) scale(${scale})`;
}

/* CLOSE */
function closeCrop(){
  cropper.style.display="none";
}

/* APPLY CROP */
function applyCrop(){

  let canvas = document.createElement("canvas");
  canvas.width = 200;
  canvas.height = 200;
  let ctx = canvas.getContext("2d");

  let img = new Image();
  img.src = cropImg.src;

  img.onload = function(){
    ctx.drawImage(img, 0, 0, 200, 200);
    document.getElementById("profileImg").src = canvas.toDataURL();
    closeCrop();
  }
}

/* SAVE PROFILE */
function saveProfile(){
  document.getElementById("fullName").innerText =
    document.getElementById("first").value +
    " " +
    document.getElementById("last").value;

  document.getElementById("age").innerText =
    "🎂 Age: " + document.getElementById("ageInput").value;

  document.getElementById("city").innerText =
    "📍 City: " + document.getElementById("cityInput").value;

  document.getElementById("modal").style.display="none";
}

/* BIKE DATA */
let bikes=[
  {name:"KTM Duke 390",type:"Street",img:"https://images.unsplash.com/photo-1558981806-ec527fa84c39"},
  {name:"Yamaha R15",type:"Sport",img:"https://images.unsplash.com/photo-1580310614729-ccd69652491d"},
  {name:"BMW GS",type:"Adventure",img:"https://images.unsplash.com/photo-1609630875171-b1321377ee65"},
  {name:"Ninja 400",type:"Sport",img:"https://images.unsplash.com/photo-1625047509168-a7026f36de04"}
];

function render(){
  let grid=document.getElementById("grid");
  grid.innerHTML="";
  bikes.forEach(b=>{
    grid.innerHTML+=`
      <div class="bike-card">
        <img src="${b.img}">
        <div class="bike-info">
          <div class="bike-name">${b.name}</div>
          <div class="bike-type">${b.type}</div>
        </div>
      </div>`;
  });
}

render();

</script>

</body>
</html>