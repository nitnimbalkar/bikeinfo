/* DARK MODE (MATCHES YOUR JS: html.dark) */
html.dark .bike-module{
  --text:#e5e7eb;
  --muted:#9ca3af;
  border:1px solid #ffffff;
}

/* GLOBAL TEXT FIX (NO BLACK TEXT ANYWHERE) */
.bike-module,
