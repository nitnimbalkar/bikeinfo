<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Compact Bike Profile Popup</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:#eef2f7;
    font-family:Arial, sans-serif;
}

/* USER TRIGGER */

.user-box{
    position:relative;
}

.user-trigger{
    display:flex;
    align-items:center;
    gap:8px;
    background:#fff;
    padding:6px 12px;
    border-radius:50px;
    cursor:pointer;
    box-shadow:0 6px 16px rgba(0,0,0,0.08);
    transition:0.3s;
}

.user-trigger:hover{
    transform:translateY(-2px);
    box-shadow:0 10px 22px rgba(0,0,0,0.12);
}

.user-trigger img{
    width:34px;
    height:34px;
    border-radius:50%;
    object-fit:cover;
    border:2px solid #3b82f6;
}

.user-info h3{
    font-size:12px;
    color:#111827;
}

.user-info span{
    font-size:10px;
    color:#6b7280;
}

/* POPUP */

.popup{
    position:absolute;
    top:70px;
    left:50%;
    transform:translateX(-50%);
    width:190px;
    background:white;
    border-radius:18px;
    padding:16px 14px;
    text-align:center;
    box-shadow:0 14px 30px rgba(0,0,0,0.15);

    opacity:0;
    visibility:hidden;
    transition:0.3s ease;
}

.user-box:hover .popup{
    opacity:1;
    visibility:visible;
    top:78px;
}

/* PROFILE IMAGE */

.profile-img{
    width:60px;
    height:60px;
    margin:auto;
    border-radius:50%;
    overflow:hidden;
    border:3px solid #3b82f6;
    box-shadow:0 6px 14px rgba(59,130,246,0.25);
}

.profile-img img{
    width:100%;
    height:100%;
    object-fit:cover;
    border-radius:50%;
}

/* TEXT */

.content h2{
    margin-top:10px;
    font-size:14px;
    color:#111827;
}

.username{
    font-size:10px;
    color:#6b7280;
}

/* CHANGED LINE (BIKE NAME) */

.bike-name{
    margin-top:8px;
    font-size:11px;
    font-weight:600;
    color:#3b82f6;
}

/* STATS */

.stats{
    display:flex;
    justify-content:space-between;
    margin-top:12px;
    padding-top:10px;
    border-top:1px solid #eee;
}

.stats div h4{
    font-size:12px;
    color:#111827;
}

.stats div p{
    font-size:9px;
    color:#6b7280;
}

/* BUTTON */

.follow-btn{
    margin-top:12px;
    width:100%;
    border:none;
    padding:8px;
    border-radius:10px;
    background:linear-gradient(135deg,#3b82f6,#2563eb);
    color:white;
    font-size:11px;
    font-weight:bold;
    cursor:pointer;
    transition:0.3s;
}

.follow-btn:hover{
    transform:translateY(-1px);
    box-shadow:0 8px 14px rgba(59,130,246,0.25);
}

</style>
</head>

<body>

<div class="user-box">

    <div class="user-trigger">
        <img src="https://randomuser.me/api/portraits/men/32.jpg">
        <div class="user-info">
            <h3>Rahul Biker</h3>
            <span>@ridewithrahul</span>
        </div>
    </div>

    <div class="popup">

        <div class="profile-img">
            <img src="https://randomuser.me/api/portraits/men/32.jpg">
        </div>

        <div class="content">
            <h2>Rahul Biker</h2>
            <div class="username">@ridewithrahul</div>

            <!-- NEW BIKE NAME -->
            <div class="bike-name">
                Kawasaki Ninja ZX-10R
            </div>

            <div class="stats">
                <div>
                    <h4>128</h4>
                    <p>Reviews</p>
                </div>
                <div>
                    <h4>54K</h4>
                    <p>Followers</p>
                </div>
                <div>
                    <h4>220</h4>
                    <p>Following</p>
                </div>
            </div>

            <button class="follow-btn">Follow</button>
        </div>

    </div>

</div>

</body>
</html>