<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>BikeInfo</title>

<style>

/* RESET */
*{margin:0;padding:0;box-sizing:border-box;}

body{
  font-family:Arial;
  background:#fff;
  color:#000;
  padding-top:60px;
}

/* NAVBAR */
.navbar{
  position:fixed;
  top:0;
  width:100%;
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:12px 20px;
  background:rgba(30,30,30,0.95);
  color:white;
  z-index:1000;
}

.logo{font-weight:bold;}

/* TOGGLE */
.switch{position:relative;width:50px;height:26px;}
.switch input{display:none;}

.slider{
  position:absolute;inset:0;
  background:#ccc;border-radius:30px;cursor:pointer;
}
.slider:before{
  content:"";
  position:absolute;width:20px;height:20px;
  left:3px;top:3px;background:white;border-radius:50%;
  transition:0.3s;
}
input:checked + .slider{background:#4CAF50;}
input:checked + .slider:before{transform:translateX(24px);}

/* PROFILE */
.profile{
  width:60%;
  margin:20px auto;
  border:1px solid #ddd;
  border-radius:14px;
  padding:18px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  background:#fafafa;
}

.profile-left{display:flex;gap:15px;align-items:center;}

.profile-img{
  width:70px;height:70px;
  border-radius:50%;
  overflow:hidden;
  border:2px solid #ddd;
}
.profile-img img{width:100%;height:100%;object-fit:cover;}

.profile-right{
  display:flex;
  flex-direction:column;
  text-align:right;
  gap:6px;
}

.edit-btn{
  padding:6px 12px;
  background:#4CAF50;
  border:none;
  color:white;
  border-radius:8px;
  cursor:pointer;
  margin-bottom:6px;
}

/* GARAGE */
.garage{
  width:60%;
  margin:20px auto;
  border:1px solid #ddd;
  border-radius:14px;
  padding:18px;
  background:#fafafa;
}

.garage-top{
  display:flex;
  justify-content:space-between;
}

.bike-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:12px;
  margin-top:12px;
}

.bike-card{
  border:1px solid #ddd;
  border-radius:10px;
  overflow:hidden;
  background:#fff;
}

.bike-card img{
  width:100%;
  height:90px;
  object-fit:cover;
}

.bike-info{padding:8px;}
.bike-name{font-size:13px;font-weight:bold;}
.bike-type{font-size:11px;color:#666;}

/* MODALS */
.modal{
  position:fixed;
  inset:0;
  display:none;
  justify-content:center;
  align-items:center;
  background:rgba(0,0,0,0.6);
  z-index:9999;
}

.modal-box{
  width:340px;
  background:white;
  border-radius:16px;
  padding:20px;
}

.modal-box input{
  width:100%;
  padding:10px;
  margin:6px 0;
  border:1px solid #ddd;
  border-radius:10px;
}

.modal-box button{
  width:100%;
  padding:10px;
  background:#4CAF50;
  border:none;
  color:white;
  border-radius:10px;
  cursor:pointer;
}

/* BIKE SEARCH RESULTS */
#bikeResults div{
  padding:10px;
  margin:5px 0;
  border:1px solid #ddd;
  border-radius:8px;
  cursor:pointer;
}

#bikeResults div:hover{
  background:#f0f0f0;
}

.selectedBike{
  background:#4CAF50 !important;
  color:white;
}

/* CROPPER */
.cropper{
  position:fixed;
  inset:0;
  display:none;
  justify-content:center;
  align-items:center;
  background:rgba(0,0,0,0.7);
  z-index:20000;
  flex-direction:column;
}

.crop-box{
  width:260px;
  height:260px;
  border-radius:50%;
  overflow:hidden;
  border:3px solid white;
  position:relative;
}

.crop-img{
  position:absolute;
  width:400px;
  cursor:grab;
}

.zoom{
  margin-top:12px;
  width:200px;
}

.crop-actions{
  margin-top:10px;
  display:flex;
  gap:10px;
}

.crop-actions button{
  padding:8px 12px;
  border:none;
  border-radius:8px;
  cursor:pointer;
}

.save{background:#4CAF50;color:white;}
.cancel{background:#999;color:white;}

</style>
</head>

<body>

<!-- NAVBAR -->
<div class="navbar">
  <div class="logo">BikeInfo</div>

  <label class="switch">
    <input type="checkbox" id="darkToggle">
    <span class="slider"></span>
  </label>
</div>

<!-- PROFILE -->
<div class="profile">

  <div class="profile-left">
    <div class="profile-img">
      <img id="profilePic" src="https://i.pravatar.cc/300?img=12">
    </div>

    <div>
      <h3 id="name">Rahul Sharma</h3>
      <p>@riderx</p>
      <button class="edit-btn" onclick="openProfile()">Edit Profile</button>
    </div>
  </div>

  <div class="profile-right">
    <div id="age">Age: 24</div>
    <div id="city">City: Pune</div>
    <div id="email">Email: test@gmail.com</div>
  </div>

</div>

<!-- GARAGE -->
<div class="garage">
  <div class="garage-top">
    <h3>Garage</h3>
    <button onclick="openBikeModal()">+ Add Bike</button>
  </div>

  <div class="bike-grid" id="grid"></div>
</div>

<!-- PROFILE MODAL -->
<div class="modal" id="modal">
  <div class="modal-box">

    <input id="first" placeholder="First Name">
    <input id="last" placeholder="Last Name">
    <input id="ageInput" placeholder="Age">
    <input id="cityInput" placeholder="City">

    <input type="file" accept="image/*" onchange="openCrop(event)">

    <button onclick="saveProfile()">Save</button>

  </div>
</div>

<!-- BIKE MODAL -->
<div class="modal" id="bikeModal">
  <div class="modal-box">

    <h3>Select Bike</h3>

    <input id="bikeSearch" placeholder="Search bike..." oninput="searchBike()">

    <div id="bikeResults"></div>

    <button id="addBikeBtn" onclick="addBike()" style="display:none;margin-top:10px;">
      Add Bike
    </button>

  </div>
</div>

<!-- CROPPER -->
<div class="cropper" id="cropper">

  <div class="crop-box">
    <img id="cropImg" class="crop-img">
  </div>

  <input type="range" min="1" max="2" step="0.01" id="zoom" class="zoom">

  <div class="crop-actions">
    <button class="cancel" onclick="closeCrop()">Cancel</button>
    <button class="save" onclick="applyCrop()">Crop</button>
  </div>

</div>

<script>

/* DARK MODE */
document.getElementById("darkToggle").onchange=()=>{
  document.body.classList.toggle("dark");
};

/* PROFILE */
function openProfile(){
  document.getElementById("modal").style.display="flex";
}

/* CROPPER */
let img=document.getElementById("cropImg");
let zoom=document.getElementById("zoom");

let x=0,y=0,scale=1,drag=false,sx,sy;

function openCrop(e){
  let file=e.target.files[0];
  let reader=new FileReader();

  reader.onload=ev=>{
    img.src=ev.target.result;
    document.getElementById("cropper").style.display="flex";
  }

  reader.readAsDataURL(file);
}

/* DRAG */
img.onmousedown=e=>{
  drag=true;
  sx=e.clientX;
  sy=e.clientY;
};

document.onmousemove=e=>{
  if(!drag)return;
  x+=e.clientX-sx;
  y+=e.clientY-sy;
  sx=e.clientX;
  sy=e.clientY;
  update();
};

document.onmouseup=()=>drag=false;

/* ZOOM */
zoom.oninput=()=>{
  scale=zoom.value;
  update();
};

function update(){
  img.style.transform=`translate(${x}px,${y}px) scale(${scale})`;
}

function closeCrop(){
  document.getElementById("cropper").style.display="none";
}

/* APPLY CROP */
function applyCrop(){
  let canvas=document.createElement("canvas");
  canvas.width=200;
  canvas.height=200;
  let ctx=canvas.getContext("2d");

  let im=new Image();
  im.src=img.src;

  im.onload=()=>{
    ctx.drawImage(im,0,0,200,200);
    document.getElementById("profilePic").src=canvas.toDataURL();
    closeCrop();
  }
}

/* SAVE PROFILE */
function saveProfile(){
  document.getElementById("name").innerText=
    document.getElementById("first").value+" "+document.getElementById("last").value;

  document.getElementById("age").innerText="Age: "+document.getElementById("ageInput").value;
  document.getElementById("city").innerText="City: "+document.getElementById("cityInput").value;

  document.getElementById("modal").style.display="none";
}

/* BIKE SYSTEM */
const bikeDB=[
  "KTM Duke 390",
  "Yamaha R15 V4",
  "BMW G 310 GS",
  "Kawasaki Ninja 400",
  "Royal Enfield GT 650",
  "Ducati Panigale V2",
  "TVS Apache RR 310"
];

let selectedBike=null;

function openBikeModal(){
  document.getElementById("bikeModal").style.display="flex";
  renderList(bikeDB);
}

function renderList(list){
  let box=document.getElementById("bikeResults");
  box.innerHTML="";
  list.forEach(b=>{
    let div=document.createElement("div");
    div.innerText=b;

    div.onclick=()=>{
      selectedBike=b;
      document.querySelectorAll("#bikeResults div")
      .forEach(d=>d.classList.remove("selectedBike"));
      div.classList.add("selectedBike");
      document.getElementById("addBikeBtn").style.display="block";
    };

    box.appendChild(div);
  });
}

function searchBike(){
  let val=document.getElementById("bikeSearch").value.toLowerCase();
  let filtered=bikeDB.filter(b=>b.toLowerCase().includes(val));
  renderList(filtered);
}

function addBike(){
  if(!selectedBike)return;

  let grid=document.getElementById("grid");

  grid.innerHTML+=`
    <div class="bike-card">
      <img src="https://source.unsplash.com/300x200/?motorcycle">
      <div class="bike-info">
        <div class="bike-name">${selectedBike}</div>
        <div class="bike-type">Custom</div>
      </div>
    </div>
  `;

  document.getElementById("bikeModal").style.display="none";
  document.getElementById("bikeSearch").value="";
  document.getElementById("addBikeBtn").style.display="none";
  selectedBike=null;
}

/* INIT */
let grid=document.getElementById("grid");
["KTM Duke 390","Yamaha R15","BMW GS","Ninja 400"].forEach(b=>{
  grid.innerHTML+=`
    <div class="bike-card">
      <img src="https://source.unsplash.com/300x200/?bike">
      <div class="bike-info">
        <div class="bike-name">${b}</div>
        <div class="bike-type">Default</div>
      </div>
    </div>`;
});

</script>

</body>
</html>