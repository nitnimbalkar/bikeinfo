<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Add Brand</title>

  <link href="https://fonts.googleapis.com/css2?family=Poppins&display=swap" rel="stylesheet">

  <style>
    :root {
      --bg: #f4f6f9;
      --card: #ffffff;
      --text: #222;
      --subtext: #666;
      --border: #e0e0e0;
      --accent: #6c63ff;
      --section: #f9fafc;
    }

    body {
      font-family: 'Poppins', sans-serif;
      background: var(--bg);
      margin: 0;
      color: var(--text);
    }

    .container {
      width: 850px;
      margin: 40px auto;
      background: var(--card);
      border-radius: 16px;
      padding: 30px;
      box-shadow: 0 15px 35px rgba(0,0,0,0.08);
    }

    h2 {
      text-align: center;
      margin-bottom: 25px;
    }

    .section {
      margin-bottom: 25px;
      padding: 20px;
      border-radius: 12px;
      background: var(--section);
      border: 1px solid var(--border);
    }

    .section h3 {
      margin-bottom: 15px;
      font-size: 18px;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 15px;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    input {
      padding: 10px 12px;
      border-radius: 8px;
      border: 1px solid var(--border);
      font-size: 14px;
      outline: none;
      transition: 0.2s;
    }

    input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(108,99,255,0.15);
    }

    input[type="file"] {
      padding: 8px;
      background: transparent;
    }

    button {
      width: 100%;
      padding: 14px;
      border-radius: 10px;
      border: none;
      background: var(--accent);
      color: white;
      font-size: 16px;
      cursor: pointer;
      transition: 0.2s;
    }

    button:hover {
      opacity: 0.9;
      transform: translateY(-1px);
    }

    @media (max-width: 768px) {
      .container {
        width: 95%;
      }
      .grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

<body>

<div class="container">
  <h2>Add Brand</h2>

  <form action="/brands/add-brand" method="POST" enctype="multipart/form-data">

    <div class="section">
      <h3>Brand Info</h3>

      <div class="grid">

        <div class="form-group">
          <input type="text" name="brandName" placeholder="Enter Brand Name" required>
        </div>

        <div class="form-group">
          <input type="text" name="brandOrigin" placeholder="Enter Brand Origin" required>
        </div>

        <div class="form-group">
          <label>Brand Image</label>
          <input type="file" name="brandImage" accept="image/*">
        </div>

      </div>
    </div>

    <button type="submit">Add Brand</button>

  </form>
</div>

</body>
</html>