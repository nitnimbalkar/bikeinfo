<script>
const toggle = document.getElementById("darkToggle");

if (toggle) {
  toggle.addEventListener("change", () => {
    document.documentElement.classList.toggle("dark", toggle.checked);
  });
}

function openDrawer(brand) {
  document.getElementById("drawer").classList.add("active");
  document.getElementById("backdrop").classList.add("active");
  document.getElementById("brandTitle").innerText = brand;
}

function closeDrawer() {
  document.getElementById("drawer").classList.remove("active");
  document.getElementById("backdrop").classList.remove("active");
}
function openLogin() {
  document.getElementById("loginModal").classList.add("active");
}

function closeLogin() {
  document.getElementById("loginModal").classList.remove("active");
}

// close when clicking outside
document.getElementById("loginModal").addEventListener("click", function(e) {
  if (e.target === this) {
    closeLogin();
  }
});
function showSignup() {
  document.getElementById("loginForm").style.display = "none";
  document.getElementById("signupForm").style.display = "block";
}

function showLogin() {
  document.getElementById("signupForm").style.display = "none";
  document.getElementById("loginForm").style.display = "block";
}
function loginUser() {
  // fake login success
  localStorage.setItem("loggedIn", "true");
  localStorage.setItem("profilePic", "https://i.pravatar.cc/150");

  updateAuthUI();
  closeLogin();
}

function handleAuth() {
  const isLoggedIn = localStorage.getItem("loggedIn");

  if (isLoggedIn) {
    toggleMenu(); // 👈 open dropdown menu
  } else {
    openLogin(); // 👈 open login popup
  }
}
function toggleMenu() {
  document.getElementById("profileMenu").classList.toggle("show");
}

function updateAuthUI() {
  const btn = document.getElementById("authBtn");
  const isLoggedIn = localStorage.getItem("loggedIn");

  if (isLoggedIn) {
    const img = document.createElement("img");
    img.src = localStorage.getItem("profilePic");
    img.className = "profile-pic";

    btn.innerHTML = "";
    btn.appendChild(img);
    btn.onclick = handleAuth;
  } else {
    btn.innerText = "Login";
  }
}
const bm_bikes = [
  {name:"Bike A", price:100000, cc:150, mileage:60, type:"commuter", img:"https://via.placeholder.com/200"},
  {name:"Bike B", price:200000, cc:250, mileage:40, type:"sport", img:"https://via.placeholder.com/200"},
  {name:"Bike C", price:300000, cc:400, mileage:30, type:"naked", img:"https://via.placeholder.com/200"},
  {name:"Bike D", price:500000, cc:650, mileage:25, type:"adventure", img:"https://via.placeholder.com/200", upcoming:true},
  {name:"Bike E", price:120000, cc:125, mileage:70, type:"commuter", img:"https://via.placeholder.com/200"},
  {name:"Bike F", price:180000, cc:200, mileage:55, type:"naked", img:"https://via.placeholder.com/200", upcoming:true},
  {name:"Bike G", price:400000, cc:500, mileage:35, type:"sport", img:"https://via.placeholder.com/200"},
  {name:"Bike H", price:600000, cc:900, mileage:20, type:"adventure", img:"https://via.placeholder.com/200", upcoming:true},
  {name:"Bike A", price:100000, cc:150, mileage:60, type:"commuter", img:"https://via.placeholder.com/200"},
  {name:"Bike B", price:200000, cc:250, mileage:40, type:"sport", img:"https://via.placeholder.com/200"},
  {name:"Bike C", price:300000, cc:400, mileage:30, type:"naked", img:"https://via.placeholder.com/200"},
  {name:"Bike D", price:500000, cc:650, mileage:25, type:"adventure", img:"https://via.placeholder.com/200", upcoming:true},
  {name:"Bike E", price:120000, cc:125, mileage:70, type:"commuter", img:"https://via.placeholder.com/200"},
  {name:"Bike F", price:180000, cc:200, mileage:55, type:"naked", img:"https://via.placeholder.com/200", upcoming:true},
  {name:"Bike G", price:400000, cc:500, mileage:35, type:"sport", img:"https://via.placeholder.com/200"},
  {name:"Bike H", price:600000, cc:900, mileage:20, type:"adventure", img:"https://via.placeholder.com/200", upcoming:true},
];

/* TRENDING */
function bm_loadTrending(){
  const g=document.getElementById("bm_trendingGrid");
  g.innerHTML="";
  bm_bikes.forEach(b=>{
    g.innerHTML+=`
      <div class="card">
        <img src="${b.img}">
        <div class="card-body">
          <b>${b.name}</b><br>${b.cc}cc
        </div>
      </div>`;
  });
}

/* FILTER */
function bm_filter(){
  const price=document.getElementById("bm_price").value;
  document.getElementById("bm_priceVal").innerText=
    Number(price).toLocaleString();

  const cc=document.querySelector('input[name="bm_cc"]:checked')?.value;
  const m=document.querySelector('input[name="bm_m"]:checked')?.value;
  const type=document.querySelector('input[name="bm_type"]:checked')?.value;

  const g=document.getElementById("bm_bikeGrid");
  g.innerHTML="";

  bm_bikes
    .filter(b =>
      (!cc || b.cc<=cc) &&
      (!m || b.mileage>=m) &&
      (!type || b.type===type) &&
      (b.price<=price)
    )
    .forEach(b=>{
      g.innerHTML+=`
        <div class="card">
          <img src="${b.img}">
          <div class="card-body">
            <b>${b.name}</b><br>
            <span class="price">₹${b.price.toLocaleString()}</span><br>
            ${b.cc}cc | ${b.type}
          </div>
        </div>`;
    });
}

function bm_loadUpcoming(){
  const g=document.getElementById("bm_upcomingGrid");
  g.innerHTML="";

  bm_bikes
    .filter(b=>b.upcoming)
    .forEach(b=>{
      g.innerHTML+=`
        <div class="card">
          <img src="${b.img}">
          <div class="card-body">
            <b>${b.name}</b><br>
            <span style="color:#f59e0b;font-weight:600;">Upcoming</span><br>
            ${b.cc}cc
          </div>
        </div>`;
    });
}
/* TABS */
function bm_show(tab,e){

  document.getElementById("bm_trend").style.display =
    tab==="trend" ? "block" : "none";

  document.getElementById("bm_browse").style.display =
    tab==="browse" ? "block" : "none";

  document.getElementById("bm_upcoming").style.display =
    tab==="upcoming" ? "block" : "none";

  document.querySelectorAll(".bike-module .tab")
    .forEach(t=>t.classList.remove("active"));

  e.target.classList.add("active");

  if(tab==="upcoming"){
    bm_loadUpcoming();
  }
}
function openModal(name, bike, text) {
  document.getElementById("reviewModal").style.display = "flex";

  document.getElementById("modalName").innerText = name;
  document.getElementById("modalBike").innerText = bike;
  document.getElementById("modalText").innerText = text;
}

function closeModal() {
  document.getElementById("reviewModal").style.display = "none";
}

/* MODAL LIKE */
let liked = false;

function toggleLike(){
  const heart = document.getElementById("heartBtn");

  liked = !liked;

  heart.innerHTML = liked ? "♥" : "♡";
  heart.classList.toggle("liked", liked);
}

/* CARD LIKE */
function toggleCardLike(btn){
  const heart = btn.querySelector(".heart");
  const countEl = btn.nextElementSibling;

  let count = parseInt(countEl.innerText);

  if(btn.classList.contains("liked")){
    btn.classList.remove("liked");
    heart.innerText = "♡";
    countEl.innerText = count - 1;
  } else {
    btn.classList.add("liked");
    heart.innerText = "♥";
    countEl.innerText = count + 1;
  }
}
/* ================= TABS ================= */

const tabs = document.querySelectorAll(".tab-btn");
const contents = document.querySelectorAll(".tab-content");

tabs.forEach(tab=>{

  tab.addEventListener("click",()=>{

    tabs.forEach(t=>t.classList.remove("active"));
    contents.forEach(c=>c.classList.remove("active"));

    tab.classList.add("active");

    document
      .getElementById(tab.dataset.tab)
      .classList.add("active");

  });

});

/* ================= ELEMENTS ================= */

const modal = document.getElementById("modal");

const modalBox = document.querySelector(".modal-box");

const modalImg = document.getElementById("modalImg");

const modalTitle = document.getElementById("modalTitle");

const modalText = document.getElementById("modalText");

const videoContainer =
  document.getElementById("videoContainer");

/* ================= NORMAL MODAL ================= */

function openModal(title,img,text){

  modalBox.classList.remove("video-mode");

  modalImg.style.display = "block";

  modalImg.src = img;

  modalTitle.innerText = title;

  modalText.innerText = text;

  modal.classList.add("active");

  document.body.style.overflow = "hidden";

}

/* ================= VIDEO MODAL ================= */

function openVideoModal(videoUrl){

  modal.classList.add("active");

  modalBox.classList.add("video-mode");

  videoContainer.innerHTML = `
    <iframe
      src="${videoUrl}?autoplay=1&rel=0&modestbranding=1"
      title="YouTube video player"
      allow="autoplay; encrypted-media"
      allowfullscreen>
    </iframe>
  `;

  document.body.style.overflow = "hidden";

}

/* ================= CLOSE ================= */

function closeModal(){

  modal.classList.remove("active");

  modalBox.classList.remove("video-mode");

  videoContainer.innerHTML = "";

  document.body.style.overflow = "auto";

}

/* ================= OUTSIDE CLICK ================= */

modal.addEventListener("click",(e)=>{

  if(e.target.id==="modal"){
    closeModal();
  }

});

/* ================= ESC KEY ================= */

document.addEventListener("keydown",(e)=>{

  if(e.key==="Escape"){
    closeModal();
  }

});



/* INIT */
bm_loadTrending();
bm_filter();
bm_loadUpcoming();
// run on page load
updateAuthUI();
const videos = document.querySelectorAll(".insta-module video");

videos.forEach(video => {
  video.addEventListener("click", () => {
    video.muted = false;
    video.play();
  });
});

</script>

