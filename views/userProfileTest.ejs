<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>BikeInfo</title>

<style>
/* RESET */
*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:Arial,sans-serif;
background:#f4f4f4;
color:#222;
padding-top:70px;
transition:.3s;
}

/* DARK MODE */
body.dark{
background:#111;
color:white;
}

body.dark .section,
body.dark .profile,
body.dark .modal-box,
body.dark .card{
background:#1e1e1e;
color:white;
border-color:#333;
}

/* NAVBAR */
.navbar{
position:fixed;
top:0;
left:0;
width:100%;
padding:15px 25px;
display:flex;
justify-content:space-between;
align-items:center;
background:#222;
color:white;
z-index:1000;
}

.logo{
font-size:20px;
font-weight:bold;
}

/* SWITCH */
.switch{
position:relative;
width:50px;
height:25px;
}

.switch input{
display:none;
}

.slider{
position:absolute;
inset:0;
background:#ccc;
border-radius:30px;
cursor:pointer;
}

.slider:before{
content:"";
position:absolute;
height:19px;
width:19px;
left:3px;
top:3px;
background:white;
border-radius:50%;
transition:.3s;
}

input:checked + .slider{
background:#4CAF50;
}

input:checked + .slider:before{
transform:translateX(25px);
}

/* PROFILE */
.profile{
width:90%;
max-width:1100px;
margin:20px auto;
background:white;
padding:20px;
border-radius:15px;
display:flex;
justify-content:space-between;
align-items:center;
box-shadow:0 3px 10px rgba(0,0,0,.08);
}

.profile-left{
display:flex;
align-items:center;
gap:15px;
}

.profile-image{
width:90px;
height:90px;
border-radius:50%;
overflow:hidden;
border:3px solid #ddd;
}

.profile-image img{
width:100%;
height:100%;
object-fit:cover;
}

.profile-extra{
display:flex;
flex-direction:column;
gap:8px;
text-align:right;
}

/* BUTTONS */
.edit-btn,
.add-btn,
.action-btn{
padding:10px 15px;
border:none;
border-radius:8px;
cursor:pointer;
background:#4CAF50;
color:white;
}

.delete-btn{
background:#e53935;
}

.edit-small{
background:#ff9800;
}

/* SECTION */
.section{
width:90%;
max-width:1100px;
margin:20px auto;
background:white;
padding:20px;
border-radius:15px;
box-shadow:0 3px 10px rgba(0,0,0,.08);
}

.section-header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:15px;
}

/* GARAGE */
.bike-grid{
display:grid;
grid-template-columns:
repeat(auto-fit,minmax(220px,1fr));
gap:15px;
}

.bike-card{
background:white;
border:1px solid #ddd;
border-radius:12px;
overflow:hidden;
}

.bike-card img{
width:100%;
height:170px;
object-fit:cover;
}

.bike-info{
padding:10px;
}

.bike-name{
font-size:16px;
font-weight:bold;
margin-bottom:5px;
}

.bike-type{
font-size:13px;
color:#777;
margin-bottom:10px;
}

.bike-actions{
display:flex;
gap:10px;
}

/* POSTS */
.post-card{
background:white;
border:1px solid #ddd;
padding:15px;
border-radius:12px;
margin-bottom:15px;
}

.post-date{
font-size:12px;
color:#888;
margin-bottom:10px;
}

.post-actions{
margin-top:15px;
}

/* REVIEWS */
.review-card{
background:white;
border:1px solid #ddd;
padding:15px;
border-radius:12px;
margin-bottom:15px;
}

.review-title{
font-size:18px;
font-weight:bold;
margin-bottom:8px;
}

.review-rating{
color:#f9a825;
margin-bottom:10px;
}

.review-actions{
display:flex;
gap:10px;
margin-top:15px;
}

/* MODAL */
.modal{
position:fixed;
inset:0;
display:none;
justify-content:center;
align-items:center;
background:rgba(0,0,0,.6);
z-index:9999;
}

.modal-box{
width:90%;
max-width:450px;
background:white;
padding:20px;
border-radius:15px;
display:flex;
flex-direction:column;
gap:10px;
}

.modal-box input,
.modal-box textarea{
padding:10px;
border:1px solid #ccc;
border-radius:8px;
width:100%;
}

.modal-box button{
padding:10px;
border:none;
border-radius:8px;
background:#4CAF50;
color:white;
cursor:pointer;
}

/* MOBILE */
@media(max-width:768px){

.profile{
flex-direction:column;
gap:15px;
text-align:center;
}

.profile-extra{
text-align:center;
}

.section-header{
flex-direction:column;
gap:10px;
}

}
</style>
</head>

<body>

<!-- NAVBAR -->
<div class="navbar">
  <div class="logo">BikeInfo</div>

  <label class="switch">
    <input type="checkbox" id="darkToggle">
    <span class="slider"></span>
  </label>
</div>

<!-- PROFILE -->
<div class="profile">

  <div class="profile-left">

    <div class="profile-image">
      <img id="profileImg"
      src="https://i.pravatar.cc/300?img=12">
    </div>

    <div>
      <h2 id="fullName">Rahul Sharma</h2>
      <p id="username">@riderx</p>

      <button
      class="edit-btn"
      onclick="openProfileModal()">
      Edit Profile
      </button>
    </div>

  </div>

  <div class="profile-extra">

    <div id="age">
      🎂 Age: 24
    </div>

    <div id="city">
      📍 City: Pune
    </div>

    <div id="email">
      📧 Email: rahul@gmail.com
    </div>

  </div>

</div>

<!-- GARAGE -->
<div class="section">

  <div class="section-header">
    <h2>🏍 My Garage</h2>

    <button
    class="add-btn"
    onclick="openBikeModal()">
    + Add Bike
    </button>

  </div>

  <div
  class="bike-grid"
  id="bikeGrid">
  </div>

</div>

<!-- POSTS -->
<div class="section">

  <div class="section-header">
    <h2>📝 My Posts</h2>

    <button
    class="add-btn"
    onclick="openPostModal()">
    + Add Post
    </button>

  </div>

  <div id="postContainer">
  </div>

</div>

<!-- REVIEWS -->
<div class="section">

  <div class="section-header">
    <h2>⭐ My Reviews</h2>

    <button
    class="add-btn"
    onclick="openReviewModal()">
    + Add Review
    </button>

  </div>

  <div id="reviewContainer">
  </div>

</div>

<!-- PROFILE MODAL -->
<div class="modal" id="profileModal">

  <div class="modal-box">

    <h3>Edit Profile</h3>

    <input
    id="firstName"
    placeholder="First Name">

    <input
    id="lastName"
    placeholder="Last Name">

    <input
    id="userNameInput"
    placeholder="Username">

    <input
    id="emailInput"
    placeholder="Email">

    <input
    id="ageInput"
    placeholder="Age">

    <input
    id="cityInput"
    placeholder="City">

    <input
    type="file"
    id="profileUpload"
    accept="image/*">

    <button onclick="saveProfile()">
      Save Profile
    </button>

  </div>

</div>

<!-- BIKE MODAL -->
<div class="modal" id="bikeModal">

  <div class="modal-box">

    <h3>Add Bike</h3>

    <input
    id="bikeName"
    placeholder="Bike Name">

    <input
    id="bikeType"
    placeholder="Bike Type">

    <input
    id="bikeImage"
    placeholder="Bike Image URL">

    <button onclick="saveBike()">
      Save Bike
    </button>

  </div>

</div>

<!-- POST MODAL -->
<div class="modal" id="postModal">

  <div class="modal-box">

    <h3>Create Post</h3>

    <textarea
    id="postText"
    rows="5"
    placeholder="Write your post...">
    </textarea>

    <button onclick="savePost()">
      Publish
    </button>

  </div>

</div>

<!-- REVIEW MODAL -->
<div class="modal" id="reviewModal">

  <div class="modal-box">

    <h3>Add Review</h3>

    <input
    id="reviewBike"
    placeholder="Bike Name">

    <input
    id="reviewRating"
    type="number"
    min="1"
    max="5"
    placeholder="Rating (1-5)">

    <textarea
    id="reviewText"
    rows="5"
    placeholder="Write review">
    </textarea>

    <button onclick="saveReview()">
      Save Review
    </button>

  </div>

</div>

<script>

let cropImg = document.getElementById("cropImg");
let cropper = document.getElementById("cropper");
let zoom = document.getElementById("zoom");

let posX = 0, posY = 0;
let scale = 1;
let dragging = false;
let startX = 0, startY = 0;

/* OPEN CROPPER */
function openCrop(e){
  let file = e.target.files[0];
  let reader = new FileReader();

  reader.onload = function(ev){
    cropImg.src = ev.target.result;
    cropper.style.display = "flex";

    posX = 0; posY = 0; scale = 1;
    zoom.value = 1;
    updateTransform();
  }

  reader.readAsDataURL(file);
}

/* DRAG */
cropImg.addEventListener("mousedown", (e)=>{
  dragging = true;
  startX = e.clientX;
  startY = e.clientY;
  cropImg.style.cursor="grabbing";
});

document.addEventListener("mousemove",(e)=>{
  if(!dragging) return;

  posX += e.clientX - startX;
  posY += e.clientY - startY;

  startX = e.clientX;
  startY = e.clientY;

  updateTransform();
});

document.addEventListener("mouseup",()=>{
  dragging=false;
  cropImg.style.cursor="grab";
});

/* ZOOM */
zoom.addEventListener("input",()=>{
  scale = zoom.value;
  updateTransform();
});

function updateTransform(){
  cropImg.style.transform =
    `translate(${posX}px,${posY}px) scale(${scale})`;
}

/* CLOSE */
function closeCrop(){
  cropper.style.display="none";
}

/* APPLY CROP */
function applyCrop(){

  let canvas = document.createElement("canvas");
  canvas.width = 200;
  canvas.height = 200;
  let ctx = canvas.getContext("2d");

  let img = new Image();
  img.src = cropImg.src;

  img.onload = function(){
    ctx.drawImage(img, 0, 0, 200, 200);
    document.getElementById("profileImg").src = canvas.toDataURL();
    closeCrop();
  }
}

/* SAVE PROFILE */
function saveProfile(){
  document.getElementById("fullName").innerText =
    document.getElementById("first").value +
    " " +
    document.getElementById("last").value;

  document.getElementById("age").innerText =
    "🎂 Age: " + document.getElementById("ageInput").value;

  document.getElementById("city").innerText =
    "📍 City: " + document.getElementById("cityInput").value;

  document.getElementById("modal").style.display="none";
}

/* BIKE DATA */
let bikes=[
  {name:"KTM Duke 390",type:"Street",img:"https://images.unsplash.com/photo-1558981806-ec527fa84c39"},
  {name:"Yamaha R15",type:"Sport",img:"https://images.unsplash.com/photo-1580310614729-ccd69652491d"},
  {name:"BMW GS",type:"Adventure",img:"https://images.unsplash.com/photo-1609630875171-b1321377ee65"},
  {name:"Ninja 400",type:"Sport",img:"https://images.unsplash.com/photo-1625047509168-a7026f36de04"}
];

function render(){
  let grid=document.getElementById("grid");
  grid.innerHTML="";
  bikes.forEach(b=>{
    grid.innerHTML+=`
      <div class="bike-card">
        <img src="${b.img}">
        <div class="bike-info">
          <div class="bike-name">${b.name}</div>
          <div class="bike-type">${b.type}</div>
        </div>
      </div>`;
  });
}

render();

</script>

</body>
</html>