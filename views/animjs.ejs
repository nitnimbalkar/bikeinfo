<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bike Info</title>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI',sans-serif;
}

body{
    min-height:100vh;
    color:white;
    overflow-x:hidden;

    background:linear-gradient(
        -45deg,
        #050816,
        #0f172a,
        #1e293b,
        #0088ff
    );

    background-size:400% 400%;
    animation:bgMove 12s ease infinite;
}

@keyframes bgMove{
    0%{background-position:0% 50%;}
    50%{background-position:100% 50%;}
    100%{background-position:0% 50%;}
}

#particles{
    position:fixed;
    inset:0;
    z-index:-1;
}

header{
    text-align:center;
    padding:40px 20px;
}

header h1{
    font-size:4rem;
    background:linear-gradient(90deg,#00ffff,#00ff88);
    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;
    animation:floatTitle 3s ease-in-out infinite;
}

header p{
    margin-top:10px;
    opacity:.8;
}

@keyframes floatTitle{
    0%,100%{
        transform:translateY(0);
    }
    50%{
        transform:translateY(-10px);
    }
}

.running-line{
    width:100%;
    height:4px;
    background:linear-gradient(
        90deg,
        transparent,
        cyan,
        transparent
    );
    background-size:200% 100%;
    animation:runLine 2s linear infinite;
}

@keyframes runLine{
    from{
        background-position:-200% 0;
    }
    to{
        background-position:200% 0;
    }
}

.search-box{
    display:flex;
    justify-content:center;
    padding:25px;
}

.search-box input{
    width:350px;
    max-width:90%;
    padding:15px;
    border:none;
    outline:none;
    border-radius:15px;
    font-size:16px;
}

.container{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
    gap:25px;
    padding:30px;
}

.card{
    background:rgba(255,255,255,0.07);
    backdrop-filter:blur(10px);
    border-radius:20px;
    overflow:hidden;
    cursor:pointer;
    transition:0.3s;
    animation:cardFloat 4s ease-in-out infinite;
}

@keyframes cardFloat{
    0%,100%{
        transform:translateY(0);
    }
    50%{
        transform:translateY(-10px);
    }
}

.card:hover{
    box-shadow:0 15px 30px rgba(0,255,255,.25);
}

.card img{
    width:100%;
    height:220px;
    object-fit:cover;
}

.info{
    padding:20px;
}

.price{
    color:#00ff88;
    font-size:22px;
    font-weight:bold;
    margin:10px 0;
    animation:pulse 1.5s infinite;
}

@keyframes pulse{
    0%{
        text-shadow:0 0 5px #00ff88;
    }
    50%{
        text-shadow:
        0 0 20px #00ff88,
        0 0 40px #00ff88;
    }
    100%{
        text-shadow:0 0 5px #00ff88;
    }
}

.modal{
    position:fixed;
    inset:0;
    display:none;
    justify-content:center;
    align-items:center;
    background:rgba(0,0,0,.85);
}

.modal-content{
    width:90%;
    max-width:650px;
    background:#111827;
    padding:25px;
    border-radius:20px;
    transform:scale(.3);
    opacity:0;
}

.modal-content img{
    width:100%;
    border-radius:15px;
    margin:15px 0;
}

.close{
    float:right;
    font-size:30px;
    cursor:pointer;
    color:#ff5555;
}

.wheel{
    position:fixed;
    right:20px;
    bottom:20px;
    font-size:60px;
    animation:spinWheel 5s linear infinite;
}

@keyframes spinWheel{
    from{
        transform:rotate(0deg);
    }
    to{
        transform:rotate(360deg);
    }
}
</style>
</head>
<body>

<canvas id="particles"></canvas>

<header>
    <h1>🏍 Bike Info</h1>
    <p>Explore Bike Specifications & Performance</p>
</header>

<div class="running-line"></div>

<div class="search-box">
    <input id="search" placeholder="Search bike...">
</div>

<div class="container" id="container"></div>

<div class="modal" id="modal">
    <div class="modal-content" id="modalContent">
        <span class="close">✖</span>
        <div id="details"></div>
    </div>
</div>

<div class="wheel">⚙️</div>

<script>

const bikes = [
{
name:"Yamaha R15 V4",
price:"₹1.85 Lakh",
engine:"155cc",
speed:"155 km/h",
img:"https://images.unsplash.com/photo-1558981806-ec527fa84c39?w=1200"
},
{
name:"KTM RC 390",
price:"₹3.18 Lakh",
engine:"373cc",
speed:"170 km/h",
img:"https://images.unsplash.com/photo-1609630875171-b1321377ee65?w=1200"
},
{
name:"Ninja ZX-6R",
price:"₹11 Lakh",
engine:"636cc",
speed:"250 km/h",
img:"https://images.unsplash.com/photo-1558981403-c5f9899a28bc?w=1200"
},
{
name:"Royal Enfield GT 650",
price:"₹3.5 Lakh",
engine:"648cc",
speed:"170 km/h",
img:"https://images.unsplash.com/photo-1517846693594-1567da72af75?w=1200"
}
];

const container=document.getElementById("container");

function render(list){

container.innerHTML="";

list.forEach((bike,index)=>{

const card=document.createElement("div");
card.className="card";

card.innerHTML=`
<img src="${bike.img}">
<div class="info">
<h2>${bike.name}</h2>
<div class="price">${bike.price}</div>
<p>Engine: ${bike.engine}</p>
<p>Top Speed: ${bike.speed}</p>
</div>
`;

card.addEventListener("mouseenter",()=>{
gsap.to(card,{
y:-20,
rotationY:8,
duration:.4
});
});

card.addEventListener("mouseleave",()=>{
gsap.to(card,{
y:0,
rotationY:0,
duration:.4
});
});

card.onclick=()=>showBike(bike);

container.appendChild(card);

gsap.from(card,{
opacity:0,
y:100,
duration:1,
delay:index*0.15
});
});

}

function showBike(bike){

document.getElementById("details").innerHTML=`
<h1>${bike.name}</h1>
<img src="${bike.img}">
<h2>${bike.price}</h2>
<p><strong>Engine:</strong> ${bike.engine}</p>
<p><strong>Top Speed:</strong> ${bike.speed}</p>
<p style="margin-top:15px">
A premium performance motorcycle with excellent styling and power.
</p>
`;

document.getElementById("modal").style.display="flex";

gsap.to("#modalContent",{
scale:1,
opacity:1,
duration:.5,
ease:"back.out(1.7)"
});

}

document.querySelector(".close").onclick=()=>{

gsap.to("#modalContent",{
scale:.3,
opacity:0,
duration:.3,
onComplete:()=>{
document.getElementById("modal").style.display="none";
}
});

};

document.getElementById("search").addEventListener("input",(e)=>{

const value=e.target.value.toLowerCase();

const filtered=bikes.filter(b=>
b.name.toLowerCase().includes(value)
);

render(filtered);

});

render(bikes);

gsap.from("h1",{
y:-100,
opacity:0,
duration:1.5,
ease:"elastic.out"
});

gsap.from("input",{
scale:0,
duration:1,
delay:.5
});

const canvas=document.getElementById("particles");
const ctx=canvas.getContext("2d");

function resize(){
canvas.width=window.innerWidth;
canvas.height=window.innerHeight;
}
resize();
window.addEventListener("resize",resize);

const particles=[];

for(let i=0;i<120;i++){
particles.push({
x:Math.random()*canvas.width,
y:Math.random()*canvas.height,
r:Math.random()*3,
dx:(Math.random()-.5),
dy:(Math.random()-.5)
});
}

function animate(){

ctx.clearRect(0,0,canvas.width,canvas.height);

particles.forEach(p=>{

ctx.beginPath();
ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
ctx.fillStyle="#00ffff";
ctx.fill();

p.x+=p.dx;
p.y+=p.dy;

if(p.x<0||p.x>canvas.width)p.dx*=-1;
if(p.y<0||p.y>canvas.height)p.dy*=-1;

});

requestAnimationFrame(animate);
}

animate();

</script>

</body>
</html>