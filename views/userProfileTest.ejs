<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>BikeInfo</title>

<style>

/* RESET */
* { margin:0; padding:0; box-sizing:border-box; }

body {
  font-family: Arial, sans-serif;
  background:#fff;
  color:#000;
  padding-top:60px;
}

/* NAVBAR */
.navbar {
  position:fixed;
  top:0;
  width:100%;
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:12px 20px;
  background:rgba(34,34,34,0.92);
  color:white;
  z-index:1000;
}

.logo { font-weight:bold; }

/* SWITCH */
.switch {
  position:relative;
  width:50px;
  height:26px;
}
.switch input { display:none; }

.slider {
  position:absolute;
  inset:0;
  background:#ccc;
  border-radius:30px;
  cursor:pointer;
}

.slider:before {
  content:"";
  position:absolute;
  width:20px;
  height:20px;
  left:3px;
  top:3px;
  background:white;
  border-radius:50%;
  transition:0.3s;
}

input:checked + .slider {
  background:#4CAF50;
}

input:checked + .slider:before {
  transform:translateX(24px);
}

/* PROFILE */
.profile {
  width:60%;
  margin:20px auto;
  border:1px solid #ddd;
  border-radius:14px;
  padding:18px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  background:#fafafa;
}

.profile-left {
  display:flex;
  align-items:center;
  gap:15px;
}

.profile-image {
  width:70px;
  height:70px;
  border-radius:50%;
  overflow:hidden;
  border:2px solid #ddd;
}

.profile-image img {
  width:100%;
  height:100%;
  object-fit:cover;
}

.profile-extra {
  display:flex;
  flex-direction:column;
  gap:6px;
  text-align:right;
  font-size:13px;
}

/* EDIT BUTTON */
.edit-btn {
  padding:6px 12px;
  border:none;
  background:#4CAF50;
  color:white;
  border-radius:8px;
  cursor:pointer;
  margin-bottom:8px;
}

/* GARAGE */
.garage {
  width:60%;
  margin:20px auto;
  border:1px solid #ddd;
  border-radius:14px;
  padding:18px;
  background:#fafafa;
}

.garage-top {
  display:flex;
  justify-content:space-between;
  align-items:center;
}

.garage-title {
  font-size:20px;
  font-weight:bold;
}

.add-btn {
  background:#4CAF50;
  color:white;
  border:none;
  padding:8px 12px;
  border-radius:8px;
}

/* GRID */
.bike-grid {
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:12px;
  margin-top:12px;
}

.bike-card {
  border:1px solid #ddd;
  border-radius:10px;
  overflow:hidden;
  background:#fff;
}

.bike-card img {
  width:100%;
  height:90px;
  object-fit:cover;
}

.bike-info {
  padding:8px;
}

.bike-name { font-size:13px; font-weight:bold; }
.bike-type { font-size:11px; color:#666; }

/* ================= PROFILE MODAL ================= */
.modal {
  position:fixed;
  inset:0;
  background:rgba(0,0,0,0.6);
  display:none;
  justify-content:center;
  align-items:center;
  z-index:1000;
}

.modal-box {
  width:340px;
  background:white;
  border-radius:16px;
  padding:20px;
}

.modal-box input {
  width:100%;
  padding:10px;
  margin:7px 0;
  border:1px solid #ddd;
  border-radius:10px;
}

.modal-box button {
  width:100%;
  padding:10px;
  background:#4CAF50;
  color:white;
  border:none;
  border-radius:10px;
}

/* ================= CROPPER ================= */
.cropper {
  position:fixed;
  inset:0;
  background:rgba(0,0,0,0.85);
  display:none;
  justify-content:center;
  align-items:center;
  z-index:2000;
  flex-direction:column;
}

.crop-circle {
  width:260px;
  height:260px;
  border-radius:50%;
  overflow:hidden;
  border:3px solid white;
  position:relative;
  background:#111;
}

.crop-img {
  position:absolute;
  width:400px;
  top:0;
  left:0;
  cursor:grab;
  user-select:none;
}

.zoom-control {
  margin-top:15px;
  width:200px;
}

.crop-actions {
  margin-top:15px;
  display:flex;
  gap:10px;
}

.crop-actions button {
  padding:8px 12px;
  border:none;
  border-radius:8px;
  cursor:pointer;
}

.save-btn { background:#4CAF50; color:white; }
.cancel-btn { background:#999; color:white; }

.profileModule_container {
  width: 60%;
  margin: 30px auto;
  background: #fff;
  border: 1px solid #ddd;
  border-radius: 12px;
  overflow: hidden;
  font-family: Arial;
}

.profileModule_tabHeader {
  display: flex;
  border-bottom: 1px solid #eee;
}

.profileModule_tabHeader button {
  flex: 1;
  padding: 12px;
  border: none;
  background: none;
  cursor: pointer;
}

.profileModule_tabHeader .active {
  border-bottom: 2px solid black;
  font-weight: bold;
}

.profileModule_hidden {
  display: none !important;
}

/* TOP BAR */
.profileModule_topBar {
  display: flex;
  justify-content: flex-end;
  padding: 10px;
}

.profileModule_addBtn {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  border: none;
  background: black;
  color: white;
  font-size: 22px;
  cursor: pointer;
}

/* POSTS */
.profileModule_postGrid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  padding: 10px;
}

.profileModule_postCard {
  position: relative;
  border-radius: 10px;
  overflow: hidden;
}

.profileModule_postCard img {
  width: 100%;
  height: 180px;
  object-fit: cover;
}

.profileModule_overlay {
  position: absolute;
  bottom: 0;
  width: 100%;
  background: rgba(0,0,0,0.5);
  color: white;
  padding: 8px;
}

/* REVIEWS */
.profileModule_reviewGrid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
  padding: 10px;
}

.profileModule_reviewCard {
  border: 1px solid #ddd;
  border-radius: 10px;
  overflow: hidden;
}

.profileModule_reviewCard img {
  width: 100%;
  height: 160px;
  object-fit: cover;
}

.profileModule_reviewBody {
  padding: 10px;
}

/* MODAL */
.profileModule_modalBackdrop {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
  display: flex;
  justify-content: center;
  align-items: center;
}

.profileModule_modal {
  background: white;
  padding: 20px;
  width: 320px;
  border-radius: 10px;
}

.profileModule_modal input,
.profileModule_modal textarea {
  width: 100%;
  margin-bottom: 10px;
  padding: 8px;
}

</style>
</head>

<body>

<!-- NAVBAR -->
<div class="navbar">
  <div class="logo">BikeInfo</div>
  <label class="switch">
    <input type="checkbox" id="darkToggle">
    <span class="slider"></span>
  </label>
</div>

<!-- PROFILE -->
<div class="profile">

  <div class="profile-left">
    <div class="profile-image">
      <img id="profileImg" src="https://i.pravatar.cc/300?img=12">
    </div>

    <div>
      <h2 id="fullName">Rahul Sharma</h2>
      <p>@riderx</p>
      <button class="edit-btn" onclick="openModal()">Edit Profile</button>
    </div>
  </div>

  <div class="profile-extra">
    <div id="age">🎂 Age: 24</div>
    <div id="city">📍 City: Pune</div>
    <div id="email">📧 Email: rahul@gmail.com</div>
  </div>

</div>

<!-- GARAGE -->
<div class="garage">
  <div class="garage-top">
    <div class="garage-title">My Garage</div>
    <button class="add-btn">+ Add Bike</button>
  </div>

  <div class="bike-grid" id="grid"></div>
</div>

<!-- PROFILE MODAL -->
<div class="modal" id="modal">
  <div class="modal-box">

    <input id="first" placeholder="First Name">
    <input id="last" placeholder="Last Name">
    <input id="ageInput" placeholder="Age">
    <input id="cityInput" placeholder="City">

    <input type="file" id="imgInput" accept="image/*" onchange="openCrop(event)">

    <button onclick="saveProfile()">Save</button>

  </div>
</div>

<!-- CROPPER -->
<div class="cropper" id="cropper">

  <div class="crop-circle">
    <img id="cropImg" class="crop-img">
  </div>

  <input type="range" min="1" max="2" step="0.01" value="1" class="zoom-control" id="zoom">

  <div class="crop-actions">
    <button class="cancel-btn" onclick="closeCrop()">Cancel</button>
    <button class="save-btn" onclick="applyCrop()">Crop & Save</button>
  </div>

</div>
<div class="profileModule_container">

  <!-- TABS -->
  <div class="profileModule_tabHeader">
    <button class="profileModule_tab active" data-tab="posts">Posts</button>
    <button class="profileModule_tab" data-tab="reviews">Bike Reviews</button>
  </div>

  <!-- POSTS -->
  <div id="profileModule_postsTab">

    <div class="profileModule_topBar">
      <button class="profileModule_addBtn" id="profileModule_addPostBtn">+</button>
    </div>

    <div id="profileModule_postGrid" class="profileModule_postGrid"></div>

  </div>

  <!-- REVIEWS -->
  <div id="profileModule_reviewsTab" class="profileModule_hidden">

    <div class="profileModule_topBar">
      <button class="profileModule_addBtn" id="profileModule_addReviewBtn">+</button>
    </div>

    <div id="profileModule_reviewGrid" class="profileModule_reviewGrid"></div>

  </div>

</div>

<!-- MODAL -->
<div id="profileModule_modal" class="profileModule_modalBackdrop profileModule_hidden">

  <div class="profileModule_modal">

    <h3 id="profileModule_modalTitle">Add</h3>

    <input
      type="text"
      id="profileModule_titleInput"
      placeholder="Title / Bike Name"
    >

    <input
      type="text"
      id="profileModule_locationInput"
      placeholder="Location (only for posts)"
    >

    <textarea
      id="profileModule_textInput"
      placeholder="Review Text (only for reviews)"
    ></textarea>

    <input
      type="file"
      id="profileModule_fileInput"
      accept="image/*"
    >

    <button id="profileModule_saveBtn">
      Save
    </button>

    <button id="profileModule_closeBtn">
      Cancel
    </button>

  </div>

</div>

<script>

let cropImg = document.getElementById("cropImg");
let cropper = document.getElementById("cropper");
let zoom = document.getElementById("zoom");

let posX = 0, posY = 0;
let scale = 1;
let dragging = false;
let startX = 0, startY = 0;

/* OPEN CROPPER */
function openCrop(e){
  let file = e.target.files[0];
  let reader = new FileReader();

  reader.onload = function(ev){
    cropImg.src = ev.target.result;
    cropper.style.display = "flex";

    posX = 0; posY = 0; scale = 1;
    zoom.value = 1;
    updateTransform();
  }

  reader.readAsDataURL(file);
}

/* DRAG */
cropImg.addEventListener("mousedown", (e)=>{
  dragging = true;
  startX = e.clientX;
  startY = e.clientY;
  cropImg.style.cursor="grabbing";
});

document.addEventListener("mousemove",(e)=>{
  if(!dragging) return;

  posX += e.clientX - startX;
  posY += e.clientY - startY;

  startX = e.clientX;
  startY = e.clientY;

  updateTransform();
});

document.addEventListener("mouseup",()=>{
  dragging=false;
  cropImg.style.cursor="grab";
});

/* ZOOM */
zoom.addEventListener("input",()=>{
  scale = zoom.value;
  updateTransform();
});

function updateTransform(){
  cropImg.style.transform =
    `translate(${posX}px,${posY}px) scale(${scale})`;
}

/* CLOSE */
function closeCrop(){
  cropper.style.display="none";
}

/* APPLY CROP */
function applyCrop(){

  let canvas = document.createElement("canvas");
  canvas.width = 200;
  canvas.height = 200;
  let ctx = canvas.getContext("2d");

  let img = new Image();
  img.src = cropImg.src;

  img.onload = function(){
    ctx.drawImage(img, 0, 0, 200, 200);
    document.getElementById("profileImg").src = canvas.toDataURL();
    closeCrop();
  }
}

/* SAVE PROFILE */
function saveProfile(){
  document.getElementById("fullName").innerText =
    document.getElementById("first").value +
    " " +
    document.getElementById("last").value;

  document.getElementById("age").innerText =
    "🎂 Age: " + document.getElementById("ageInput").value;

  document.getElementById("city").innerText =
    "📍 City: " + document.getElementById("cityInput").value;

  document.getElementById("modal").style.display="none";
}

/* BIKE DATA */
let bikes=[
  {name:"KTM Duke 390",type:"Street",img:"https://images.unsplash.com/photo-1558981806-ec527fa84c39"},
  {name:"Yamaha R15",type:"Sport",img:"https://images.unsplash.com/photo-1580310614729-ccd69652491d"},
  {name:"BMW GS",type:"Adventure",img:"https://images.unsplash.com/photo-1609630875171-b1321377ee65"},
  {name:"Ninja 400",type:"Sport",img:"https://images.unsplash.com/photo-1625047509168-a7026f36de04"}
];

function render(){
  let grid=document.getElementById("grid");
  grid.innerHTML="";
  bikes.forEach(b=>{
    grid.innerHTML+=`
      <div class="bike-card">
        <img src="${b.img}">
        <div class="bike-info">
          <div class="bike-name">${b.name}</div>
          <div class="bike-type">${b.type}</div>
        </div>
      </div>`;
  });
}
render();
/* =========================
   PROFILE MODULE DATA
========================= */

let profileModule_posts = [
  {
    id: 1,
    title: "Beach Ride",
    location: "Goa",
    image: "https://picsum.photos/400/400"
  }
];

let profileModule_reviews = [
  {
    id: 1,
    bike: "Yamaha R15",
    text: "Smooth ride and great mileage",
    image: "https://picsum.photos/401/400"
  }
];

let profileModule_mode = "post";
let profileModule_editId = null;
let profileModule_selectedImage = null;


/* =========================
   INIT
========================= */

profileModule_init();

function profileModule_init() {

  profileModule_renderPosts();
  profileModule_renderReviews();

  const addPostBtn =
    document.getElementById("profileModule_addPostBtn");

  const addReviewBtn =
    document.getElementById("profileModule_addReviewBtn");

  if (addPostBtn) {

    addPostBtn.addEventListener("click", () => {
      profileModule_openModal("post");
    });

  }

  if (addReviewBtn) {

    addReviewBtn.addEventListener("click", () => {
      profileModule_openModal("review");
    });

  }

  document.getElementById("profileModule_saveBtn")
    .addEventListener("click", profileModule_saveData);

  document.getElementById("profileModule_closeBtn")
    .addEventListener("click", profileModule_closeModal);

  document.getElementById("profileModule_fileInput")
    .addEventListener("change", (e) => {

      if (e.target.files[0]) {

        profileModule_selectedImage =
          URL.createObjectURL(e.target.files[0]);

      }

    });

  document.querySelectorAll(".profileModule_tab")
    .forEach(btn => {

      btn.addEventListener("click", () => {

        profileModule_switchTab(btn.dataset.tab);

      });

    });

}


/* =========================
   TAB SWITCH
========================= */

function profileModule_switchTab(tab) {

  document.getElementById("profileModule_postsTab")
    .classList.add("profileModule_hidden");

  document.getElementById("profileModule_reviewsTab")
    .classList.add("profileModule_hidden");

  document.querySelectorAll(".profileModule_tab")
    .forEach(btn => {
      btn.classList.remove("active");
    });

  if (tab === "posts") {

    document.getElementById("profileModule_postsTab")
      .classList.remove("profileModule_hidden");

    document.querySelector('[data-tab="posts"]')
      .classList.add("active");

  }

  else {

    document.getElementById("profileModule_reviewsTab")
      .classList.remove("profileModule_hidden");

    document.querySelector('[data-tab="reviews"]')
      .classList.add("active");

  }

}


/* =========================
   POSTS
========================= */

function profileModule_renderPosts() {

  const grid =
    document.getElementById("profileModule_postGrid");

  grid.innerHTML = "";

  profileModule_posts.forEach(p => {

    grid.innerHTML += `
      <div class="profileModule_postCard">

        <img src="${p.image}">

        <div class="profileModule_overlay">

          <b>${p.title}</b><br/>
          ${p.location}

        </div>

      </div>
    `;

  });

}


/* =========================
   REVIEWS
========================= */

function profileModule_renderReviews() {

  const grid =
    document.getElementById("profileModule_reviewGrid");

  grid.innerHTML = "";

  profileModule_reviews.forEach(r => {

    grid.innerHTML += `
      <div class="profileModule_reviewCard">

        <img src="${r.image}">

        <div class="profileModule_reviewBody">

          <b>${r.bike}</b>

          <p>${r.text}</p>

          <button
            onclick="profileModule_editReview(${r.id})">
            Edit
          </button>

          <button
            onclick="profileModule_deleteReview(${r.id})">
            Delete
          </button>

        </div>

      </div>
    `;

  });

}


/* =========================
   MODAL
========================= */

function profileModule_openModal(type, data = null) {

  profileModule_mode = type;

  profileModule_editId =
    data ? data.id : null;

  document.getElementById("profileModule_modal")
    .classList.remove("profileModule_hidden");

  document.getElementById("profileModule_titleInput")
    .value = data?.title || data?.bike || "";

  document.getElementById("profileModule_locationInput")
    .value = data?.location || "";

  document.getElementById("profileModule_textInput")
    .value = data?.text || "";

  profileModule_selectedImage =
    data?.image || null;

}


function profileModule_closeModal() {

  document.getElementById("profileModule_modal")
    .classList.add("profileModule_hidden");

}


/* =========================
   SAVE LOGIC
========================= */

function profileModule_saveData() {

  if (profileModule_mode === "post") {

    const title =
      document.getElementById("profileModule_titleInput").value;

    const location =
      document.getElementById("profileModule_locationInput").value;

    profileModule_posts.unshift({

      id: Date.now(),

      title,

      location,

      image:
        profileModule_selectedImage ||
        "https://picsum.photos/400/400"

    });

    profileModule_renderPosts();

  }

  else {

    const bike =
      document.getElementById("profileModule_titleInput").value;

    const text =
      document.getElementById("profileModule_textInput").value;

    if (profileModule_editId) {

      profileModule_reviews =
        profileModule_reviews.map(r =>

          r.id === profileModule_editId

            ? {
                ...r,
                bike,
                text,
                image: profileModule_selectedImage
              }

            : r

        );

    }

    else {

      profileModule_reviews.unshift({

        id: Date.now(),

        bike,

        text,

        image:
          profileModule_selectedImage ||
          "https://picsum.photos/401/400"

      });

    }

    profileModule_renderReviews();

  }

  profileModule_closeModal();

}


/* =========================
   REVIEW ACTIONS
========================= */

function profileModule_editReview(id) {

  const r =
    profileModule_reviews.find(x => x.id === id);

  profileModule_openModal("review", r);

}


function profileModule_deleteReview(id) {

  profileModule_reviews =
    profileModule_reviews.filter(r => r.id !== id);

  profileModule_renderReviews();

}

</script>

</body>
</html>