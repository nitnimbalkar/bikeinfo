<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>Profile Showcase - Horizontal Bikes</title>

<style>

/* =========================
   LIGHT THEME
========================= */

:root{

  --bg:#f5f6f8;
  --card:#ffffff;
  --text:#111111;
  --sub:#666666;
  --border:#d9dbe1;
  --accent:#4c8bf5;

}

/* RESET */

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{

  background:var(--bg);
  color:var(--text);
  font-family:Arial, sans-serif;
}

/* CONTAINER */

.container{

  max-width:1200px;
  margin:auto;
  padding:40px 20px;
}

/* PROFILE */

.profile-top{

  display:flex;
  gap:60px;
  align-items:center;

  padding-bottom:35px;
  border-bottom:1px solid var(--border);
}

.profile-image{

  width:150px;
  height:150px;

  border-radius:50%;
  overflow:hidden;

  border:3px solid var(--border);
}

.profile-image img{

  width:100%;
  height:100%;
  object-fit:cover;
}

.username{

  font-size:30px;
  font-weight:700;
}

.meta{

  margin-top:10px;
  color:var(--sub);
  font-size:14px;
}

.edit-btn{

  margin-top:15px;

  padding:10px 16px;

  border:none;
  border-radius:10px;

  background:#eee;
  color:var(--text);

  cursor:pointer;

  transition:.2s;
}

.edit-btn:hover{

  background:var(--accent);
  color:#fff;
  transform:translateY(-2px);
}

/* =========================
   SHOWCASE (HORIZONTAL SCROLL)
========================= */

.showcase{

  width:100%;
  margin-top:50px;
}

.showcase-title{

  font-size:22px;
  font-weight:700;
  margin-bottom:20px;
}

/* HORIZONTAL SCROLL ROW */

.bike-grid{

  display:flex;

  gap:15px;

  overflow-x:auto;

  padding-bottom:10px;

  scroll-behavior:smooth;
}

/* hide scrollbar (optional clean UI) */

.bike-grid::-webkit-scrollbar{
  height:8px;
}

.bike-grid::-webkit-scrollbar-thumb{
  background:#ccc;
  border-radius:10px;
}

/* CARD */

.bike-card{

  min-width:220px;

  background:var(--card);

  border:1px solid var(--border);

  border-radius:14px;

  overflow:hidden;

  transition:.25s;

  flex-shrink:0;
}

.bike-card:hover{

  transform:translateY(-6px);
  box-shadow:0 12px 25px rgba(0,0,0,.08);
  border-color:rgba(76,139,245,.4);
}

/* IMAGE */

.bike-card img{

  width:100%;
  height:140px;

  object-fit:cover;
}

/* INFO */

.bike-info{

  padding:12px;
}

.bike-name{

  font-size:16px;
  font-weight:700;
  margin-bottom:5px;
}

.bike-desc{

  font-size:12px;
  color:var(--sub);
  line-height:1.4;
}

/* RESPONSIVE */

@media(max-width:900px){

  .profile-top{
    flex-direction:column;
    align-items:flex-start;
  }

  .bike-card{
    min-width:200px;
  }
}

</style>
</head>

<body>

<div class="container">

  <!-- PROFILE -->

  <div class="profile-top">

    <div class="profile-image">
      <img src="https://i.pravatar.cc/400">
    </div>

    <div>
      <div class="username">rider_john</div>

      <div class="meta">
        johndoe@gmail.com • Mumbai, India
      </div>

      <button class="edit-btn">Edit Profile</button>
    </div>

  </div>

  <!-- SHOWCASE -->

  <div class="showcase">

    <div class="showcase-title">Bike Showcase</div>

    <div class="bike-grid">

      <div class="bike-card">
        <img src="https://images.unsplash.com/photo-1558981806-ec527fa84c39?q=80&w=1200&auto=format&fit=crop">
        <div class="bike-info">
          <div class="bike-name">KTM Duke 390</div>
          <div class="bike-desc">Aggressive street naked machine.</div>
        </div>
      </div>

      <div class="bike-card">
        <img src="https://images.unsplash.com/photo-1609630875171-b1321377ee65?q=80&w=1200&auto=format&fit=crop">
        <div class="bike-info">
          <div class="bike-name">BMW G 310 GS</div>
          <div class="bike-desc">Adventure touring bike for all roads.</div>
        </div>
      </div>

      <div class="bike-card">
        <img src="https://images.unsplash.com/photo-1580310614729-ccd69652491d?q=80&w=1200&auto=format&fit=crop">
        <div class="bike-info">
          <div class="bike-name">Yamaha R15 V4</div>
          <div class="bike-desc">Lightweight supersport machine.</div>
        </div>
      </div>

      <div class="bike-card">
        <img src="https://images.unsplash.com/photo-1625047509168-a7026f36de04?q=80&w=1200&auto=format&fit=crop">
        <div class="bike-info">
          <div class="bike-name">Kawasaki Ninja 400</div>
          <div class="bike-desc">Balanced sport performance machine.</div>
        </div>
      </div>

      <div class="bike-card">
        <img src="https://images.unsplash.com/photo-1606220838315-056192d5e927?q=80&w=1200&auto=format&fit=crop">
        <div class="bike-info">
          <div class="bike-name">Royal Enfield GT 650</div>
          <div class="bike-desc">Classic twin-cylinder cruiser.</div>
        </div>
      </div>

      <div class="bike-card">
        <img src="https://images.unsplash.com/photo-1605559424843-9e5c0b0a6b8d?q=80&w=1200&auto=format&fit=crop">
        <div class="bike-info">
          <div class="bike-name">Honda CBR 650R</div>
          <div class="bike-desc">Inline-4 sport touring machine.</div>
        </div>
      </div>

    </div>

  </div>

</div>

</body>
</html>