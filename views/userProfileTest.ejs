<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>Steam Bike Garage</title>

<style>

:root{
  --bg:#f5f6f8;
  --card:#ffffff;
  --text:#111;
  --sub:#666;
  --border:#d9dbe1;
  --accent:#4c8bf5;
}

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  background:var(--bg);
  font-family:Arial, sans-serif;
  color:var(--text);
}

.container{
  max-width:1200px;
  margin:auto;
  padding:40px 20px;
}

/* PROFILE */

.profile-top{
  display:flex;
  gap:40px;
  align-items:center;
  border-bottom:1px solid var(--border);
  padding-bottom:25px;
}

.profile-image{
  width:130px;
  height:130px;
  border-radius:50%;
  overflow:hidden;
  border:3px solid var(--border);
}

.profile-image img{
  width:100%;
  height:100%;
  object-fit:cover;
}

.username{
  font-size:28px;
  font-weight:700;
}

.meta{
  color:var(--sub);
  margin-top:6px;
  font-size:14px;
}

/* SECTION */

.showcase{
  margin-top:40px;
}

.garage-title{
  font-size:22px;
  font-weight:700;
  margin-bottom:15px;
}

/* BIKE GRID */

.bike-grid{
  display:flex;
  gap:15px;
  overflow-x:auto;
  padding-bottom:10px;
}

/* BIKE CARD */

.bike-card{
  width:220px;
  height:300px;
  flex-shrink:0;

  background:#fff;
  border:1px solid var(--border);
  border-radius:14px;
  overflow:hidden;

  cursor:pointer;

  display:flex;
  flex-direction:column;

  transition:.25s;
}

.bike-card:hover{
  transform:translateY(-6px);
}

.bike-card img{
  width:100%;
  height:170px;
  object-fit:cover;
}

.bike-info{
  padding:12px;
}

.bike-name{
  font-weight:700;
  font-size:15px;
}

.bike-desc{
  margin-top:8px;
  color:var(--sub);
  font-size:13px;
}

/* ADD TILE */

.add-tile{
  width:220px;
  height:300px;
  flex-shrink:0;

  border:2px dashed #bbb;
  border-radius:14px;

  display:flex;
  align-items:center;
  justify-content:center;

  cursor:pointer;

  background:#fafafa;

  transition:.25s;
}

.add-tile:hover{
  border-color:var(--accent);
  background:#eef5ff;
}

.add-plus{
  font-size:45px;
  color:#888;
}

/* MEDIA SECTION */

.media-section{
  margin-top:60px;
}

.media-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:12px;
}

.media-post{
  position:relative;
  overflow:hidden;
  border-radius:14px;
  aspect-ratio:1/1;
  cursor:pointer;
  background:#ddd;
}

.media-post img{
  width:100%;
  height:100%;
  object-fit:cover;
  transition:.3s;
}

.media-post:hover img{
  transform:scale(1.05);
  opacity:.9;
}

/* MODAL */

.modal,
.inspect{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.65);

  display:none;
  justify-content:center;
  align-items:center;

  z-index:1000;
}

/* MODAL BOX */

.modal-box{
  width:360px;
  background:#fff;
  padding:20px;
  border-radius:14px;
}

.modal-box input,
.modal-box textarea{
  width:100%;
  padding:12px;
  margin-bottom:12px;
  border-radius:8px;
  border:1px solid #ddd;
  font-size:14px;
}

.modal-box textarea{
  min-height:90px;
  resize:none;
}

.save{
  width:100%;
  padding:12px;
  border:none;
  border-radius:8px;
  background:var(--accent);
  color:#fff;
  cursor:pointer;
  font-size:15px;
}

/* INSPECT */

.inspect-box{
  width:430px;
  background:#fff;
  border-radius:14px;
  overflow:hidden;
}

.inspect-box img{
  width:100%;
  height:240px;
  object-fit:cover;
}

.inspect-content{
  padding:16px;
}

.inspect-title{
  font-size:20px;
  font-weight:700;
}

.inspect-desc{
  margin-top:8px;
  color:var(--sub);
  font-size:14px;
}

.actions{
  display:flex;
  justify-content:space-between;
  margin-top:18px;
}

.btn{
  border:none;
  padding:10px 16px;
  border-radius:8px;
  cursor:pointer;
  font-size:14px;
}

.edit{
  background:#e5e7eb;
}

.del{
  background:#ef4444;
  color:#fff;
}

/* MOBILE */

@media(max-width:700px){

  .profile-top{
    flex-direction:column;
    text-align:center;
  }

  .media-grid{
    grid-template-columns:repeat(2,1fr);
  }

}

</style>
</head>

<body>

<div class="container">

  <!-- PROFILE -->

  <div class="profile-top">

    <div class="profile-image">
      <img src="https://i.pravatar.cc/400?img=12">
    </div>

    <div>
      <div class="username">Rider_X</div>
      <div class="meta">Mumbai • Steam Garage System</div>
    </div>

  </div>

  <!-- GARAGE -->

  <div class="showcase">

    <div class="garage-title">Bike Garage</div>

    <div class="bike-grid" id="grid"></div>

  </div>

  <!-- MEDIA -->

  <div class="media-section">

    <div class="garage-title">Media</div>

    <div class="media-grid">

      <div class="media-post">
        <img src="https://images.unsplash.com/photo-1511919884226-fd3cad34687c">
      </div>

      <div class="media-post">
        <img src="https://images.unsplash.com/photo-1493238792000-8113da705763">
      </div>

      <div class="media-post">
        <img src="https://images.unsplash.com/photo-1503376780353-7e6692767b70">
      </div>

      <div class="media-post">
        <img src="https://images.unsplash.com/photo-1489824904134-891ab64532f1">
      </div>

      <div class="media-post">
        <img src="https://images.unsplash.com/photo-1544636331-e26879cd4d9b">
      </div>

      <div class="media-post">
        <img src="https://images.unsplash.com/photo-1502877338535-766e1452684a">
      </div>

    </div>

  </div>

</div>

<!-- ADD / EDIT MODAL -->

<div class="modal" id="modal">

  <div class="modal-box">

    <input id="name" placeholder="Bike Name">

    <input id="img" placeholder="Image URL">

    <textarea id="desc" placeholder="Description"></textarea>

    <button class="save" onclick="saveBike()">SAVE</button>

  </div>

</div>

<!-- INSPECT -->

<div class="inspect" id="inspect" onclick="closeInspect(event)">

  <div class="inspect-box">

    <img id="iimg">

    <div class="inspect-content">

      <div class="inspect-title" id="ititle"></div>

      <div class="inspect-desc" id="idesc"></div>

      <div class="actions">

        <button class="btn edit" onclick="editBike()">Edit</button>

        <button class="btn del" onclick="deleteBike()">Delete</button>

      </div>

    </div>

  </div>

</div>

<script>

/* ELEMENTS */

const modal = document.getElementById("modal");
const inspect = document.getElementById("inspect");

const nameInput = document.getElementById("name");
const imgInput = document.getElementById("img");
const descInput = document.getElementById("desc");

const grid = document.getElementById("grid");

const iimg = document.getElementById("iimg");
const ititle = document.getElementById("ititle");
const idesc = document.getElementById("idesc");

/* DATA */

let bikes = JSON.parse(localStorage.getItem("bikes")) || [

  {
    name:"KTM Duke 390",
    img:"https://images.unsplash.com/photo-1558981806-ec527fa84c39",
    desc:"Street performance beast"
  },

  {
    name:"BMW G 310 GS",
    img:"https://images.unsplash.com/photo-1609630875171-b1321377ee65",
    desc:"Adventure touring machine"
  },

  {
    name:"Yamaha R15 V4",
    img:"https://images.unsplash.com/photo-1580310614729-ccd69652491d",
    desc:"Light supersport"
  },

  {
    name:"Ninja 400",
    img:"https://images.unsplash.com/photo-1625047509168-a7026f36de04",
    desc:"Balanced sport bike"
  },

  {
    name:"GT 650",
    img:"https://images.unsplash.com/photo-1606220838315-056192d5e927",
    desc:"Classic cruiser"
  }

];

let currentIndex = null;

/* STORAGE */

function saveStorage(){
  localStorage.setItem("bikes", JSON.stringify(bikes));
}

/* RESET */

function resetForm(){

  nameInput.value = "";
  imgInput.value = "";
  descInput.value = "";
}

/* RENDER */

function render(){

  grid.innerHTML = "";

  bikes.forEach((bike,index)=>{

    const card = document.createElement("div");

    card.className = "bike-card";

    card.innerHTML = `
      <img src="${bike.img}">
      <div class="bike-info">
        <div class="bike-name">${bike.name}</div>
        <div class="bike-desc">${bike.desc}</div>
      </div>
    `;

    card.onclick = () => openInspect(index);

    grid.appendChild(card);

  });

  /* ADD TILE */

  const addTile = document.createElement("div");

  addTile.className = "add-tile";

  addTile.innerHTML = `<div class="add-plus">+</div>`;

  addTile.onclick = () => {

    currentIndex = null;

    resetForm();

    modal.style.display = "flex";
  };

  grid.appendChild(addTile);
}

/* SAVE */

function saveBike(){

  const bikeData = {

    name:nameInput.value,
    img:imgInput.value,
    desc:descInput.value
  };

  if(currentIndex !== null){

    bikes[currentIndex] = bikeData;

  }else{

    bikes.push(bikeData);
  }

  saveStorage();

  render();

  modal.style.display = "none";

  resetForm();
}

/* OPEN INSPECT */

function openInspect(index){

  currentIndex = index;

  const bike = bikes[index];

  ititle.innerText = bike.name;
  idesc.innerText = bike.desc;
  iimg.src = bike.img;

  inspect.style.display = "flex";
}

/* CLOSE INSPECT */

function closeInspect(e){

  if(e.target === inspect){

    inspect.style.display = "none";
  }
}

/* DELETE */

function deleteBike(){

  bikes.splice(currentIndex,1);

  saveStorage();

  render();

  inspect.style.display = "none";
}

/* EDIT */

function editBike(){

  const bike = bikes[currentIndex];

  nameInput.value = bike.name;
  imgInput.value = bike.img;
  descInput.value = bike.desc;

  inspect.style.display = "none";

  modal.style.display = "flex";
}

/* CLOSE MODAL */

window.addEventListener("click",(e)=>{

  if(e.target === modal){

    modal.style.display = "none";
  }
});

/* START */

render();

</script>

</body>
</html>