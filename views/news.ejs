<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>Namespaced Updates Module</title>

<style>

/* =========================================================
   UFM = Updates Feature Module
   Fully namespaced to avoid page conflicts
========================================================= */

:root{
  --ufm-bg:#ffffff;
  --ufm-text:#111111;
  --ufm-border:#d8d8d8;
  --ufm-tab-bg:#f4f4f4;
  --ufm-active:#111111;
  --ufm-active-text:#ffffff;
}

html.dark{
  --ufm-bg:#0f0f0f;
  --ufm-text:#f5f5f5;
  --ufm-border:#343434;
  --ufm-tab-bg:#1b1b1b;
  --ufm-active:#ffffff;
  --ufm-active-text:#111111;
}

/* =========================================================
   ROOT MODULE
========================================================= */

.ufm-module-wrapper{
  display:flex;
  justify-content:center;
  padding:50px 20px;
  background:var(--ufm-bg);
  color:var(--ufm-text);
  font-family:Inter,sans-serif;
}

.ufm-module{
  width:60%;
  min-height:680px;
  border:1px solid var(--ufm-border);
  border-radius:22px;
  padding:26px;
  display:flex;
  flex-direction:column;
  overflow:hidden;
  background:var(--ufm-bg);
  isolation:isolate;
}

.ufm-heading{
  font-size:34px;
  font-weight:700;
  margin-bottom:20px;
}

/* =========================================================
   TABS
========================================================= */

.ufm-tabs{
  display:flex;
  gap:12px;
  margin-bottom:18px;
  flex-wrap:wrap;
}

.ufm-tab-btn{
  padding:10px 18px;
  border-radius:10px;
  border:1px solid var(--ufm-border);
  background:var(--ufm-tab-bg);
  color:var(--ufm-text);
  cursor:pointer;
  font-weight:600;
  transition:.2s ease;
}

.ufm-tab-btn:hover{
  opacity:.9;
}

.ufm-tab-btn.ufm-active{
  background:var(--ufm-active);
  color:var(--ufm-active-text);
}

/* =========================================================
   TAB CONTENT
========================================================= */

.ufm-tab-content{
  display:none;
  flex:1;
  overflow:hidden;
  animation:ufmFade .3s ease;
}

.ufm-tab-content.ufm-active{
  display:block;
}

@keyframes ufmFade{
  from{
    opacity:0;
    transform:translateY(8px);
  }
  to{
    opacity:1;
    transform:translateY(0);
  }
}

/* =========================================================
   CARDS
========================================================= */

.ufm-cards{
  display:grid;
  grid-auto-flow:column;
  grid-auto-columns:minmax(280px,1fr);
  gap:20px;
  overflow-x:auto;
  overflow-y:hidden;
  padding-bottom:12px;
  scroll-behavior:smooth;
  height:100%;
}

.ufm-cards::-webkit-scrollbar{
  height:8px;
}

.ufm-cards::-webkit-scrollbar-thumb{
  background:#8884;
  border-radius:10px;
}

/* =========================================================
   CARD
========================================================= */

.ufm-card{
  border:1px solid var(--ufm-border);
  border-radius:18px;
  overflow:hidden;
  min-height:460px;
  display:flex;
  flex-direction:column;
  cursor:pointer;
  transition:
    transform .25s ease,
    box-shadow .25s ease;
  background:var(--ufm-bg);
  outline:none;
}

.ufm-card:hover,
.ufm-card:focus{
  transform:translateY(-6px);
  box-shadow:0 12px 28px rgba(0,0,0,0.12);
}

.ufm-card-image{
  width:100%;
  height:210px;
  object-fit:cover;
  border-bottom:1px solid var(--ufm-border);
}

.ufm-card-content{
  padding:20px;
  display:flex;
  flex-direction:column;
  flex:1;
}

.ufm-card-tag{
  font-size:12px;
  text-transform:uppercase;
  opacity:.7;
  margin-bottom:10px;
  font-weight:700;
}

.ufm-card-title{
  font-size:22px;
  font-weight:700;
  margin-bottom:10px;
}

.ufm-card-desc{
  font-size:15px;
  line-height:1.6;
  opacity:.82;
}

/* =========================================================
   MODAL
========================================================= */

.ufm-modal{
  position:fixed;
  inset:0;
  width:100vw;
  height:100vh;
  display:none;
  justify-content:center;
  align-items:center;
  background:rgba(0,0,0,0.6);
  z-index:999999;
}

.ufm-modal.ufm-active{
  display:flex;
}

.ufm-modal-box{
  width:min(70%,900px);
  max-height:85vh;
  overflow:auto;
  border-radius:18px;
  background:var(--ufm-bg);
  border:1px solid var(--ufm-border);
  position:relative;
  animation:ufmModalIn .28s ease;
}

@keyframes ufmModalIn{
  from{
    opacity:0;
    transform:scale(.92);
  }
  to{
    opacity:1;
    transform:scale(1);
  }
}

.ufm-close-btn{
  position:absolute;
  top:12px;
  right:16px;
  width:40px;
  height:40px;
  border-radius:50%;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:28px;
  cursor:pointer;
  z-index:10;
  color:var(--ufm-text);
  background:rgba(255,255,255,0.12);
  backdrop-filter:blur(4px);
}

.ufm-modal-img{
  width:100%;
  height:300px;
  object-fit:cover;
}

.ufm-modal-content{
  padding:24px;
  display:flex;
  flex-direction:column;
  gap:14px;
}

.ufm-modal-title{
  font-size:28px;
  font-weight:700;
}

.ufm-modal-text{
  font-size:16px;
  line-height:1.7;
  opacity:.85;
}

/* =========================================================
   VIDEO
========================================================= */

.ufm-video-container{
  width:100%;
  aspect-ratio:16/9;
  display:none;
}

.ufm-video-container iframe{
  width:100%;
  height:100%;
  border:none;
}

.ufm-modal-box.ufm-video-mode .ufm-modal-content,
.ufm-modal-box.ufm-video-mode .ufm-modal-img{
  display:none;
}

.ufm-modal-box.ufm-video-mode .ufm-video-container{
  display:block;
}

/* =========================================================
   RESPONSIVE
========================================================= */

@media(max-width:900px){

  .ufm-module-wrapper{
    padding:20px 14px;
  }

  .ufm-module{
    width:100%;
    padding:20px;
  }

  .ufm-heading{
    font-size:28px;
  }

  .ufm-cards{
    grid-auto-columns:85%;
  }

  .ufm-modal-box{
    width:92%;
  }

  .ufm-modal-img{
    height:220px;
  }

}

</style>
</head>

<body>

<div class="ufm-module-wrapper">

  <div class="ufm-module">

    <div class="ufm-heading">
      Latest Updates
    </div>

    <!-- TABS -->

    <div class="ufm-tabs">

      <button class="ufm-tab-btn ufm-active" data-ufm-tab="news">
        News
      </button>

      <button class="ufm-tab-btn" data-ufm-tab="reviews">
        Reviews
      </button>

      <button class="ufm-tab-btn" data-ufm-tab="videos">
        Videos
      </button>

    </div>

    <!-- NEWS -->

    <div class="ufm-tab-content ufm-active" id="ufm-news">

      <div class="ufm-cards">

        <div
          class="ufm-card"
          tabindex="0"
          data-ufm-type="modal"
          data-ufm-title="Product Launch This Week"
          data-ufm-image="https://images.unsplash.com/photo-1495020689067-958852a7765e?q=80&w=600&auto=format&fit=crop"
          data-ufm-text="Complete breakdown of the latest product release and roadmap."
        >

          <img
            class="ufm-card-image"
            loading="lazy"
            src="https://images.unsplash.com/photo-1495020689067-958852a7765e?q=80&w=600&auto=format&fit=crop"
            alt="Launch">

          <div class="ufm-card-content">

            <div class="ufm-card-tag">
              News
            </div>

            <div class="ufm-card-title">
              Product Launch
            </div>

            <div class="ufm-card-desc">
              Latest release insights.
            </div>

          </div>

        </div>

      </div>

    </div>

    <!-- REVIEWS -->

    <div class="ufm-tab-content" id="ufm-reviews">

      <div class="ufm-cards">

        <div
          class="ufm-card"
          tabindex="0"
          data-ufm-type="modal"
          data-ufm-title="Performance Review"
          data-ufm-image="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?q=80&w=600&auto=format&fit=crop"
          data-ufm-text="Performance improvements analyzed by experts."
        >

          <img
            class="ufm-card-image"
            loading="lazy"
            src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?q=80&w=600&auto=format&fit=crop"
            alt="Review">

          <div class="ufm-card-content">

            <div class="ufm-card-tag">
              Review
            </div>

            <div class="ufm-card-title">
              Performance Boost
            </div>

            <div class="ufm-card-desc">
              Speed and UX improvements.
            </div>

          </div>

        </div>

      </div>

    </div>

    <!-- VIDEOS -->

    <div class="ufm-tab-content" id="ufm-videos">

      <div class="ufm-cards">

        <div
          class="ufm-card"
          tabindex="0"
          data-ufm-type="video"
          data-ufm-video="https://www.youtube.com/embed/dQw4w9WgXcQ"
        >

          <img
            class="ufm-card-image"
            loading="lazy"
            src="https://img.youtube.com/vi/dQw4w9WgXcQ/hqdefault.jpg"
            alt="Video">

          <div class="ufm-card-content">

            <div class="ufm-card-tag">
              Video
            </div>

            <div class="ufm-card-title">
              Product Walkthrough
            </div>

            <div class="ufm-card-desc">
              Complete feature overview.
            </div>

          </div>

        </div>

      </div>

    </div>

  </div>

</div>

<!-- =========================================================
     MODAL
========================================================= -->

<div class="ufm-modal" role="dialog" aria-modal="true">

  <div class="ufm-modal-box">

    <div class="ufm-close-btn">
      ×
    </div>

    <img class="ufm-modal-img" alt="Modal Image">

    <div class="ufm-video-container"></div>

    <div class="ufm-modal-content">

      <div class="ufm-modal-title"></div>

      <div class="ufm-modal-text"></div>

    </div>

  </div>

</div>

<script>

(() => {

  /* =========================================================
     MODULE ROOT
  ========================================================= */

  const ufmModule = document.querySelector(".ufm-module");

  if(!ufmModule) return;

  /* =========================================================
     TABS
  ========================================================= */

  const ufmTabs =
    ufmModule.querySelectorAll(".ufm-tab-btn");

  const ufmContents =
    ufmModule.querySelectorAll(".ufm-tab-content");

  ufmTabs.forEach(tab => {

    tab.addEventListener("click", () => {

      ufmTabs.forEach(btn =>
        btn.classList.remove("ufm-active")
      );

      ufmContents.forEach(content =>
        content.classList.remove("ufm-active")
      );

      tab.classList.add("ufm-active");

      const target =
        document.getElementById(
          `ufm-${tab.dataset.ufmTab}`
        );

      if(target){
        target.classList.add("ufm-active");
      }

    });

  });

  /* =========================================================
     MODAL ELEMENTS
  ========================================================= */

  const ufmModal =
    document.querySelector(".ufm-modal");

  const ufmModalBox =
    ufmModal.querySelector(".ufm-modal-box");

  const ufmModalImg =
    ufmModal.querySelector(".ufm-modal-img");

  const ufmModalTitle =
    ufmModal.querySelector(".ufm-modal-title");

  const ufmModalText =
    ufmModal.querySelector(".ufm-modal-text");

  const ufmVideoContainer =
    ufmModal.querySelector(".ufm-video-container");

  const ufmCloseBtn =
    ufmModal.querySelector(".ufm-close-btn");

  /* =========================================================
     OPEN CONTENT MODAL
  ========================================================= */

  function ufmOpenModal(title,image,text){

    ufmModal.classList.add("ufm-active");

    ufmModalBox.classList.remove("ufm-video-mode");

    ufmModalImg.style.display = "block";

    ufmModalImg.src = image;

    ufmModalTitle.textContent = title;

    ufmModalText.textContent = text;

    document.body.classList.add("ufm-body-lock");

  }

  /* =========================================================
     OPEN VIDEO MODAL
  ========================================================= */

  function ufmOpenVideoModal(videoUrl){

    ufmModal.classList.add("ufm-active");

    ufmModalBox.classList.add("ufm-video-mode");

    ufmVideoContainer.innerHTML = "";

    const iframe =
      document.createElement("iframe");

    iframe.src =
      `${videoUrl}?autoplay=1&mute=1&rel=0`;

    iframe.allow =
      "autoplay; encrypted-media";

    iframe.allowFullscreen = true;

    ufmVideoContainer.appendChild(iframe);

    document.body.classList.add("ufm-body-lock");

  }

  /* =========================================================
     CLOSE MODAL
  ========================================================= */

  function ufmCloseModal(){

    ufmModal.classList.remove("ufm-active");

    ufmModalBox.classList.remove("ufm-video-mode");

    ufmVideoContainer.innerHTML = "";

    document.body.classList.remove("ufm-body-lock");

  }

  /* =========================================================
     CARD EVENTS
  ========================================================= */

  const ufmCards =
    ufmModule.querySelectorAll(".ufm-card");

  ufmCards.forEach(card => {

    const ufmTriggerCard = () => {

      const type =
        card.dataset.ufmType;

      if(type === "modal"){

        ufmOpenModal(
          card.dataset.ufmTitle,
          card.dataset.ufmImage,
          card.dataset.ufmText
        );

      }

      if(type === "video"){

        ufmOpenVideoModal(
          card.dataset.ufmVideo
        );

      }

    };

    card.addEventListener(
      "click",
      ufmTriggerCard
    );

    card.addEventListener(
      "keydown",
      e => {

        if(
          e.key === "Enter" ||
          e.key === " "
        ){

          e.preventDefault();

          ufmTriggerCard();

        }

      }
    );

  });

  /* =========================================================
     CLOSE EVENTS
  ========================================================= */

  ufmCloseBtn.addEventListener(
    "click",
    ufmCloseModal
  );

  ufmModal.addEventListener(
    "click",
    e => {

      if(e.target === ufmModal){
        ufmCloseModal();
      }

    }
  );

  document.addEventListener(
    "keydown",
    e => {

      if(
        e.key === "Escape" &&
        ufmModal.classList.contains("ufm-active")
      ){

        ufmCloseModal();

      }

    }
  );

})();

</script>

</body>
</html>