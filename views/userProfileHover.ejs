<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Bike Review User Profile</title>

<style>
    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
        font-family: Arial, sans-serif;
    }

    body{
        background:#f3f4f6;
        display:flex;
        justify-content:center;
        align-items:center;
        min-height:100vh;
        padding:20px;
    }

    .profile-card{
        width:360px;
        background:white;
        border-radius:20px;
        overflow:hidden;
        box-shadow:0 10px 30px rgba(0,0,0,0.1);
        transition:0.3s;
    }

    .profile-card:hover{
        transform:translateY(-5px);
    }

    .cover{
        height:140px;
        background:url('https://images.unsplash.com/photo-1517846693594-1567da72af75?q=80&w=1200&auto=format&fit=crop') center/cover;
        position:relative;
    }

    .profile-img{
        width:110px;
        height:110px;
        border-radius:50%;
        border:5px solid white;
        position:absolute;
        bottom:-55px;
        left:50%;
        transform:translateX(-50%);
        object-fit:cover;
    }

    .content{
        padding:70px 25px 25px;
        text-align:center;
    }

    .name{
        font-size:26px;
        font-weight:bold;
        color:#111827;
    }

    .username{
        color:#6b7280;
        margin-top:5px;
        font-size:14px;
    }

    .bio{
        margin-top:18px;
        color:#4b5563;
        line-height:1.6;
        font-size:15px;
    }

    .stats{
        display:flex;
        justify-content:space-around;
        margin-top:25px;
        padding-top:20px;
        border-top:1px solid #e5e7eb;
    }

    .stat h3{
        color:#111827;
        font-size:22px;
    }

    .stat p{
        color:#6b7280;
        font-size:13px;
        margin-top:4px;
    }

    .fav-bike{
        background:#111827;
        color:white;
        margin-top:25px;
        padding:15px;
        border-radius:14px;
    }

    .fav-bike h4{
        margin-bottom:8px;
        font-size:16px;
    }

    .fav-bike p{
        font-size:14px;
        color:#d1d5db;
    }

    .buttons{
        margin-top:25px;
        display:flex;
        gap:12px;
    }

    .btn{
        flex:1;
        padding:12px;
        border:none;
        border-radius:10px;
        cursor:pointer;
        font-weight:bold;
        transition:0.3s;
    }

    .follow{
        background:#ef4444;
        color:white;
    }

    .follow:hover{
        background:#dc2626;
    }

    .message{
        background:#e5e7eb;
        color:#111827;
    }

    .message:hover{
        background:#d1d5db;
    }
</style>
</head>
<body>

<div class="profile-card">

    <div class="cover">
        <img 
        class="profile-img"
        src="https://randomuser.me/api/portraits/men/32.jpg" 
        alt="profile">
    </div>

    <div class="content">

        <div class="name">Rahul Biker</div>
        <div class="username">@ridewithrahul</div>

        <div class="bio">
            Passionate superbike reviewer 🏍️  
            Love touring, speed, and honest bike reviews.
        </div>

        <div class="stats">
            <div class="stat">
                <h3>128</h3>
                <p>Reviews</p>
            </div>

            <div class="stat">
                <h3>54K</h3>
                <p>Followers</p>
            </div>

            <div class="stat">
                <h3>220</h3>
                <p>Following</p>
            </div>
        </div>

        <div class="fav-bike">
            <h4>Favorite Bike</h4>
            <p>Kawasaki Ninja ZX-10R</p>
        </div>

        <div class="buttons">
            <button class="btn follow">Follow</button>
            <button class="btn message">Message</button>
        </div>

    </div>

</div>

</body>
</html>