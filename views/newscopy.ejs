<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>Latest Updates</title>

<style>

/* ================= news css start from here ================= */

:root{
  --bg:#ffffff;
  --text:#111111;
  --border:#d8d8d8;
  --tab-bg:#f4f4f4;
  --active:#111111;
  --active-text:#ffffff;
}

body.dark{
  --bg:#0f0f0f;
  --text:#f5f5f5;
  --border:#343434;
  --tab-bg:#1b1b1b;
  --active:#ffffff;
  --active-text:#111111;
}

/* ================= MODULE ================= */

.updates-module{
  width:60%;
  height:680px;
  border:1px solid var(--border);
  border-radius:22px;
  padding:26px;
  display:flex;
  flex-direction:column;
  overflow:hidden;
  background:var(--bg);
}

.heading{
  font-size:34px;
  font-weight:700;
  margin-bottom:20px;
}

/* ================= TABS ================= */

.tabs{
  display:flex;
  gap:12px;
  margin-bottom:18px;
  flex-wrap:wrap;
}

.tab-btn{
  padding:10px 18px;
  border-radius:10px;
  border:1px solid var(--border);
  background:var(--tab-bg);
  color:var(--text);
  cursor:pointer;
  font-weight:600;
  transition:.2s ease;
}

.tab-btn:hover{
  opacity:.9;
}

.tab-btn.active{
  background:var(--active);
  color:var(--active-text);
}

/* ================= CONTENT ================= */

.tab-content{
  display:none;
  flex:1;
  overflow:hidden;
  animation:fade .3s ease;
}

.tab-content.active{
  display:block;
}

@keyframes fade{
  from{
    opacity:0;
    transform:translateY(8px);
  }
  to{
    opacity:1;
    transform:translateY(0);
  }
}

/* ================= CARDS ================= */

.cards{
  display:grid;
  grid-auto-flow:column;
  grid-auto-columns:repeat(auto-fit,minmax(280px,1fr));
  gap:20px;
  overflow-x:auto;
  overflow-y:hidden;
  padding-bottom:12px;
  scroll-behavior:smooth;
  height:100%;
}

.cards::-webkit-scrollbar{
  height:8px;
}

.cards::-webkit-scrollbar-thumb{
  background:#8884;
  border-radius:10px;
}

.cards::-webkit-scrollbar-track{
  background:transparent;
}

/* ================= CARD ================= */

.card{
  border:1px solid var(--border);
  border-radius:18px;
  overflow:hidden;
  min-height:460px;
  display:flex;
  flex-direction:column;
  cursor:pointer;
  transition:
    transform .25s ease,
    box-shadow .25s ease;
  background:var(--bg);
  outline:none;
}

.card:hover,
.card:focus{
  transform:translateY(-6px);
  box-shadow:0 12px 28px rgba(0,0,0,0.12);
}

.card-image{
  width:100%;
  height:210px;
  object-fit:cover;
  border-bottom:1px solid var(--border);
}

.card-content{
  padding:20px;
  display:flex;
  flex-direction:column;
  flex:1;
}

.card-tag{
  font-size:12px;
  text-transform:uppercase;
  opacity:.7;
  margin-bottom:10px;
  font-weight:700;
}

.card-title{
  font-size:22px;
  font-weight:700;
  margin-bottom:10px;
}

.card-desc{
  font-size:15px;
  line-height:1.6;
  opacity:.82;
}

/* ================= MODAL ================= */

.modal{
  position:fixed;
  inset:0;
  display:none;
  justify-content:center;
  align-items:center;
  background:rgba(0,0,0,0.6);
  backdrop-filter:blur(6px);
  z-index:999;
}

.modal.active{
  display:flex;
}

.modal-box{
  width:70%;
  max-height:85vh;
  background:var(--bg);
  border:1px solid var(--border);
  border-radius:18px;
  overflow:auto;
  position:relative;
  animation:modalIn .28s ease;
}

@keyframes modalIn{
  from{
    opacity:0;
    transform:scale(.92);
  }
  to{
    opacity:1;
    transform:scale(1);
  }
}

.close-btn{
  position:absolute;
  top:12px;
  right:16px;
  font-size:28px;
  cursor:pointer;
  z-index:10;
  color:var(--text);
  background:rgba(255,255,255,0.12);
  width:40px;
  height:40px;
  border-radius:50%;
  display:flex;
  align-items:center;
  justify-content:center;
  backdrop-filter:blur(4px);
}

.modal-img{
  width:100%;
  height:300px;
  object-fit:cover;
}

.modal-content{
  padding:24px;
  display:flex;
  flex-direction:column;
  gap:14px;
}

.modal-title{
  font-size:28px;
  font-weight:700;
}

.modal-text{
  font-size:16px;
  line-height:1.7;
  opacity:.85;
}

/* ================= VIDEO MODAL ================= */

.video-modal{
  width:100%;
  aspect-ratio:16/9;
  display:none;
}

.video-modal iframe{
  width:100%;
  height:100%;
  border:none;
}

.modal-box.video-mode{
  width:70%;
}

.modal-box.video-mode .modal-content,
.modal-box.video-mode .modal-img{
  display:none;
}

.modal-box.video-mode .video-modal{
  display:block;
}

/* ================= RESPONSIVE ================= */

@media(max-width:900px){

  body{
    padding:20px 14px;
  }

  .updates-module{
    width:100%;
    height:auto;
    padding:20px;
  }

  .heading{
    font-size:28px;
  }

  .cards{
    grid-auto-columns:85%;
  }

  .modal-box{
    width:92%;
  }

  .modal-box.video-mode{
    width:95%;
  }

  .modal-img{
    height:220px;
  }

}

</style>
</head>

<body>

<div class="news-wrapper">
  <div class="updates-module">

  <div class="heading">Latest Updates</div>

  <!-- TABS -->
  <div class="tabs">
