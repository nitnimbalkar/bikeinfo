<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SuperBikeX</title>

<style>
:root{
    --primary:#ff4500;
    --dark:#0f0f0f;
    --card:#1b1b1b;
    --text:#ffffff;
}

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI',sans-serif;
}

body{
    background:var(--dark);
    color:var(--text);
}

/* HERO */

.hero{
    height:60vh;
    background:
    linear-gradient(rgba(0,0,0,.6),rgba(0,0,0,.7)),
    url("https://images.unsplash.com/photo-1558981806-ec527fa84c39?w=1600");
    background-size:cover;
    background-position:center;
    display:flex;
    align-items:center;
    justify-content:center;
    flex-direction:column;
    text-align:center;
}

.hero h1{
    font-size:4rem;
    color:white;
}

.hero p{
    font-size:1.2rem;
    margin-top:10px;
}

.search{
    margin-top:20px;
    width:500px;
    max-width:90%;
    padding:15px;
    border:none;
    border-radius:50px;
}

/* STATS */

.stats{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:20px;
    padding:30px;
}

.stat{
    background:var(--card);
    padding:25px;
    text-align:center;
    border-radius:15px;
}

.stat h2{
    color:var(--primary);
}

/* FILTERS */

.filters{
    display:flex;
    gap:15px;
    padding:20px;
    flex-wrap:wrap;
}

.filters select{
    padding:10px;
    border-radius:10px;
}

/* BIKES */

.grid{
    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(300px,1fr));
    gap:25px;
    padding:20px;
}

.card{
    background:var(--card);
    border-radius:20px;
    overflow:hidden;
    transition:.3s;
}

.card:hover{
    transform:translateY(-8px);
}

.card img{
    width:100%;
    height:220px;
    object-fit:cover;
}

.content{
    padding:20px;
}

.price{
    color:orange;
    font-size:1.2rem;
    margin:10px 0;
}

.specs{
    display:flex;
    justify-content:space-between;
    margin:15px 0;
}

.badge{
    background:#333;
    padding:5px 10px;
    border-radius:20px;
}

.actions{
    display:flex;
    gap:10px;
}

button{
    flex:1;
    padding:12px;
    border:none;
    border-radius:10px;
    cursor:pointer;
}

.compare{
    background:var(--primary);
    color:white;
}

.fav{
    background:#333;
    color:white;
}

/* COMPARE PANEL */

.compare-panel{
    position:fixed;
    bottom:0;
    left:0;
    width:100%;
    background:#111;
    border-top:2px solid var(--primary);
    padding:20px;
    display:none;
}

.compare-list{
    display:flex;
    gap:15px;
    margin-bottom:15px;
}

.compare-item{
    background:#222;
    padding:10px 15px;
    border-radius:10px;
}

.compare-btn{
    background:limegreen;
    color:white;
    padding:12px 20px;
}

/* TABLE */

table{
    width:100%;
    margin-top:30px;
    border-collapse:collapse;
}

th,td{
    padding:15px;
    border:1px solid #333;
}

th{
    background:#222;
}

@media(max-width:768px){
.hero h1{
font-size:2.2rem;
}
}
</style>
</head>
<body>

<section class="hero">
<h1>🏍 SuperBikeX</h1>
<p>Compare, Discover & Explore Superbikes</p>
<input class="search" id="search" placeholder="Search Ducati, BMW, Kawasaki...">
</section>

<section class="stats">
<div class="stat">
<h2>500+</h2>
<p>Bikes Listed</p>
</div>

<div class="stat">
<h2>120+</h2>
<p>Brands</p>
</div>

<div class="stat">
<h2>50K+</h2>
<p>User Reviews</p>
</div>

<div class="stat">
<h2>100+</h2>
<p>Comparisons Daily</p>
</div>
</section>

<div class="filters">
<select id="brandFilter">
<option value="">All Brands</option>
<option>Ducati</option>
<option>BMW</option>
<option>Kawasaki</option>
<option>Yamaha</option>
</select>

<select id="sortPrice">
<option value="">Sort Price</option>
<option value="low">Low to High</option>
<option value="high">High to Low</option>
</select>
</div>

<div class="grid" id="grid"></div>

<div class="compare-panel" id="panel">
<h3>Comparison Queue</h3>
<div class="compare-list" id="compareList"></div>
<button class="compare-btn" onclick="generateComparison()">
Compare Bikes
</button>
</div>

<div style="padding:20px">
<table id="comparisonTable"></table>
</div>

<script>

const bikes = [
{
name:"Ducati Panigale V4",
brand:"Ducati",
price:2800000,
power:"215 HP",
engine:"1103cc",
rating:"4.9",
img:"https://images.unsplash.com/photo-1558981806-ec527fa84c39?w=1000"
},
{
name:"BMW S1000RR",
brand:"BMW",
price:2200000,
power:"210 HP",
engine:"999cc",
rating:"4.8",
img:"https://images.unsplash.com/photo-1609630875171-b1321377ee65?w=1000"
},
{
name:"Kawasaki ZX10R",
brand:"Kawasaki",
price:1800000,
power:"203 HP",
engine:"998cc",
rating:"4.7",
img:"https://images.unsplash.com/photo-1558981285-6f0c94958bb6?w=1000"
}
];

let compare=[];

function render(data){

const grid=document.getElementById("grid");

grid.innerHTML=data.map(b=>`
<div class="card">
<img src="${b.img}">
<div class="content">

<h2>${b.name}</h2>

<div class="price">
₹${(b.price/100000).toFixed(1)} Lakh
</div>

<div class="specs">
<span class="badge">${b.engine}</span>
<span class="badge">${b.power}</span>
</div>

⭐ ${b.rating}/5

<div class="actions">
<button class="compare"
onclick="addCompare('${b.name}')">
Compare
</button>

<button class="fav">
❤ Wishlist
</button>
</div>

</div>
</div>
`).join("");
}

render(bikes);

function addCompare(name){

if(compare.includes(name)) return;

if(compare.length>=4){
alert("Maximum 4 bikes");
return;
}

compare.push(name);

document.getElementById("panel").style.display="block";

document.getElementById("compareList").innerHTML=
compare.map(x=>`
<div class="compare-item">${x}</div>
`).join("");
}

function generateComparison(){

const selected=bikes.filter(b=>
compare.includes(b.name)
);

let html=`
<tr>
<th>Specification</th>
${selected.map(b=>`<th>${b.name}</th>`).join("")}
</tr>

<tr>
<td>Price</td>
${selected.map(b=>`<td>₹${(b.price/100000).toFixed(1)}L</td>`).join("")}
</tr>

<tr>
<td>Engine</td>
${selected.map(b=>`<td>${b.engine}</td>`).join("")}
</tr>

<tr>
<td>Power</td>
${selected.map(b=>`<td>${b.power}</td>`).join("")}
</tr>

<tr>
<td>Rating</td>
${selected.map(b=>`<td>${b.rating}</td>`).join("")}
</tr>
`;

document.getElementById("comparisonTable").innerHTML=html;
}

document.getElementById("search")
.addEventListener("input",e=>{

const q=e.target.value.toLowerCase();

render(
bikes.filter(b=>
b.name.toLowerCase().includes(q)
)
);

});

</script>

</body>
</html>