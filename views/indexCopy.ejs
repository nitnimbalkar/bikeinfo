<!DOCTYPE html>
<html lang="en">

<head>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>BikeInfo</title>

  <style>

    /* ===============================
       GLOBAL
    =============================== */

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    :root{

      --bg:#ffffff;
      --text:#111111;
      --card:#ffffff;
      --border:#d8d8d8;
      --primary:#4CAF50;

    }

    html.dark{

      --bg:#0f0f0f;
      --text:#f5f5f5;
      --card:#1b1b1b;
      --border:#343434;

    }

    body{

      background:var(--bg);
      color:var(--text);

      font-family:Arial,sans-serif;

      transition:.3s;

      padding-top:75px;

    }

    img{
      width:100%;
      display:block;
    }

    button{
      border:none;
      cursor:pointer;
    }

    /* ===============================
       NAVBAR
    =============================== */

    .navbar{

      position:fixed;

      top:0;
      left:0;

      width:100%;

      height:75px;

      display:flex;

      justify-content:space-between;
      align-items:center;

      padding:0 30px;

      background:rgba(20,20,20,.92);

      backdrop-filter:blur(10px);

      color:#fff;

      z-index:1000;

    }

    .logo{

      font-size:24px;
      font-weight:700;

    }

    .nav-right{

      display:flex;
      align-items:center;
      gap:18px;

    }

    /* ===============================
       TOGGLE
    =============================== */

    .switch{

      position:relative;

      width:52px;
      height:26px;

    }

    .switch input{
      display:none;
    }

    .slider{

      position:absolute;

      inset:0;

      background:#666;

      border-radius:50px;

      transition:.3s;

    }

    .slider::before{

      content:"";

      position:absolute;

      width:20px;
      height:20px;

      top:3px;
      left:3px;

      background:#fff;

      border-radius:50%;

      transition:.3s;

    }

    .switch input:checked + .slider{

      background:var(--primary);

    }

    .switch input:checked + .slider::before{

      transform:translateX(26px);

    }

    /* ===============================
       LOGIN BUTTON
    =============================== */

    .login-btn{

      padding:10px 18px;

      border-radius:8px;

      background:var(--primary);

      color:#fff;

      font-weight:600;

    }

    /* ===============================
       HERO
    =============================== */

    .hero{

      position:relative;

      width:100%;
      height:85vh;

      overflow:hidden;

    }

    .hero img{

      width:100%;
      height:100%;

      object-fit:cover;

      filter:brightness(.7);

    }

    .quote{

      position:absolute;

      top:35%;
      left:65%;

      transform:translateY(-50%);

      color:#fff;

      font-size:34px;

      line-height:1.5;

      max-width:420px;

      font-style:italic;

    }

    /* ===============================
       SEARCH
    =============================== */

    .search-box{

      position:absolute;

      left:50%;
      bottom:70px;

      transform:translateX(-50%);

      width:min(700px,90%);

      display:flex;

      overflow:hidden;

      border-radius:50px;

      background:rgba(255,255,255,.92);

    }

    .search-box input{

      flex:1;

      padding:18px;

      border:none;
      outline:none;

      background:transparent;

      font-size:16px;

    }

    .search-box button{

      padding:0 28px;

      background:var(--primary);

      color:#fff;

    }

    html.dark .search-box{

      background:rgba(30,30,30,.92);

    }

    html.dark .search-box input{

      color:#fff;

    }

    /* ===============================
       BRANDS
    =============================== */

    .brand-section{

      width:min(1200px,95%);

      margin:50px auto;

    }

    .brand-grid{

      display:grid;

      grid-template-columns:
        repeat(auto-fit,minmax(170px,1fr));

      gap:18px;

    }

    .brand-card{

      padding:24px;

      border-radius:14px;

      background:#1b1b1b;

      color:#fff;

      text-align:center;

      cursor:pointer;

      transition:.25s;

    }

    .brand-card:hover{

      transform:translateY(-4px);

    }

    /* ===============================
       DRAWER
    =============================== */

    .backdrop{

      position:fixed;

      inset:0;

      background:rgba(0,0,0,.55);

      opacity:0;

      pointer-events:none;

      transition:.3s;

      z-index:1000;

    }

    .backdrop.active{

      opacity:1;

      pointer-events:all;

    }

    .drawer{

      position:fixed;

      left:50%;
      bottom:-100%;

      transform:translateX(-50%);

      width:min(1200px,100%);

      height:500px;

      background:var(--card);

      color:var(--text);

      border-top-left-radius:22px;
      border-top-right-radius:22px;

      transition:.4s;

      z-index:1001;

      padding:28px;

    }

    .drawer.active{

      bottom:0;

    }

    .close-btn{

      float:right;

      cursor:pointer;

      font-size:24px;

    }

    /* ===============================
       BIKE MODULE
    =============================== */

    .bike-module{

      width:min(1200px,95%);

      margin:50px auto;

    }

    .tabs{

      display:flex;

      gap:12px;

      margin-bottom:24px;

    }

    .tab{

      padding:12px 20px;

      border-radius:10px;

      background:#ececec;

      font-weight:600;

    }

    .tab.active{

      background:#111;

      color:#fff;

    }

    html.dark .tab{

      background:#222;

      color:#fff;

    }

    html.dark .tab.active{

      background:#fff;

      color:#111;

    }

    .bike-content{

      display:none;

    }

    .bike-content.active{

      display:block;

    }

    .grid,
    .horizontal{

      display:grid;

      grid-template-columns:
        repeat(auto-fit,minmax(220px,1fr));

      gap:20px;

    }

    .card{

      border:1px solid var(--border);

      border-radius:14px;

      overflow:hidden;

      background:var(--card);

    }

    .card img{

      height:220px;

      object-fit:cover;

    }

    .card-body{

      padding:16px;

    }

    .price{

      color:var(--primary);

      font-weight:700;

    }

    .container{

      display:flex;

      gap:20px;

    }

    .sidebar{

      width:250px;

      border:1px solid var(--border);

      padding:18px;

      border-radius:12px;

    }

    .sidebar h4{

      margin-bottom:10px;

    }

    .content{

      flex:1;

    }

    /* ===============================
       LOGIN MODAL
    =============================== */

    .login-modal{

      position:fixed;

      inset:0;

      display:flex;

      justify-content:center;
      align-items:center;

      background:rgba(0,0,0,.6);

      opacity:0;

      pointer-events:none;

      transition:.3s;

      z-index:2000;

    }

    .login-modal.active{

      opacity:1;

      pointer-events:all;

    }

    .login-box{

      width:350px;

      background:var(--card);

      color:var(--text);

      padding:28px;

      border-radius:16px;

    }

    .login-box h2{

      margin-bottom:18px;

    }

    .login-box input{

      width:100%;

      padding:12px;

      margin-bottom:14px;

      border:1px solid var(--border);

      border-radius:8px;

      background:transparent;

      color:var(--text);

    }

    .login-box button{

      width:100%;

      padding:12px;

      border-radius:8px;

      background:var(--primary);

      color:#fff;

    }

    .login-close{

      float:right;

      cursor:pointer;

      font-size:22px;

    }

    /* ===============================
       RESPONSIVE
    =============================== */

    @media(max-width:900px){

      .quote{

        left:50%;

        transform:
          translate(-50%,-50%);

        text-align:center;

        width:90%;

        font-size:28px;

      }

      .container{

        flex-direction:column;

      }

      .sidebar{

        width:100%;

      }

    }

  </style>

</head>

<body>

  <!-- ===============================
       NAVBAR
  =============================== -->

  <nav class="navbar">

    <div class="logo">
      BikeInfo
    </div>

    <div class="nav-right">

      <!-- DARK MODE -->
      <label class="switch">

        <input type="checkbox" id="darkToggle">

        <span class="slider"></span>

      </label>

      <!-- LOGIN -->
      <button class="login-btn" id="authBtn">
        Login
      </button>

    </div>

  </nav>

  <!-- ===============================
       HERO
  =============================== -->

  <section class="hero">

    <img
      src="https://images.unsplash.com/photo-1558981806-ec527fa84c39?q=80&w=1400&auto=format&fit=crop"
      alt="Bike Rider"
    >

    <div class="quote">

      Adrenaline is my fuel <br>
      adventure is my destination

    </div>

    <div class="search-box">

      <input
        type="text"
        placeholder="Find Your Dream Ride..."
      >

      <button>
        Search
      </button>

    </div>

  </section>

  <!-- ===============================
       BRANDS
  =============================== -->

  <section class="brand-section">

    <div class="brand-grid" id="brandGrid"></div>

  </section>

  <!-- ===============================
       DRAWER
  =============================== -->

  <div class="backdrop" id="backdrop"></div>

  <div class="drawer" id="drawer">

    <span class="close-btn" id="drawerClose">
      ✖
    </span>

    <h2 id="brandTitle"></h2>

    <p style="margin-top:20px;">

      Brand details appear here.

    </p>

  </div>

  <!-- ===============================
       BIKE MODULE
  =============================== -->

  <section class="bike-module">

    <!-- TABS -->
    <div class="tabs">

      <button
        class="tab active"
        data-tab="trending"
      >
        Trending
      </button>

      <button
        class="tab"
        data-tab="browse"
      >
        Browse
      </button>

      <button
        class="tab"
        data-tab="upcoming"
      >
        Upcoming
      </button>

    </div>

    <!-- TRENDING -->
    <div
      class="bike-content active"
      id="trending"
    >

      <div
        class="grid"
        id="trendingGrid"
      ></div>

    </div>

    <!-- BROWSE -->
    <div
      class="bike-content"
      id="browse"
    >

      <div class="container">

        <!-- FILTER -->
        <aside class="sidebar">

          <h4>Price</h4>

          <input
            type="range"
            min="0"
            max="600000"
            step="50000"
            value="600000"
            id="priceFilter"
          >

          <div style="margin-top:10px;">

            ₹
            <span id="priceValue">
              600000
            </span>

          </div>

        </aside>

        <!-- RESULTS -->
        <div class="content">

          <div
            class="horizontal"
            id="browseGrid"
          ></div>

        </div>

      </div>

    </div>

    <!-- UPCOMING -->
    <div
      class="bike-content"
      id="upcoming"
    >

      <div
        class="grid"
        id="upcomingGrid"
      ></div>

    </div>

  </section>

  <!-- ===============================
       LOGIN MODAL
  =============================== -->

  <div
    class="login-modal"
    id="loginModal"
  >

    <div class="login-box">

      <span
        class="login-close"
        id="loginClose"
      >
        ✖
      </span>

      <h2>Login</h2>

      <input
        type="text"
        placeholder="Username"
      >

      <input
        type="password"
        placeholder="Password"
      >

      <button id="loginSubmit">
        Login
      </button>

    </div>

  </div>

  <!-- ===============================
       JAVASCRIPT
  =============================== -->

  <script>

    /* ===============================
       THEME
    =============================== */

    const darkToggle =
      document.getElementById("darkToggle");

    darkToggle.addEventListener("change", () => {

      document.documentElement
        .classList
        .toggle("dark", darkToggle.checked);

    });

    /* ===============================
       LOGIN MODAL
    =============================== */

    const authBtn =
      document.getElementById("authBtn");

    const loginModal =
      document.getElementById("loginModal");

    const loginClose =
      document.getElementById("loginClose");

    const loginSubmit =
      document.getElementById("loginSubmit");

    authBtn.addEventListener("click", () => {

      loginModal.classList.add("active");

    });

    loginClose.addEventListener("click", () => {

      loginModal.classList.remove("active");

    });

    loginSubmit.addEventListener("click", () => {

      loginModal.classList.remove("active");

      authBtn.innerHTML = `
        <img
          src="https://i.pravatar.cc/100"
          style="
            width:42px;
            height:42px;
            border-radius:50%;
          "
        >
      `;

    });

    /* ===============================
       BRANDS
    =============================== */

    const brands = [

      "Royal Enfield",
      "Honda",
      "Yamaha",
      "KTM",
      "BMW",
      "TVS",
      "Bajaj",
      "Hero"

    ];

    const brandGrid =
      document.getElementById("brandGrid");

    const drawer =
      document.getElementById("drawer");

    const backdrop =
      document.getElementById("backdrop");

    const brandTitle =
      document.getElementById("brandTitle");

    brands.forEach(brand => {

      const card =
        document.createElement("div");

      card.className = "brand-card";

      card.textContent = brand;

      card.addEventListener("click", () => {

        brandTitle.textContent = brand;

        drawer.classList.add("active");

        backdrop.classList.add("active");

      });

      brandGrid.appendChild(card);

    });

    function closeDrawer(){

      drawer.classList.remove("active");

      backdrop.classList.remove("active");

    }

    backdrop.addEventListener("click", closeDrawer);

    document
      .getElementById("drawerClose")
      .addEventListener("click", closeDrawer);

    /* ===============================
       BIKES DATA
    =============================== */

    const bikes = [

      {
        name:"Classic 350",
        price:230000,
        cc:350,
        upcoming:false,
        img:"https://images.unsplash.com/photo-1558981806-ec527fa84c39?q=80&w=1200&auto=format&fit=crop"
      },

      {
        name:"Apache RTR",
        price:150000,
        cc:160,
        upcoming:false,
        img:"https://images.unsplash.com/photo-1517846693594-1567da72af75?q=80&w=1200&auto=format&fit=crop"
      },

      {
        name:"KTM Duke 390",
        price:320000,
        cc:390,
        upcoming:true,
        img:"https://images.unsplash.com/photo-1449965408869-eaa3f722e40d?q=80&w=1200&auto=format&fit=crop"
      },

      {
        name:"BMW GS",
        price:580000,
        cc:850,
        upcoming:true,
        img:"https://images.unsplash.com/photo-1503376780353-7e6692767b70?q=80&w=1200&auto=format&fit=crop"
      }

    ];

    /* ===============================
       CARD CREATOR
    =============================== */

    function createBikeCard(bike){

      return `

        <div class="card">

          <img
            src="${bike.img}"
            alt="${bike.name}"
          >

          <div class="card-body">

            <h3>${bike.name}</h3>

            <p style="margin:10px 0;">
              ${bike.cc}cc
            </p>

            <span class="price">

              ₹${bike.price.toLocaleString()}

            </span>

          </div>

        </div>

      `;

    }

    /* ===============================
       RENDER BIKES
    =============================== */

    const trendingGrid =
      document.getElementById("trendingGrid");

    const browseGrid =
      document.getElementById("browseGrid");

    const upcomingGrid =
      document.getElementById("upcomingGrid");

    function renderTrending(){

      trendingGrid.innerHTML =
        bikes.map(createBikeCard).join("");

    }

    function renderBrowse(){

      const maxPrice =
        Number(priceFilter.value);

      priceValue.innerText =
        maxPrice.toLocaleString();

      const filtered =
        bikes.filter(b => b.price <= maxPrice);

      browseGrid.innerHTML =
        filtered.map(createBikeCard).join("");

    }

    function renderUpcoming(){

      const upcoming =
        bikes.filter(b => b.upcoming);

      upcomingGrid.innerHTML =
        upcoming.map(createBikeCard).join("");

    }

    renderTrending();
    renderBrowse();
    renderUpcoming();

    /* ===============================
       FILTER
    =============================== */

    const priceFilter =
      document.getElementById("priceFilter");

    const priceValue =
      document.getElementById("priceValue");

    priceFilter.addEventListener("input", () => {

      renderBrowse();

    });

    /* ===============================
       TABS
    =============================== */

    const tabs =
      document.querySelectorAll(".tab");

    const contents =
      document.querySelectorAll(".bike-content");

    tabs.forEach(tab => {

      tab.addEventListener("click", () => {

        tabs.forEach(t =>
          t.classList.remove("active")
        );

        contents.forEach(c =>
          c.classList.remove("active")
        );

        tab.classList.add("active");

        document
          .getElementById(tab.dataset.tab)
          .classList.add("active");

      });

    });

  </script>

</body>
</html>
