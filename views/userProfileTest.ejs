<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>BikeInfo</title>

<style>

/* RESET */
*{margin:0;padding:0;box-sizing:border-box;}

body{
  font-family:Arial;
  background:#fff;
  color:#000;
  padding-top:60px;
}

/* NAVBAR */
.navbar{
  position:fixed;
  top:0;
  width:100%;
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:12px 20px;
  background:rgba(30,30,30,0.95);
  color:white;
}

.logo{font-weight:bold;}

/* TOGGLE */
.switch{position:relative;width:50px;height:26px;}
.switch input{display:none;}
.slider{
  position:absolute;inset:0;
  background:#ccc;border-radius:30px;cursor:pointer;
}
.slider:before{
  content:"";
  position:absolute;width:20px;height:20px;
  left:3px;top:3px;background:white;border-radius:50%;
  transition:0.3s;
}
input:checked + .slider{background:#4CAF50;}
input:checked + .slider:before{transform:translateX(24px);}

/* PROFILE */
.profile{
  width:60%;
  margin:20px auto;
  border:1px solid #ddd;
  border-radius:14px;
  padding:18px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  background:#fafafa;
}

.profile-left{
  display:flex;
  align-items:center;
  gap:15px;
}

.profile-img{
  width:70px;height:70px;
  border-radius:50%;
  overflow:hidden;
  border:2px solid #ddd;
}

.profile-img img{
  width:100%;height:100%;
  object-fit:cover;
}

/* RIGHT INFO */
.profile-right{
  display:flex;
  flex-direction:column;
  text-align:right;
  gap:6px;
}

/* EDIT BUTTON */
.edit-btn{
  padding:6px 12px;
  background:#4CAF50;
  color:white;
  border:none;
  border-radius:8px;
  cursor:pointer;
  margin-bottom:6px;
}

/* GARAGE */
.garage{
  width:60%;
  margin:20px auto;
  border:1px solid #ddd;
  border-radius:14px;
  padding:18px;
  background:#fafafa;
}

.garage-top{
  display:flex;
  justify-content:space-between;
}

.bike-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:12px;
  margin-top:12px;
}

.bike-card{
  border:1px solid #ddd;
  border-radius:10px;
  overflow:hidden;
  background:#fff;
}

.bike-card img{
  width:100%;
  height:90px;
  object-fit:cover;
}

.bike-info{padding:8px;}
.bike-name{font-size:13px;font-weight:bold;}
.bike-type{font-size:11px;color:#666;}

/* ================= MODALS ================= */
.modal,
.cropper{
  position:fixed;
  inset:0;
  display:none;
  justify-content:center;
  align-items:center;
  background:rgba(0,0,0,0.6);
  z-index:9999;
}

/* PROFILE MODAL */
.modal-box{
  width:340px;
  background:white;
  border-radius:16px;
  padding:20px;
}

.modal-box input{
  width:100%;
  padding:10px;
  margin:6px 0;
  border:1px solid #ddd;
  border-radius:10px;
}

.modal-box button{
  width:100%;
  padding:10px;
  background:#4CAF50;
  border:none;
  color:white;
  border-radius:10px;
  cursor:pointer;
}

/* CROPPER */
.crop-box{
  width:260px;
  height:260px;
  border-radius:50%;
  overflow:hidden;
  border:3px solid white;
  position:relative;
  background:#111;
}

.crop-img{
  position:absolute;
  width:400px;
  cursor:grab;
}

.zoom{
  margin-top:12px;
  width:200px;
}

.crop-actions{
  margin-top:12px;
  display:flex;
  gap:10px;
}

.crop-actions button{
  padding:8px 12px;
  border:none;
  border-radius:8px;
  cursor:pointer;
}

.save{background:#4CAF50;color:white;}
.cancel{background:#999;color:white;}

</style>
</head>

<body>

<!-- NAVBAR -->
<div class="navbar">
  <div class="logo">BikeInfo</div>

  <label class="switch">
    <input type="checkbox" id="darkToggle">
    <span class="slider"></span>
  </label>
</div>

<!-- PROFILE -->
<div class="profile">

  <div class="profile-left">
    <div class="profile-img">
      <img id="profilePic" src="https://i.pravatar.cc/300?img=12">
    </div>

    <div>
      <h3 id="name">Rahul Sharma</h3>
      <p>@riderx</p>
      <button class="edit-btn" onclick="openProfile()">Edit Profile</button>
    </div>
  </div>

  <div class="profile-right">
    <div id="age">Age: 24</div>
    <div id="city">City: Pune</div>
    <div id="email">Email: test@gmail.com</div>
  </div>

</div>

<!-- GARAGE -->
<div class="garage">
  <div class="garage-top">
    <h3>Garage</h3>
    <button>+ Add Bike</button>
  </div>

  <div class="bike-grid" id="grid"></div>
</div>

<!-- PROFILE MODAL -->
<div class="modal" id="modal">
  <div class="modal-box">

    <input id="first" placeholder="First Name">
    <input id="last" placeholder="Last Name">
    <input id="ageInput" placeholder="Age">
    <input id="cityInput" placeholder="City">

    <!-- IMAGE UPLOAD -->
    <input type="file" accept="image/*" onchange="openCrop(event)">

    <button onclick="saveProfile()">Save</button>

  </div>
</div>

<!-- CROPPER -->
<div class="cropper" id="cropper">

  <div class="crop-box">
    <img id="cropImg" class="crop-img">
  </div>

  <input type="range" min="1" max="2" step="0.01" id="zoom" class="zoom">

  <div class="crop-actions">
    <button class="cancel" onclick="closeCrop()">Cancel</button>
    <button class="save" onclick="applyCrop()">Crop</button>
  </div>

</div>

<script>

/* DARK MODE */
document.getElementById("darkToggle").onchange=()=>{
  document.body.classList.toggle("dark");
}

/* PROFILE MODAL */
function openProfile(){
  document.getElementById("modal").style.display="flex";
}

/* CROPPER LOGIC */
let img=document.getElementById("cropImg");
let zoom=document.getElementById("zoom");

let x=0,y=0,scale=1,drag=false,sx,sy;

function openCrop(e){
  let file=e.target.files[0];
  let reader=new FileReader();

  reader.onload=ev=>{
    img.src=ev.target.result;
    document.getElementById("cropper").style.display="flex";
    x=0;y=0;scale=1;
  }
  reader.readAsDataURL(file);
}

/* DRAG */
img.onmousedown=e=>{
  drag=true;
  sx=e.clientX;
  sy=e.clientY;
};

document.onmousemove=e=>{
  if(!drag)return;
  x+=e.clientX-sx;
  y+=e.clientY-sy;
  sx=e.clientX;
  sy=e.clientY;
  update();
};

document.onmouseup=()=>drag=false;

/* ZOOM */
zoom.oninput=()=>{
  scale=zoom.value;
  update();
};

function update(){
  img.style.transform=`translate(${x}px,${y}px) scale(${scale})`;
}

function closeCrop(){
  document.getElementById("cropper").style.display="none";
}

/* APPLY CROP */
function applyCrop(){
  let canvas=document.createElement("canvas");
  canvas.width=200;
  canvas.height=200;
  let ctx=canvas.getContext("2d");

  let im=new Image();
  im.src=img.src;

  im.onload=()=>{
    ctx.drawImage(im,0,0,200,200);
    document.getElementById("profilePic").src=canvas.toDataURL();
    closeCrop();
  }
}

/* SAVE PROFILE */
function saveProfile(){
  document.getElementById("name").innerText=
    document.getElementById("first").value+" "+document.getElementById("last").value;

  document.getElementById("age").innerText="Age: "+document.getElementById("ageInput").value;
  document.getElementById("city").innerText="City: "+document.getElementById("cityInput").value;

  document.getElementById("modal").style.display="none";
}

/* BIKE DATA */
let bikes=[
  {name:"KTM Duke",type:"Street"},
  {name:"Yamaha R15",type:"Sport"},
  {name:"BMW GS",type:"ADV"},
  {name:"Ninja 400",type:"Sport"}
];

let grid=document.getElementById("grid");

bikes.forEach(b=>{
  grid.innerHTML+=`
    <div class="bike-card">
      <img src="https://source.unsplash.com/300x200/?bike">
      <div class="bike-info">
        <div class="bike-name">${b.name}</div>
        <div class="bike-type">${b.type}</div>
      </div>
    </div>
  `;
});

</script>

</body>
</html>