<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Steam Bike Garage</title>

<style>

:root{
  --bg:#f5f6f8;
  --text:#111;
  --sub:#666;
  --border:#d9dbe1;
  --accent:#4c8bf5;
}

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  background:var(--bg);
  font-family:Arial, sans-serif;
  color:var(--text);
}

.container{
  max-width:1200px;
  margin:auto;
  padding:40px 20px;
}

/* PROFILE */

.profile-top{
  display:flex;
  gap:40px;
  align-items:center;
  border-bottom:1px solid var(--border);
  padding-bottom:25px;
}

.profile-image{
  width:130px;
  height:130px;
  border-radius:50%;
  overflow:hidden;
  border:3px solid var(--border);
}

.profile-image img{
  width:100%;
  height:100%;
  object-fit:cover;
}

.username{
  font-size:28px;
  font-weight:700;
}

.meta{
  color:var(--sub);
  margin-top:6px;
  font-size:14px;
}

/* GARAGE */

.showcase{
  margin-top:40px;
}

.garage-title{
  font-size:22px;
  font-weight:700;
  margin-bottom:15px;
}

/* BIKE GRID */

.bike-grid{
  display:flex;
  gap:15px;
  overflow-x:auto;
  padding-bottom:10px;
}

.bike-card{
  width:220px;
  height:300px;
  flex-shrink:0;
  background:#fff;
  border:1px solid var(--border);
  border-radius:14px;
  overflow:hidden;
  cursor:pointer;
  display:flex;
  flex-direction:column;
  transition:.25s;
}

.bike-card:hover{
  transform:translateY(-6px);
}

.bike-card img{
  width:100%;
  height:170px;
  object-fit:cover;
}

.bike-info{
  padding:12px;
}

.bike-name{
  font-weight:700;
  font-size:15px;
}

.bike-desc{
  margin-top:8px;
  color:var(--sub);
  font-size:13px;
}

/* TABS */

.tabs{
  display:flex;
  gap:12px;
  margin-top:60px;
  margin-bottom:20px;
}

.tab{
  padding:12px 20px;
  border-radius:10px;
  background:#e5e7eb;
  cursor:pointer;
  font-weight:600;
}

.tab.active{
  background:var(--accent);
  color:#fff;
}

.tab-content{
  display:none;
}

.tab-content.active{
  display:block;
}

/* MEDIA */

.media-grid{
  display:grid;
  grid-template-columns:repeat(3, 1fr);
  gap:12px;
}

.media-post{
  aspect-ratio:1/1;
  border-radius:14px;
  overflow:hidden;
  background:#ddd;
}

.media-post img{
  width:100%;
  height:100%;
  object-fit:cover;
  transition:.3s;
}

.media-post:hover img{
  transform:scale(1.05);
}

/* REVIEWS */

.review-list{
  display:flex;
  flex-direction:column;
  gap:18px;
}

.review-card{
  background:#fff;
  border:1px solid var(--border);
  border-radius:16px;
  padding:18px;
}

.review-bike{
  display:flex;
  align-items:center;
  gap:14px;
}

.review-bike img{
  width:70px;
  height:70px;
  border-radius:12px;
  object-fit:cover;
}

.review-bike-name{
  font-size:18px;
  font-weight:700;
}

.review-date{
  margin-top:4px;
  color:var(--sub);
  font-size:13px;
}

.review-stars{
  margin-top:14px;
  color:#f59e0b;
  font-size:20px;
}

.review-text{
  margin-top:12px;
  color:var(--sub);
  line-height:1.7;
  font-size:14px;
}

</style>
</head>

<body>

<div class="container">

  <!-- PROFILE -->
  <div class="profile-top">
    <div class="profile-image">
      <img src="https://i.pravatar.cc/400?img=12">
    </div>
    <div>
      <div class="username">Rider_X</div>
      <div class="meta">Mumbai • Steam Garage System</div>
    </div>
  </div>

  <!-- BIKE GARAGE -->
  <div class="showcase">
    <div class="garage-title">Bike Garage</div>

    <div class="bike-grid">

      <div class="bike-card">
        <img src="https://images.unsplash.com/photo-1558981806-ec527fa84c39">
        <div class="bike-info">
          <div class="bike-name">KTM Duke 390</div>
          <div class="bike-desc">Street performance beast</div>
        </div>
      </div>

      <div class="bike-card">
        <img src="https://images.unsplash.com/photo-1609630875171-b1321377ee65">
        <div class="bike-info">
          <div class="bike-name">BMW G 310 GS</div>
          <div class="bike-desc">Adventure touring machine</div>
        </div>
      </div>

      <div class="bike-card">
        <img src="https://images.unsplash.com/photo-1580310614729-ccd69652491d">
        <div class="bike-info">
          <div class="bike-name">Yamaha R15 V4</div>
          <div class="bike-desc">Light supersport machine</div>
        </div>
      </div>

      <div class="bike-card">
        <img src="https://images.unsplash.com/photo-1625047509168-a7026f36de04">
        <div class="bike-info">
          <div class="bike-name">Kawasaki Ninja 400</div>
          <div class="bike-desc">Balanced sport performance</div>
        </div>
      </div>

      <div class="bike-card">
        <img src="https://images.unsplash.com/photo-1606220838315-056192d5e927">
        <div class="bike-info">
          <div class="bike-name">Royal Enfield GT 650</div>
          <div class="bike-desc">Classic modern cruiser</div>
        </div>
      </div>

      <div class="bike-card">
        <img src="https://images.unsplash.com/photo-1502877338535-766e1452684a">
        <div class="bike-info">
          <div class="bike-name">Harley Davidson Iron 883</div>
          <div class="bike-desc">Pure American cruiser feel</div>
        </div>
      </div>

      <div class="bike-card">
        <img src="https://images.unsplash.com/photo-1500530855697-b586d89ba3ee">
        <div class="bike-info">
          <div class="bike-name">Ducati Panigale V2</div>
          <div class="bike-desc">Superbike performance machine</div>
        </div>
      </div>

      <div class="bike-card">
        <img src="https://images.unsplash.com/photo-1491553895911-0055eca6402d">
        <div class="bike-info">
          <div class="bike-name">TVS Apache RR 310</div>
          <div class="bike-desc">Affordable sport tourer</div>
        </div>
      </div>

    </div>
  </div>

  <!-- TABS -->
  <div class="tabs">
    <div class="tab active" onclick="switchTab('media',this)">Media</div>
    <div class="tab" onclick="switchTab('reviews',this)">Reviews</div>
  </div>

  <!-- MEDIA -->
  <div class="tab-content active" id="media">

    <div class="media-grid">

      <div class="media-post"><img src="https://images.unsplash.com/photo-1511919884226-fd3cad34687c"></div>
      <div class="media-post"><img src="https://images.unsplash.com/photo-1493238792000-8113da705763"></div>
      <div class="media-post"><img src="https://images.unsplash.com/photo-1503376780353-7e6692767b70"></div>
      <div class="media-post"><img src="https://images.unsplash.com/photo-1489824904134-891ab64532f1"></div>
      <div class="media-post"><img src="https://images.unsplash.com/photo-1544636331-e26879cd4d9b"></div>
      <div class="media-post"><img src="https://images.unsplash.com/photo-1502877338535-766e1452684a"></div>

    </div>

  </div>

  <!-- REVIEWS -->
  <div class="tab-content" id="reviews">

    <div class="review-list">

      <div class="review-card">
        <div class="review-bike">
          <img src="https://images.unsplash.com/photo-1558981806-ec527fa84c39">
          <div>
            <div class="review-bike-name">KTM Duke 390</div>
            <div class="review-date">May 17, 2026</div>
          </div>
        </div>
        <div class="review-stars">★★★★★</div>
        <div class="review-text">Insane power and perfect city bike.</div>
      </div>

      <div class="review-card">
        <div class="review-bike">
          <img src="https://images.unsplash.com/photo-1609630875171-b1321377ee65">
          <div>
            <div class="review-bike-name">BMW G 310 GS</div>
            <div class="review-date">April 28, 2026</div>
          </div>
        </div>
        <div class="review-stars">★★★★☆</div>
        <div class="review-text">Comfortable touring but slightly underpowered.</div>
      </div>

    </div>

  </div>

</div>

<script>

function switchTab(id, el){
  document.querySelectorAll(".tab").forEach(t=>t.classList.remove("active"));
  document.querySelectorAll(".tab-content").forEach(c=>c.classList.remove("active"));

  el.classList.add("active");
  document.getElementById(id).classList.add("active");
}

</script>

</body>
</html> 