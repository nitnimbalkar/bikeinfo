<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bike Compare Pro</title>

<style>
:root{
    --primary:#ff6d00;
    --dark:#1f2937;
    --gray:#6b7280;
    --border:#e5e7eb;
    --bg:#f5f7fb;
    --card:#ffffff;
    --success:#dcfce7;
    --shadow:0 8px 25px rgba(0,0,0,.08);
}

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Inter,Segoe UI,sans-serif;
}

body{
    background:var(--bg);
    color:var(--dark);
}

.header{
    background:white;
    padding:20px;
    box-shadow:0 2px 10px rgba(0,0,0,.05);
    position:sticky;
    top:0;
    z-index:1000;
}

.container{
    width:min(1400px,95%);
    margin:auto;
}

.header h1{
    font-size:32px;
}

.header p{
    color:var(--gray);
    margin-top:5px;
}

.selection-box{
    margin-top:20px;
    display:grid;
    grid-template-columns:repeat(5,1fr);
    gap:12px;
}

.selection-box select{
    padding:12px;
    border:1px solid var(--border);
    border-radius:12px;
    background:white;
    font-size:14px;
}

.compare-btn{
    margin-top:15px;
    background:var(--primary);
    color:white;
    border:none;
    padding:12px 28px;
    border-radius:10px;
    cursor:pointer;
    font-weight:600;
}

.compare-btn:hover{
    opacity:.9;
}

.compare-wrapper{
    margin-top:25px;
    overflow-x:auto;
}

.compare-table{
    width:100%;
    min-width:1100px;
    border-collapse:collapse;
    background:white;
    border-radius:20px;
    overflow:hidden;
    box-shadow:var(--shadow);
}

.compare-table th{
    background:white;
    position:sticky;
    top:0;
    z-index:100;
    border-bottom:2px solid var(--border);
}

.compare-table th,
.compare-table td{
    padding:18px;
    text-align:center;
}

.compare-table tr{
    border-bottom:1px solid var(--border);
}

.spec-name{
    text-align:left !important;
    font-weight:700;
    background:#fafafa;
    min-width:220px;
}

.bike-card{
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:10px;
}

.bike-card img{
    width:220px;
    height:130px;
    object-fit:cover;
    border-radius:12px;
}

.bike-name{
    font-size:15px;
    font-weight:700;
}

.price{
    color:var(--primary);
    font-weight:700;
}

.section{
    background:#f9fafb;
    font-weight:700;
    color:#111827;
}

.best{
    background:var(--success);
    font-weight:700;
}

.badge{
    display:inline-block;
    background:#fff3e8;
    color:#ff6d00;
    padding:6px 10px;
    border-radius:999px;
    font-size:12px;
    font-weight:600;
}

.footer{
    text-align:center;
    padding:40px;
    color:var(--gray);
}

@media(max-width:900px){

    .selection-box{
        grid-template-columns:1fr;
    }

    .header h1{
        font-size:24px;
    }

    .bike-card img{
        width:140px;
        height:90px;
    }
}
</style>
</head>
<body>

<div class="header">
    <div class="container">
        <h1>🏍 Bike Compare Pro</h1>
        <p>Compare up to 5 bikes side-by-side</p>

        <div class="selection-box">
            <select class="bike-select"></select>
            <select class="bike-select"></select>
            <select class="bike-select"></select>
            <select class="bike-select"></select>
            <select class="bike-select"></select>
        </div>

        <button class="compare-btn" onclick="compareBikes()">
            Compare Bikes
        </button>
    </div>
</div>

<div class="container">
    <div id="compareResult"></div>
</div>

<div class="footer">
    Bike Comparison Demo
</div>

<script>

const bikes = [

{
name:"Royal Enfield Hunter 350",
price:"₹1.50 Lakh",
engine:349,
power:20.2,
torque:27,
mileage:36,
weight:181,
seatHeight:800,
fuelTank:13,
image:"https://images.unsplash.com/photo-1558981806-ec527fa84c39?w=1000"
},

{
name:"TVS Raider 125",
price:"₹95,000",
engine:124,
power:11.2,
torque:11.2,
mileage:57,
weight:123,
seatHeight:780,
fuelTank:10,
image:"https://images.unsplash.com/photo-1580310614729-ccd69652491d?w=1000"
},

{
name:"Yamaha R15 V4",
price:"₹1.85 Lakh",
engine:155,
power:18.4,
torque:14.2,
mileage:45,
weight:141,
seatHeight:815,
fuelTank:11,
image:"https://images.unsplash.com/photo-1609630875171-b1321377ee65?w=1000"
},

{
name:"Bajaj Pulsar N160",
price:"₹1.32 Lakh",
engine:164,
power:16,
torque:14.7,
mileage:50,
weight:154,
seatHeight:795,
fuelTank:14,
image:"https://images.unsplash.com/photo-1517846693594-1567da72af75?w=1000"
},

{
name:"TVS Apache RTR 200",
price:"₹1.55 Lakh",
engine:197,
power:20.8,
torque:17.2,
mileage:41,
weight:152,
seatHeight:800,
fuelTank:12,
image:"https://images.unsplash.com/photo-1449965408869-eaa3f722e40d?w=1000"
}

];

const selects = document.querySelectorAll(".bike-select");

function populateDropdowns(){

selects.forEach(select=>{

select.innerHTML =
`<option value="">Select Bike</option>`;

bikes.forEach((bike,index)=>{

select.innerHTML += `
<option value="${index}">
${bike.name}
</option>`;

});

});

}

populateDropdowns();

function maxValue(arr,key){
return Math.max(...arr.map(x=>x[key]));
}

function compareBikes(){

const selected=[];

selects.forEach(select=>{

if(select.value !== ""){
selected.push(bikes[select.value]);
}

});

if(selected.length < 2){
alert("Please select at least 2 bikes");
return;
}

const bestEngine=maxValue(selected,"engine");
const bestPower=maxValue(selected,"power");
const bestTorque=maxValue(selected,"torque");
const bestMileage=maxValue(selected,"mileage");
const bestFuel=maxValue(selected,"fuelTank");

let html=`
<div class="compare-wrapper">

<table class="compare-table">

<tr>
<th class="spec-name">Bike</th>
`;

selected.forEach(bike=>{

html += `
<th>
<div class="bike-card">
<img src="${bike.image}">
<div class="bike-name">${bike.name}</div>
<div class="price">${bike.price}</div>
</div>
</th>
`;

});

html += `</tr>`;

html += `
<tr class="section">
<td class="spec-name">Engine & Performance</td>
${selected.map(()=>"<td></td>").join("")}
</tr>
`;

createRow("Engine (cc)","engine",bestEngine);
createRow("Power (PS)","power",bestPower);
createRow("Torque (Nm)","torque",bestTorque);
createRow("Mileage (km/l)","mileage",bestMileage);

html += `
<tr class="section">
<td class="spec-name">Dimensions</td>
${selected.map(()=>"<td></td>").join("")}
</tr>
`;

createRow("Weight (kg)","weight");
createRow("Seat Height (mm)","seatHeight");
createRow("Fuel Tank (L)","fuelTank",bestFuel);

html += "</table></div>";

document.getElementById("compareResult").innerHTML = html;

function createRow(label,key,best=null){

html += `
<tr>
<td class="spec-name">${label}</td>
`;

selected.forEach(bike=>{

const highlight =
(best !== null && bike[key] === best)
? "best"
: "";

html += `
<td class="${highlight}">
${bike[key]}
</td>
`;

});

html += "</tr>";

}

}

</script>

</body>
</html>