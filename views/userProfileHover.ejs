<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bike Review Profile Popup</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:#eef2f7;
    font-family:Arial, sans-serif;
}

/* SMALL USER CARD */

.user-box{
    position:relative;
}

.user-trigger{
    display:flex;
    align-items:center;
    gap:12px;
    background:#fff;
    padding:10px 16px;
    border-radius:60px;
    cursor:pointer;
    box-shadow:0 8px 20px rgba(0,0,0,0.08);
    transition:0.3s ease;
}

.user-trigger:hover{
    transform:translateY(-3px);
    box-shadow:0 12px 28px rgba(0,0,0,0.12);
}

.user-trigger img{
    width:48px;
    height:48px;
    border-radius:50%;
    object-fit:cover;
    border:2px solid #3b82f6;
}

.user-info h3{
    font-size:15px;
    color:#111827;
}

.user-info span{
    font-size:12px;
    color:#6b7280;
}

/* POPUP PROFILE */

.popup{
    position:absolute;
    top:80px;
    left:50%;
    transform:translateX(-50%);
    width:320px;
    background:white;
    border-radius:24px;
    padding:28px 22px;
    text-align:center;
    box-shadow:0 18px 40px rgba(0,0,0,0.15);

    opacity:0;
    visibility:hidden;
    transition:0.35s ease;
}

.user-box:hover .popup{
    opacity:1;
    visibility:visible;
    top:90px;
}

/* PROFILE IMAGE */

.profile-img{
    width:100px;
    height:100px;
    margin:auto;
    border-radius:50%;
    overflow:hidden;

    border:5px solid #3b82f6;

    box-shadow:0 10px 22px rgba(59,130,246,0.25);
}

.profile-img img{
    width:100%;
    height:100%;
    object-fit:cover;
    border-radius:50%;
}

/* CONTENT */

.content h2{
    margin-top:18px;
    font-size:22px;
    color:#111827;
}

.username{
    margin-top:5px;
    font-size:13px;
    color:#6b7280;
}

.bio{
    margin-top:14px;
    font-size:14px;
    line-height:1.6;
    color:#4b5563;
}

/* STATS */

.stats{
    display:flex;
    justify-content:space-between;
    margin-top:24px;
    padding-top:18px;
    border-top:1px solid #eee;
}

.stats div h4{
    font-size:18px;
    color:#111827;
}

.stats div p{
    margin-top:4px;
    font-size:12px;
    color:#6b7280;
}

/* BUTTON */

.follow-btn{
    margin-top:24px;
    width:100%;
    border:none;
    padding:12px;
    border-radius:14px;
    background:linear-gradient(135deg,#3b82f6,#2563eb);
    color:white;
    font-weight:bold;
    cursor:pointer;
    transition:0.3s;
}

.follow-btn:hover{
    transform:translateY(-2px);
    box-shadow:0 10px 18px rgba(59,130,246,0.3);
}

</style>
</head>

<body>

<div class="user-box">

    <!-- SMALL USER -->
    <div class="user-trigger">

        <img 
        src="https://randomuser.me/api/portraits/men/32.jpg"
        alt="user">

        <div class="user-info">
            <h3>Rahul Biker</h3>
            <span>@ridewithrahul</span>
        </div>

    </div>

    <!-- POPUP PROFILE -->
    <div class="popup">

        <!-- PROFILE IMAGE -->
        <div class="profile-img">

            <img 
            src="https://randomuser.me/api/portraits/men/32.jpg"
            alt="profile">

        </div>

        <!-- CONTENT -->
        <div class="content">

            <h2>Rahul Biker</h2>

            <div class="username">
                @ridewithrahul
            </div>

            <div class="bio">
                Superbikes • Long Rides • Honest Bike Reviews 🏍️
            </div>

            <!-- STATS -->
            <div class="stats">

                <div>
                    <h4>128</h4>
                    <p>Reviews</p>
                </div>

                <div>
                    <h4>54K</h4>
                    <p>Followers</p>
                </div>

                <div>
                    <h4>220</h4>
                    <p>Following</p>
                </div>

            </div>

            <!-- BUTTON -->
            <button class="follow-btn">
                Follow
            </button>

        </div>

    </div>

</div>

</body>
</html>