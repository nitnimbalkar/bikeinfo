<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KTM 390 Duke R</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Inter, Arial, sans-serif;
}

body{
    background:#f5f6fa;
    color:#222;
}

.container{
    max-width:1200px;
    margin:auto;
    padding:20px;
}

header{
    background:#fff;
    padding:15px 30px;
    box-shadow:0 2px 10px rgba(0,0,0,.08);
    position:sticky;
    top:0;
    z-index:100;
}

.logo{
    font-size:24px;
    font-weight:700;
    color:#ff6600;
}

.hero{
    display:grid;
    grid-template-columns:1.5fr 1fr;
    gap:25px;
    margin-top:20px;
}

.card{
    background:#fff;
    border-radius:16px;
    padding:20px;
    box-shadow:0 4px 12px rgba(0,0,0,.06);
}

.main-image{
    width:100%;
    height:420px;
    object-fit:cover;
    border-radius:12px;
}

.thumbnail-row{
    display:flex;
    gap:10px;
    margin-top:12px;
}

.thumb{
    width:90px;
    height:60px;
    border-radius:8px;
    cursor:pointer;
    object-fit:cover;
    border:2px solid transparent;
}

.thumb.active{
    border-color:#ff6600;
}

.bike-title{
    font-size:34px;
    margin-bottom:8px;
}

.rating{
    color:#f4b400;
    font-size:18px;
    margin-bottom:15px;
}

.price{
    font-size:34px;
    font-weight:700;
    color:#111;
}

.sub-price{
    color:#666;
    margin-top:5px;
}

.btns{
    display:flex;
    gap:12px;
    margin-top:20px;
}

.btn{
    flex:1;
    padding:14px;
    border:none;
    border-radius:10px;
    font-weight:600;
    cursor:pointer;
}

.primary{
    background:#ff6600;
    color:white;
}

.secondary{
    background:#eee;
}

.specs{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:15px;
    margin-top:25px;
}

.spec-box{
    background:white;
    padding:18px;
    text-align:center;
    border-radius:12px;
    box-shadow:0 4px 10px rgba(0,0,0,.05);
}

.spec-value{
    font-size:24px;
    font-weight:700;
    color:#ff6600;
}

.spec-label{
    color:#666;
    margin-top:8px;
}

.tabs{
    display:flex;
    gap:15px;
    margin-top:35px;
    flex-wrap:wrap;
}

.tab{
    background:white;
    border:none;
    padding:12px 20px;
    border-radius:10px;
    cursor:pointer;
}

.tab.active{
    background:#ff6600;
    color:white;
}

.tab-content{
    margin-top:20px;
}

.content-panel{
    display:none;
}

.content-panel.active{
    display:block;
}

.feature-grid{
    display:grid;
    grid-template-columns:repeat(2,1fr);
    gap:15px;
}

.feature-item{
    background:white;
    padding:18px;
    border-radius:12px;
}

.spec-table{
    width:100%;
    border-collapse:collapse;
    background:white;
    border-radius:12px;
    overflow:hidden;
}

.spec-table td{
    padding:14px;
    border-bottom:1px solid #eee;
}

.review{
    background:white;
    padding:18px;
    border-radius:12px;
    margin-bottom:15px;
}

.emi-box{
    background:white;
    padding:20px;
    border-radius:12px;
}

input[type=range]{
    width:100%;
    margin:15px 0;
}

.emi-result{
    font-size:32px;
    color:#ff6600;
    font-weight:700;
}

.footer{
    text-align:center;
    padding:40px;
    color:#666;
}

@media(max-width:900px){

.hero{
    grid-template-columns:1fr;
}

.specs{
    grid-template-columns:repeat(2,1fr);
}

.feature-grid{
    grid-template-columns:1fr;
}
}

@media(max-width:600px){

.specs{
    grid-template-columns:1fr;
}

.bike-title{
    font-size:28px;
}
}
</style>
</head>