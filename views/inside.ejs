<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KTM 390 Duke R - BikeZone</title>

<style>
:root{
    --primary:#ff6600;
    --primary-dark:#e55a00;
    --bg:#f5f6fa;
    --card:#ffffff;
    --text:#222;
    --muted:#666;
    --border:#ececec;
    --shadow:0 8px 24px rgba(0,0,0,.08);
}

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Inter,Arial,sans-serif;
}

html{
    scroll-behavior:smooth;
}

body{
    background:var(--bg);
    color:var(--text);
}

header{
    position:sticky;
    top:0;
    z-index:999;
    background:rgba(255,255,255,.9);
    backdrop-filter:blur(10px);
    box-shadow:0 2px 12px rgba(0,0,0,.06);
}

.nav{
    max-width:1200px;
    margin:auto;
    padding:16px 20px;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.logo{
    font-size:24px;
    font-weight:800;
    color:var(--primary);
}

.theme-btn{
    border:none;
    background:#fff;
    padding:10px 14px;
    border-radius:10px;
    cursor:pointer;
    box-shadow:0 2px 8px rgba(0,0,0,.08);
}

.container{
    max-width:1200px;
    margin:auto;
    padding:20px;
}

.hero{
    display:grid;
    grid-template-columns:1.6fr 1fr;
    gap:24px;
    margin-top:20px;
}

.card{
    background:var(--card);
    border-radius:18px;
    padding:22px;
    box-shadow:var(--shadow);
}

.main-image{
    width:100%;
    height:450px;
    object-fit:cover;
    border-radius:14px;
    transition:.4s;
}

.thumbnail-row{
    display:flex;
    gap:10px;
    margin-top:12px;
}

.thumb{
    width:95px;
    height:65px;
    object-fit:cover;
    border-radius:10px;
    cursor:pointer;
    border:3px solid transparent;
}

.thumb.active{
    border-color:var(--primary);
}

.status-row{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:15px;
}

.badge{
    background:var(--primary);
    color:#fff;
    padding:8px 12px;
    border-radius:30px;
    font-size:12px;
    font-weight:700;
}

.stock{
    color:#16a34a;
    font-weight:700;
}

.purchase-card{
    position:sticky;
    top:90px;
    height:fit-content;
}

.bike-title{
    font-size:36px;
    margin-bottom:8px;
}

.rating{
    color:#f4b400;
    margin-bottom:15px;
}

.price{
    font-size:38px;
    font-weight:800;
}

.sub-price{
    color:var(--muted);
    margin-top:6px;
}

.colors{
    margin-top:20px;
}

.color-row{
    display:flex;
    gap:10px;
    margin-top:10px;
}

.color{
    width:28px;
    height:28px;
    border-radius:50%;
    cursor:pointer;
    border:3px solid white;
    box-shadow:0 0 0 1px #ddd;
}

.orange{background:#ff6600;}
.black{background:#111;}
.white{background:#fff;}

.btns{
    display:flex;
    gap:12px;
    margin-top:25px;
}

.btn{
    flex:1;
    padding:14px;
    border:none;
    border-radius:12px;
    cursor:pointer;
    font-weight:700;
    transition:.3s;
}

.primary{
    background:var(--primary);
    color:#fff;
}

.primary:hover{
    background:var(--primary-dark);
    transform:translateY(-2px);
}

.secondary{
    background:#eee;
}

.secondary:hover{
    background:#ddd;
}

.specs{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:15px;
    margin-top:25px;
}

.spec-box{
    background:#fff;
    padding:20px;
    border-radius:16px;
    text-align:center;
    box-shadow:var(--shadow);
}

.spec-value{
    color:var(--primary);
    font-size:28px;
    font-weight:800;
}

.spec-label{
    color:var(--muted);
    margin-top:8px;
}

.tabs{
    display:flex;
    flex-wrap:wrap;
    gap:12px;
    margin-top:35px;
}

.tab{
    border:none;
    background:#fff;
    padding:12px 20px;
    border-radius:12px;
    cursor:pointer;
    font-weight:600;
}

.tab.active{
    background:var(--primary);
    color:white;
}

.content-panel{
    display:none;
    margin-top:20px;
    animation:fade .35s ease;
}

.content-panel.active{
    display:block;
}

@keyframes fade{
    from{
        opacity:0;
        transform:translateY(10px);
    }
    to{
        opacity:1;
        transform:translateY(0);
    }
}

.feature-grid{
    display:grid;
    grid-template-columns:repeat(2,1fr);
    gap:15px;
}

.feature-item{
    background:white;
    padding:18px;
    border-radius:12px;
    box-shadow:var(--shadow);
}

.spec-table{
    width:100%;
    border-collapse:collapse;
    background:#fff;
    border-radius:16px;
    overflow:hidden;
    box-shadow:var(--shadow);
}

.spec-table td{
    padding:15px;
    border-bottom:1px solid #eee;
}

.review{
    background:#fff;
    padding:18px;
    border-radius:14px;
    box-shadow:var(--shadow);
    margin-bottom:15px;
}

.review-header{
    display:flex;
    gap:12px;
    align-items:center;
    margin-bottom:10px;
}

.avatar{
    width:50px;
    height:50px;
    border-radius:50%;
    background:var(--primary);
    color:white;
    display:flex;
    justify-content:center;
    align-items:center;
    font-weight:700;
}

.emi-box{
    background:#fff;
    padding:20px;
    border-radius:16px;
    box-shadow:var(--shadow);
}

label{
    display:block;
    margin-top:15px;
    margin-bottom:6px;
    font-weight:600;
}

input[type=range]{
    width:100%;
}

.emi-result{
    font-size:36px;
    font-weight:800;
    color:var(--primary);
    margin-top:15px;
}

.compare-table{
    width:100%;
    border-collapse:collapse;
    background:white;
    border-radius:16px;
    overflow:hidden;
    box-shadow:var(--shadow);
}

.compare-table td,
.compare-table th{
    padding:15px;
    border-bottom:1px solid #eee;
}

.footer{
    text-align:center;
    padding:50px;
    color:#777;
}

.reveal{
    opacity:0;
    transform:translateY(30px);
    transition:.6s;
}

.reveal.show{
    opacity:1;
    transform:translateY(0);
}

.dark{
    --bg:#111827;
    --card:#1f2937;
    --text:#f5f5f5;
    --muted:#cfcfcf;
    --border:#374151;
}

.dark .spec-box,
.dark .feature-item,
.dark .spec-table,
.dark .review,
.dark .emi-box,
.dark .tab{
    background:#1f2937;
}

.dark .secondary{
    background:#374151;
    color:white;
}

@media(max-width:900px){

.hero{
    grid-template-columns:1fr;
}

.purchase-card{
    position:static;
}

.specs{
    grid-template-columns:repeat(2,1fr);
}

.feature-grid{
    grid-template-columns:1fr;
}
}

@media(max-width:600px){

.specs{
    grid-template-columns:1fr;
}

.bike-title{
    font-size:30px;
}

.main-image{
    height:280px;
}
}
</style>

</head>
<body>

<header>
<div class="nav">
<div class="logo">BikeZone</div>
<button id="themeBtn" class="theme-btn">🌙</button>
</div>
</header>

<div class="container">

<div class="hero">

<div class="card reveal">

<img id="mainImage"
class="main-image"
src="https://images.unsplash.com/photo-1558981806-ec527fa84c39?w=1200"
alt="Bike">

<div class="thumbnail-row">

<img class="thumb active"
src="https://images.unsplash.com/photo-1558981806-ec527fa84c39?w=500">

<img class="thumb"
src="https://images.unsplash.com/photo-1503376780353-7e6692767b70?w=500">

<img class="thumb"
src="https://images.unsplash.com/photo-1511919884226-fd3cad34687c?w=500">

</div>

</div>

<div class="card purchase-card reveal">

<div class="status-row">
<span class="badge">🔥 Best Seller</span>
<span class="stock">● In Stock</span>
</div>

<h1 class="bike-title">KTM 390 Duke R</h1>

<div class="rating">
★★★★★ 4.8 (1,254 Reviews)
</div>

<div class="price">₹3.38 Lakh</div>
<div class="sub-price">Average Ex-Showroom Price</div>

<div class="colors">
<strong>Available Colors</strong>

<div class="color-row">
<div class="color orange"></div>
<div class="color black"></div>
<div class="color white"></div>
</div>
</div>

<div class="btns">
<button class="btn primary">Get Offers</button>
<button class="btn secondary">Book Test Ride</button>
</div>

</div>

</div>

<div class="specs">

<div class="spec-box reveal">
<div class="spec-value">399cc</div>
<div class="spec-label">Engine</div>
</div>

<div class="spec-box reveal">
<div class="spec-value">46 HP</div>
<div class="spec-label">Power</div>
</div>

<div class="spec-box reveal">
<div class="spec-value">39 Nm</div>
<div class="spec-label">Torque</div>
</div>

<div class="spec-box reveal">
<div class="spec-value">29 kmpl</div>
<div class="spec-label">Mileage</div>
</div>

</div>

<div class="tabs">
<button class="tab active" data-tab="overview">Overview</button>
<button class="tab" data-tab="specifications">Specifications</button>
<button class="tab" data-tab="features">Features</button>
<button class="tab" data-tab="reviews">Reviews</button>
<button class="tab" data-tab="compare">Compare</button>
</div>

<div class="content-panel active" id="overview">

<div class="card">
<h2>About KTM 390 Duke R</h2>
<br>
<p>
The KTM 390 Duke R is built for riders who want sharp handling,
aggressive styling, premium electronics and thrilling performance.
Its 399cc liquid-cooled engine delivers excellent power while advanced
rider aids improve safety and confidence.
</p>
</div>

<br>

<div class="emi-box">

<h2>EMI Calculator</h2>

<label>Loan Amount</label> <input id="loanAmountRange"
type="range"
min="100000"
max="500000"
step="10000"
value="338000">

<p id="loanText">₹338,000</p>

<label>Interest Rate (%)</label> <input id="rateRange"
type="range"
min="5"
max="15"
step="1"
value="9">

<p id="rateText">9%</p>

<label>Tenure (Months)</label> <input id="tenureRange"
type="range"
min="12"
max="84"
step="12"
value="60">

<p id="tenureText">60 Months</p>

<div class="emi-result" id="emiResult">₹7,110</div>

</div>

</div>

<div class="content-panel" id="specifications">

<table class="spec-table">
<tr><td>Engine</td><td>399cc Liquid Cooled</td></tr>
<tr><td>Power</td><td>46 HP</td></tr>
<tr><td>Torque</td><td>39 Nm</td></tr>
<tr><td>Gearbox</td><td>6-Speed</td></tr>
<tr><td>Fuel Tank</td><td>15 Litres</td></tr>
<tr><td>Weight</td><td>168 Kg</td></tr>
</table>

</div>

<div class="content-panel" id="features">

<div class="feature-grid">
<div class="feature-item">✅ TFT Digital Display</div>
<div class="feature-item">✅ Quick Shifter</div>
<div class="feature-item">✅ Ride Modes</div>
<div class="feature-item">✅ Dual Channel ABS</div>
<div class="feature-item">✅ Traction Control</div>
<div class="feature-item">✅ LED Lighting</div>
</div>

</div>

<div class="content-panel" id="reviews">

<div class="review">
<div class="review-header">
<div class="avatar">R</div>
<div>
<h3>Rahul Sharma</h3>
<small>Verified Buyer</small>
</div>
</div>
★★★★★
<p>Excellent performance and handling. One of the best bikes in this segment.</p>
</div>

<div class="review">
<div class="review-header">
<div class="avatar">A</div>
<div>
<h3>Amit Verma</h3>
<small>Verified Buyer</small>
</div>
</div>
★★★★☆
<p>Powerful engine and premium features. Mileage could be slightly better.</p>
</div>

</div>

<div class="content-panel" id="compare">

<table class="compare-table">
<tr>
<th>Bike</th>
<th>Power</th>
<th>Torque</th>
<th>Mileage</th>
</tr>

<tr>
<td>KTM 390 Duke</td>
<td>46 HP</td>
<td>39 Nm</td>
<td>29 kmpl</td>
</tr>

<tr>
<td>TVS Apache RTR 310</td>
<td>35 HP</td>
<td>28.7 Nm</td>
<td>30 kmpl</td>
</tr>

<tr>
<td>BMW G310R</td>
<td>34 HP</td>
<td>28 Nm</td>
<td>32 kmpl</td>
</tr>
</table>

</div>

</div>

<div class="footer">
© 2025 BikeZone. All Rights Reserved.
</div>

</div>

<script>

// Dark Mode

document.getElementById("themeBtn")
.addEventListener("click",()=>{
document.body.classList.toggle("dark");
});

// Gallery

const thumbs=document.querySelectorAll(".thumb");
const mainImage=document.getElementById("mainImage");

thumbs.forEach(thumb=>{

thumb.addEventListener("click",()=>{

mainImage.style.opacity="0";

setTimeout(()=>{
mainImage.src=thumb.src;
mainImage.style.opacity="1";
},200);

thumbs.forEach(t=>t.classList.remove("active"));
thumb.classList.add("active");

});

});

// Tabs

const tabs=document.querySelectorAll(".tab");
const panels=document.querySelectorAll(".content-panel");

tabs.forEach(tab=>{

tab.addEventListener("click",()=>{

tabs.forEach(t=>t.classList.remove("active"));
panels.forEach(p=>p.classList.remove("active"));

tab.classList.add("active");

document
.getElementById(tab.dataset.tab)
.classList.add("active");

});

});

// EMI Calculator

const loan=document.getElementById("loanAmountRange");
const rate=document.getElementById("rateRange");
const tenure=document.getElementById("tenureRange");

function calculateEMI(){

const principal=Number(loan.value);
const monthlyRate=Number(rate.value)/12/100;
const months=Number(tenure.value);

const emi=
principal*
monthlyRate*
Math.pow(1+monthlyRate,months)/
(Math.pow(1+monthlyRate,months)-1);

document.getElementById("loanText").innerText=
"₹"+principal.toLocaleString();

document.getElementById("rateText").innerText=
rate.value+"%";

document.getElementById("tenureText").innerText=
months+" Months";

document.getElementById("emiResult").innerText=
"₹"+Math.round(emi).toLocaleString();

}

loan.addEventListener("input",calculateEMI);
rate.addEventListener("input",calculateEMI);
tenure.addEventListener("input",calculateEMI);

calculateEMI();

// Scroll Reveal

const observer=new IntersectionObserver(entries=>{

entries.forEach(entry=>{

if(entry.isIntersecting){

entry.target.classList.add("show");

}

});

});

document
.querySelectorAll(".reveal")
.forEach(el=>observer.observe(el));

</script>

</body>
</html>
