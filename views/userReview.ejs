<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Bike Reviews Module</title>

<style>

/* ================= MODULE WRAPPER ================= */
.bike-reviews-module{
  width:60%;
  margin:20px auto;
  min-height:60vh;

  border:2px solid #d1d5db;
  border-radius:12px;
  padding:20px 15px;

  display:flex;
  flex-direction:column;
  box-sizing:border-box;

  --text:#111;
  --muted:#6b7280;
  --card:#ffffff;
}

/* DARK MODE */
html.dark .bike-reviews-module{
  --text:#e5e7eb;
  --muted:#9ca3af;
  --card:#1f2937;
  border-color:#ffffff;
}

/* GLOBAL TEXT INSIDE MODULE ONLY */
.bike-reviews-module,
.bike-reviews-module *{
  color:var(--text);
}

/* HEADER */
.bike-reviews-module h2{
  margin-bottom:5px;
}

/* SUBTEXT */
.bike-reviews-module .subtext{
  color:var(--muted);
  font-size:14px;
  margin-bottom:10px;
}

/* SEARCH */
.bike-reviews-module .search-bar{
  width:60%;
  padding:12px;
  border-radius:8px;
  border:1px solid #ccc;
  margin-bottom:10px;
}

/* LABEL */
.bike-reviews-module .recent{
  font-weight:bold;
  margin-bottom:10px;
}

/* GRID (3x2 auto grow) */
.bike-reviews-module .review-list{
  flex:1;
  display:grid;
  grid-template-columns:repeat(3,1fr);
  grid-auto-rows:minmax(180px,auto);
  gap:12px;
}

/* CARD */
.bike-reviews-module .review-card{
  background:var(--card);
  border:1px solid #e5e7eb;
  border-radius:12px;
  padding:12px;
  box-sizing:border-box;

  display:flex;
  flex-direction:column;
  justify-content:space-between;
}

/* TOP */
.bike-reviews-module .top{
  display:flex;
  align-items:center;
  gap:10px;
}

.bike-reviews-module .avatar{
  width:40px;
  height:40px;
  border-radius:50%;
}

/* TEXT */
.bike-reviews-module .preview{
  font-size:13px;
  margin:8px 0;
  color:var(--muted);
}

/* BUTTON */
.bike-reviews-module .expand-btn{
  background:#007bff;
  color:white;
  border:none;
  padding:6px 10px;
  border-radius:6px;
  cursor:pointer;
  font-size:12px;
}

/* ================= MODAL ================= */
.review-modal{
  position:fixed;
  top:0;
  left:0;
  width:100%;
  height:100%;

  display:none;
  justify-content:center;
  align-items:center;

  background:rgba(0,0,0,0.6);
  z-index:9999;
}

.review-modal-box{
  width:60vw;
  height:60vh;

  background:#fff;
  border-radius:12px;
  padding:20px;

  position:relative;
  overflow-y:auto;
}

/* DARK MODE MODAL */
html.dark .review-modal-box{
  background:#1f2937;
  color:#e5e7eb;
}

.close-modal{
  position:absolute;
  top:10px;
  right:15px;
  font-size:24px;
  cursor:pointer;
}

</style>
</head>

<body>

<!-- ================= MODULE ================= -->
<section class="bike-reviews-module">

  <h2>Owner Reviews</h2>

  <p class="subtext">
    Verified bike owners sharing real-world pros and cons.
  </p>

  <input class="search-bar" placeholder="Search bike model..." />

  <div class="recent">Recent Reviews</div>

  <div class="review-list">

    <div class="review-card">
      <div class="top">
        <img src="https://i.pravatar.cc/100?img=1" class="avatar">
        <div>
          <h4>Rahul Sharma</h4>
          <span>Classic 350</span>
        </div>
      </div>

      <p class="preview">Great highway stability and comfort.</p>

      <button class="expand-btn"
        onclick="openModal('Rahul Sharma','Classic 350','Excellent highway stability, very comfortable on long rides but slightly heavy in city traffic.')">
        See Full Review
      </button>
    </div>

    <div class="review-card">
      <div class="top">
        <img src="https://i.pravatar.cc/100?img=5" class="avatar">
        <div>
          <h4>Amit Verma</h4>
          <span>Yamaha R15</span>
        </div>
      </div>

      <p class="preview">Perfect beginner sports bike.</p>

      <button class="expand-btn"
        onclick="openModal('Amit Verma','Yamaha R15','Sharp design, great handling, but riding posture is aggressive for long trips.')">
        See Full Review
      </button>
    </div>

    <div class="review-card">
      <div class="top">
        <img src="https://i.pravatar.cc/100?img=8" class="avatar">
        <div>
          <h4>Vikram Singh</h4>
          <span>Apache RTR</span>
        </div>
      </div>

      <p class="preview">Excellent mileage in city.</p>

      <button class="expand-btn"
        onclick="openModal('Vikram Singh','Apache RTR','Very fuel efficient, smooth in traffic, and low maintenance cost.')">
        See Full Review
      </button>
    </div>

  </div>
</section>

<!-- ================= MODAL ================= -->
<div class="review-modal" id="reviewModal">
  <div class="review-modal-box">

    <span class="close-modal" onclick="closeModal()">×</span>

    <h3 id="modalName"></h3>
    <p id="modalBike"></p>
    <hr style="margin:10px 0;">
    <p id="modalText"></p>

  </div>
</div>

<!-- ================= SCRIPT ================= -->
<script>

function openModal(name, bike, text) {
  document.getElementById("reviewModal").style.display = "flex";

  document.getElementById("modalName").innerText = name;
  document.getElementById("modalBike").innerText = bike;
  document.getElementById("modalText").innerText = text;
}

function closeModal() {
  document.getElementById("reviewModal").style.display = "none";
}

</script>

</body>
</html>