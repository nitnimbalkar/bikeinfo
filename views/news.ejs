<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>Latest Updates</title>

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

:root{
  --bg:#ffffff;
  --text:#111111;
  --border:#d8d8d8;
  --tab-bg:#f4f4f4;
  --active:#111111;
  --active-text:#ffffff;
}

body.dark{
  --bg:#0f0f0f;
  --text:#f5f5f5;
  --border:#343434;
  --tab-bg:#1b1b1b;
  --active:#ffffff;
  --active-text:#111111;
}

body{
  background:var(--bg);
  color:var(--text);
  font-family:Inter,sans-serif;
  display:flex;
  justify-content:center;
  padding:50px 20px;
}

/* MODULE */
.updates-module{
  width:60%;
  height:820px;
  border:1px solid var(--border);
  border-radius:22px;
  padding:26px;

  display:flex;
  flex-direction:column;
  overflow:hidden;
  position:relative;
}

/* HEADER */
.heading{
  font-size:34px;
  font-weight:700;
  margin-bottom:20px;
}

/* TABS */
.tabs{
  display:flex;
  gap:12px;
  margin-bottom:18px;
}

.tab-btn{
  padding:10px 18px;
  border-radius:10px;
  border:1px solid var(--border);
  background:var(--tab-bg);
  color:var(--text);
  cursor:pointer;
  font-weight:600;
}

.tab-btn.active{
  background:var(--active);
  color:var(--active-text);
}

/* CONTENT */
.tab-content{
  display:none;
  flex:1;
  overflow:auto;
  padding-right:6px;
}

.tab-content.active{
  display:block;
}

/* GRID */
.cards{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:20px;
}

/* CARD */
.card{
  border:1px solid var(--border);
  border-radius:18px;
  overflow:hidden;
  height:460px;
  display:flex;
  flex-direction:column;
  cursor:pointer;
  transition:.2s ease;
}

.card:hover{
  transform:scale(1.02);
}

/* IMAGE */
.card-image{
  width:100%;
  height:210px;
  object-fit:cover;
  border-bottom:1px solid var(--border);
}

/* VIDEO */
.video-wrapper{
  width:100%;
  height:210px;
  border-bottom:1px solid var(--border);
}

.video-wrapper iframe{
  width:100%;
  height:100%;
}

/* CONTENT */
.card-content{
  padding:20px;
  display:flex;
  flex-direction:column;
  flex:1;
}

.card-tag{
  font-size:12px;
  text-transform:uppercase;
  opacity:.7;
  margin-bottom:10px;
  font-weight:700;
}

.card-title{
  font-size:22px;
  font-weight:700;
  margin-bottom:10px;
}

.card-desc{
  font-size:15px;
  line-height:1.6;
  opacity:.82;
}

/* ===================== */
/* POPUP MODAL */
/* ===================== */

.modal{
  position:fixed;
  top:0;
  left:0;
  width:100%;
  height:100%;
  display:none;
  justify-content:center;
  align-items:center;
  background:rgba(0,0,0,0.6);
  backdrop-filter:blur(6px);
  z-index:999;
}

.modal.active{
  display:flex;
}

.modal-box{
  width:70%;               /* 70% of screen/module feel */
  height:70vh;
  background:var(--bg);
  border:1px solid var(--border);
  border-radius:18px;
  padding:24px;
  overflow:auto;
  position:relative;
}

/* CLOSE BUTTON */
.close-btn{
  position:absolute;
  top:10px;
  right:15px;
  font-size:22px;
  cursor:pointer;
}

/* MODAL CONTENT */
.modal-title{
  font-size:28px;
  font-weight:700;
  margin-bottom:12px;
}

.modal-text{
  font-size:16px;
  line-height:1.7;
  opacity:.85;
}

/* RESPONSIVE */
@media(max-width:900px){
  .updates-module{
    width:95%;
    height:auto;
  }

  .cards{
    grid-template-columns:1fr;
  }

  .card{
    height:auto;
  }

  .modal-box{
    width:90%;
    height:80vh;
  }
}

</style>
</head>

<body>

<div class="updates-module">

  <div class="heading">Latest Updates</div>

  <!-- TABS -->
  <div class="tabs">
    <button class="tab-btn active" data-tab="news">News</button>
    <button class="tab-btn" data-tab="reviews">Expert Reviews</button>
    <button class="tab-btn" data-tab="videos">Videos</button>
  </div>

  <!-- NEWS -->
  <div class="tab-content active" id="news">

    <div class="cards">

      <div class="card" onclick="openModal('News 1','Full detailed breakdown of product launch happening this week. Includes features, roadmap and expected impact on users.')">
        <img class="card-image" src="https://images.unsplash.com/photo-1495020689067-958852a7765e?q=80&w=1200&auto=format&fit=crop">
        <div class="card-content">
          <div class="card-tag">News</div>
          <div class="card-title">Product Launch This Week</div>
          <div class="card-desc">Latest announcements and updates from the industry.</div>
        </div>
      </div>

      <div class="card" onclick="openModal('News 2','Global rollout has started with early users testing performance improvements and UI redesign.')">
        <img class="card-image" src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?q=80&w=1200&auto=format&fit=crop">
        <div class="card-content">
          <div class="card-tag">News</div>
          <div class="card-title">Global Rollout Begins</div>
          <div class="card-desc">Users testing new improvements worldwide.</div>
        </div>
      </div>

      <div class="card" onclick="openModal('News 3','Community feedback is increasing rapidly with discussions across social platforms and forums.')">
        <img class="card-image" src="https://images.unsplash.com/photo-1520607162513-77705c0f0d4a?q=80&w=1200&auto=format&fit=crop">
        <div class="card-content">
          <div class="card-tag">News</div>
          <div class="card-title">Community Reactions</div>
          <div class="card-desc">User feedback growing rapidly.</div>
        </div>
      </div>

    </div>
  </div>

  <!-- REVIEWS -->
  <div class="tab-content" id="reviews">

    <div class="cards">

      <div class="card" onclick="openModal('Review 1','Experts praise the new UI design for better usability, accessibility and visual clarity.')">
        <img class="card-image" src="https://images.unsplash.com/photo-1516321497487-e288fb19713f?q=80&w=1200&auto=format&fit=crop">
        <div class="card-content">
          <div class="card-tag">Expert Reviews</div>
          <div class="card-title">Interface Design</div>
          <div class="card-desc">Clean UI and usability improvements.</div>
        </div>
      </div>

      <div class="card" onclick="openModal('Review 2','Performance improvements show faster loading, smoother navigation and better stability.')">
        <img class="card-image" src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?q=80&w=1200&auto=format&fit=crop">
        <div class="card-content">
          <div class="card-tag">Expert Reviews</div>
          <div class="card-title">Performance Boost</div>
          <div class="card-desc">Speed and stability improvements.</div>
        </div>
      </div>

      <div class="card" onclick="openModal('Review 3','Experts discuss long term scalability and product roadmap potential.')">
        <img class="card-image" src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=1200&auto=format&fit=crop">
        <div class="card-content">
          <div class="card-tag">Expert Reviews</div>
          <div class="card-title">Future Scope</div>
          <div class="card-desc">Roadmap and scalability discussion.</div>
        </div>
      </div>

    </div>
  </div>

  <!-- VIDEOS -->
  <div class="tab-content" id="videos">

    <div class="cards">

      <div class="card">
        <div class="video-wrapper">
          <iframe src="https://www.youtube.com/embed/dQw4w9WgXcQ" allowfullscreen></iframe>
        </div>
        <div class="card-content">
          <div class="card-tag">Video</div>
          <div class="card-title">Walkthrough</div>
          <div class="card-desc">Full product overview.</div>
        </div>
      </div>

      <div class="card">
        <div class="video-wrapper">
          <iframe src="https://www.youtube.com/embed/ysz5S6PUM-U" allowfullscreen></iframe>
        </div>
        <div class="card-content">
          <div class="card-tag">Video</div>
          <div class="card-title">Behind Scenes</div>
          <div class="card-desc">Development insights.</div>
        </div>
      </div>

      <div class="card">
        <div class="video-wrapper">
          <iframe src="https://www.youtube.com/embed/jNQXAC9IVRw" allowfullscreen></iframe>
        </div>
        <div class="card-content">
          <div class="card-tag">Video</div>
          <div class="card-title">Tutorials</div>
          <div class="card-desc">Quick productivity tips.</div>
        </div>
      </div>

    </div>

  </div>

</div>

<!-- MODAL -->
<div class="modal" id="modal">

  <div class="modal-box">

    <div class="close-btn" onclick="closeModal()">×</div>

    <div class="modal-title" id="modalTitle"></div>
    <div class="modal-text" id="modalText"></div>

  </div>

</div>

<script>

const tabs = document.querySelectorAll(".tab-btn");
const contents = document.querySelectorAll(".tab-content");

tabs.forEach(tab=>{
  tab.addEventListener("click",()=>{

    tabs.forEach(t=>t.classList.remove("active"));
    contents.forEach(c=>c.classList.remove("active"));

    tab.classList.add("active");
    document.getElementById(tab.dataset.tab).classList.add("active");

  });
});

function openModal(title,text){
  document.getElementById("modalTitle").innerText = title;
  document.getElementById("modalText").innerText = text;
  document.getElementById("modal").classList.add("active");
}

function closeModal(){
  document.getElementById("modal").classList.remove("active");
}

document.getElementById("modal").addEventListener("click",(e)=>{
  if(e.target.id==="modal") closeModal();
});

</script>

</body>
</html>