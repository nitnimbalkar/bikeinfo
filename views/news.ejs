<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>Latest Updates</title>

<style>

/* ================= BASE ================= */

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

:root{
  --bg:#ffffff;
  --text:#111111;
  --border:#d8d8d8;
  --tab-bg:#f4f4f4;
  --active:#111111;
  --active-text:#ffffff;
}

body.dark{
  --bg:#0f0f0f;
  --text:#f5f5f5;
  --border:#343434;
  --tab-bg:#1b1b1b;
  --active:#ffffff;
  --active-text:#111111;
}

body{
  background:var(--bg);
  color:var(--text);
  font-family:Inter,sans-serif;
  display:flex;
  justify-content:center;
  padding:50px 20px;
}

/* ================= MODULE ================= */

.updates-module{
  width:60%;
  height:820px;
  border:1px solid var(--border);
  border-radius:22px;
  padding:26px;

  display:flex;
  flex-direction:column;
  overflow:hidden;
}

.heading{
  font-size:34px;
  font-weight:700;
  margin-bottom:20px;
}

/* ================= TABS ================= */

.tabs{
  display:flex;
  gap:12px;
  margin-bottom:18px;
}

.tab-btn{
  padding:10px 18px;
  border-radius:10px;
  border:1px solid var(--border);
  background:var(--tab-bg);
  color:var(--text);
  cursor:pointer;
  font-weight:600;
}

.tab-btn.active{
  background:var(--active);
  color:var(--active-text);
}

/* ================= CONTENT ================= */

.tab-content{
  display:none;
  flex:1;
  overflow:auto;
  padding-right:6px;
}

.tab-content.active{
  display:block;
}

/* ================= CARDS ================= */

.cards{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:20px;
}

.card{
  border:1px solid var(--border);
  border-radius:18px;
  overflow:hidden;
  height:460px;
  display:flex;
  flex-direction:column;
  cursor:pointer;
  transition:.2s ease;
}

.card:hover{
  transform:scale(1.02);
}

.card-image{
  width:100%;
  height:210px;
  object-fit:cover;
  border-bottom:1px solid var(--border);
}

.card-content{
  padding:20px;
  display:flex;
  flex-direction:column;
  flex:1;
}

.card-tag{
  font-size:12px;
  text-transform:uppercase;
  opacity:.7;
  margin-bottom:10px;
  font-weight:700;
}

.card-title{
  font-size:22px;
  font-weight:700;
  margin-bottom:10px;
}

.card-desc{
  font-size:15px;
  line-height:1.6;
  opacity:.82;
}

/* ================= VIDEO ================= */

.video-wrapper{
  width:100%;
  height:210px;
  border-bottom:1px solid var(--border);
}

.video-wrapper iframe{
  width:100%;
  height:100%;
}

/* ================= MODAL ================= */

.modal{
  position:fixed;
  inset:0;
  display:none;
  justify-content:center;
  align-items:center;
  background:rgba(0,0,0,0.6);
  backdrop-filter:blur(6px);
  z-index:999;
}

.modal.active{
  display:flex;
}

/* 70% MODAL */
.modal-box{
  width:70%;
  max-height:85vh;
  background:var(--bg);
  border:1px solid var(--border);
  border-radius:18px;
  overflow:auto;
  position:relative;
  padding-bottom:20px;
}

/* CLOSE */
.close-btn{
  position:absolute;
  top:10px;
  right:15px;
  font-size:22px;
  cursor:pointer;
}

/* MODAL IMAGE */
.modal-img{
  width:100%;
  height:300px;
  object-fit:cover;
}

/* MODAL CONTENT */
.modal-content{
  padding:24px;
  display:flex;
  flex-direction:column;
  gap:14px;
}

.modal-title{
  font-size:28px;
  font-weight:700;
}

.modal-text{
  font-size:16px;
  line-height:1.7;
  opacity:.85;
}

/* ================= RESPONSIVE ================= */

@media(max-width:900px){

  .updates-module{
    width:95%;
    height:auto;
  }

  .cards{
    grid-template-columns:1fr;
  }

  .card{
    height:auto;
  }

  .modal-box{
    width:90%;
    height:80vh;
  }

  .modal-img{
    height:220px;
  }
}

</style>
</head>

<body>

<div class="updates-module">

  <div class="heading">Latest Updates</div>

  <!-- TABS -->
  <div class="tabs">
    <button class="tab-btn active" data-tab="news">News</button>
    <button class="tab-btn" data-tab="reviews">Expert Reviews</button>
    <button class="tab-btn" data-tab="videos">Videos</button>
  </div>

  <!-- NEWS -->
  <div class="tab-content active" id="news">

    <div class="cards">

      <div class="card"
        onclick="openModal(
          'Product Launch This Week',
          'https://images.unsplash.com/photo-1495020689067-958852a7765e?q=80&w=1200&auto=format&fit=crop',
          'Full breakdown of the upcoming product launch with new features, roadmap, and impact analysis.'
        )">
        <img class="card-image" src="https://images.unsplash.com/photo-1495020689067-958852a7765e?q=80&w=1200&auto=format&fit=crop">
        <div class="card-content">
          <div class="card-tag">News</div>
          <div class="card-title">Product Launch This Week</div>
          <div class="card-desc">Latest announcements and updates.</div>
        </div>
      </div>

      <div class="card"
        onclick="openModal(
          'Global Rollout Begins',
          'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?q=80&w=1200&auto=format&fit=crop',
          'Early rollout has started globally with performance improvements and UI redesign being tested.'
        )">
        <img class="card-image" src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?q=80&w=1200&auto=format&fit=crop">
        <div class="card-content">
          <div class="card-tag">News</div>
          <div class="card-title">Global Rollout Begins</div>
          <div class="card-desc">Users testing new improvements.</div>
        </div>
      </div>

      <div class="card"
        onclick="openModal(
          'Community Reactions',
          'https://images.unsplash.com/photo-1520607162513-77705c0f0d4a?q=80&w=1200&auto=format&fit=crop',
          'Community engagement is rapidly increasing with discussions and feedback across platforms.'
        )">
        <img class="card-image" src="https://images.unsplash.com/photo-1520607162513-77705c0f0d4a?q=80&w=1200&auto=format&fit=crop">
        <div class="card-content">
          <div class="card-tag">News</div>
          <div class="card-title">Community Reactions</div>
          <div class="card-desc">User feedback growing rapidly.</div>
        </div>
      </div>

    </div>
  </div>

  <!-- REVIEWS -->
  <div class="tab-content" id="reviews">

    <div class="cards">

      <div class="card"
        onclick="openModal(
          'Interface Design Review',
          'https://images.unsplash.com/photo-1516321497487-e288fb19713f?q=80&w=1200&auto=format&fit=crop',
          'Experts highlight improved usability, clean UI and better accessibility across the platform.'
        )">
        <img class="card-image" src="https://images.unsplash.com/photo-1516321497487-e288fb19713f?q=80&w=1200&auto=format&fit=crop">
        <div class="card-content">
          <div class="card-tag">Expert Reviews</div>
          <div class="card-title">Interface Design</div>
          <div class="card-desc">Clean UI improvements.</div>
        </div>
      </div>

      <div class="card"
        onclick="openModal(
          'Performance Boost Review',
          'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?q=80&w=1200&auto=format&fit=crop',
          'Performance upgrades result in faster loading, smoother navigation and improved stability.'
        )">
        <img class="card-image" src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?q=80&w=1200&auto=format&fit=crop">
        <div class="card-content">
          <div class="card-tag">Expert Reviews</div>
          <div class="card-title">Performance Boost</div>
          <div class="card-desc">Speed improvements tested.</div>
        </div>
      </div>

      <div class="card"
        onclick="openModal(
          'Future Scope Review',
          'https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=1200&auto=format&fit=crop',
          'Experts discuss scalability, roadmap direction and long-term platform evolution.'
        )">
        <img class="card-image" src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=1200&auto=format&fit=crop">
        <div class="card-content">
          <div class="card-tag">Expert Reviews</div>
          <div class="card-title">Future Scope</div>
          <div class="card-desc">Roadmap discussion.</div>
        </div>
      </div>

    </div>
  </div>

  <!-- VIDEOS -->
  <div class="tab-content" id="videos">

    <div class="cards">

      <div class="card">
        <div class="video-wrapper">
          <iframe src="https://www.youtube.com/embed/dQw4w9WgXcQ" allowfullscreen></iframe>
        </div>
        <div class="card-content">
          <div class="card-tag">Video</div>
          <div class="card-title">Walkthrough</div>
          <div class="card-desc">Full product overview.</div>
        </div>
      </div>

      <div class="card">
        <div class="video-wrapper">
          <iframe src="https://www.youtube.com/embed/ysz5S6PUM-U" allowfullscreen></iframe>
        </div>
        <div class="card-content">
          <div class="card-tag">Video</div>
          <div class="card-title">Behind Scenes</div>
          <div class="card-desc">Development insights.</div>
        </div>
      </div>

      <div class="card">
        <div class="video-wrapper">
          <iframe src="https://www.youtube.com/embed/jNQXAC9IVRw" allowfullscreen></iframe>
        </div>
        <div class="card-content">
          <div class="card-tag">Video</div>
          <div class="card-title">Tutorials</div>
          <div class="card-desc">Quick tips and guides.</div>
        </div>
      </div>

    </div>

  </div>

</div>

<!-- MODAL -->
<div class="modal" id="modal">

  <div class="modal-box">

    <div class="close-btn" onclick="closeModal()">×</div>

    <img id="modalImg" class="modal-img"/>

    <div class="modal-content">
      <div id="modalTitle" class="modal-title"></div>
      <div id="modalText" class="modal-text"></div>
    </div>

  </div>

</div>

<script>

/* TABS */
const tabs = document.querySelectorAll(".tab-btn");
const contents = document.querySelectorAll(".tab-content");

tabs.forEach(tab=>{
  tab.addEventListener("click",()=>{
    tabs.forEach(t=>t.classList.remove("active"));
    contents.forEach(c=>c.classList.remove("active"));

    tab.classList.add("active");
    document.getElementById(tab.dataset.tab).classList.add("active");
  });
});

/* MODAL */
function openModal(title,img,text){
  document.getElementById("modalTitle").innerText = title;
  document.getElementById("modalImg").src = img;
  document.getElementById("modalText").innerText = text;
  document.getElementById("modal").classList.add("active");
}

function closeModal(){
  document.getElementById("modal").classList.remove("active");
}

document.getElementById("modal").addEventListener("click",(e)=>{
  if(e.target.id==="modal") closeModal();
});

</script>

</body>
</html>