<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>UFM Updates Module</title>

<style>

/* =========================================================
   ROOT VARIABLES
========================================================= */

:root{
  --ufm-bg:#ffffff;
  --ufm-text:#111111;
  --ufm-border:#d9d9d9;
  --ufm-tab-bg:#f4f4f4;
  --ufm-active:#111111;
  --ufm-active-text:#ffffff;
}

html.dark{
  --ufm-bg:#0f0f0f;
  --ufm-text:#f5f5f5;
  --ufm-border:#343434;
  --ufm-tab-bg:#1b1b1b;
  --ufm-active:#ffffff;
  --ufm-active-text:#111111;
}

/* =========================================================
   BODY LOCK
========================================================= */

body.ufm-body-lock{
  overflow:hidden;
}

/* =========================================================
   MODULE WRAPPER
========================================================= */

.ufm-module-wrapper{
  width:100%;
  display:flex;
  justify-content:center;
  padding:40px 20px;
  background:var(--ufm-bg);
  color:var(--ufm-text);
  font-family:Inter,sans-serif;
  box-sizing:border-box;
}

/* =========================================================
   MODULE
========================================================= */

.ufm-module{
  width:min(1200px,60%);
  height:60vh;
  min-height:650px;
  border:1px solid var(--ufm-border);
  border-radius:24px;
  padding:28px;
  display:flex;
  flex-direction:column;
  overflow:hidden;
  background:var(--ufm-bg);
  isolation:isolate;
  box-sizing:border-box;
}

/* =========================================================
   HEADING
========================================================= */

.ufm-heading{
  font-size:34px;
  font-weight:700;
  margin-bottom:24px;
  flex-shrink:0;
}

/* =========================================================
   TABS
========================================================= */

.ufm-tabs{
  display:flex;
  gap:12px;
  flex-wrap:wrap;
  margin-bottom:24px;
  flex-shrink:0;
}

.ufm-tab-btn{
  border:none;
  outline:none;
  cursor:pointer;
  padding:12px 18px;
  border-radius:12px;
  background:var(--ufm-tab-bg);
  color:var(--ufm-text);
  font-weight:600;
  transition:.25s ease;
  border:1px solid var(--ufm-border);
}

.ufm-tab-btn:hover{
  transform:translateY(-2px);
}

.ufm-tab-btn.ufm-active{
  background:var(--ufm-active);
  color:var(--ufm-active-text);
}

/* =========================================================
   CONTENT
========================================================= */

.ufm-tab-content{
  display:none;
  animation:ufmFade .3s ease;
  flex:1;
  overflow:hidden;
  min-height:0;
}

.ufm-tab-content.ufm-active{
  display:flex;
}

@keyframes ufmFade{
  from{
    opacity:0;
    transform:translateY(8px);
  }
  to{
    opacity:1;
    transform:translateY(0);
  }
}

/* =========================================================
   CARD CONTAINER
========================================================= */

.ufm-cards{
  display:grid;
  grid-auto-flow:column;
  grid-auto-columns:minmax(220px,1fr);
  gap:18px;

  width:100%;
  max-width:100%;

  overflow-x:auto;
  overflow-y:hidden;

  padding-bottom:10px;

  scroll-behavior:smooth;

  box-sizing:border-box;
}
.ufm-cards::-webkit-scrollbar{
  height:8px;
}

.ufm-cards::-webkit-scrollbar-thumb{
  background:#8884;
  border-radius:20px;
}

/* =========================================================
   CARD
========================================================= */

.ufm-card{
  border:1px solid var(--ufm-border);
  border-radius:20px;
  overflow:hidden;
  background:var(--ufm-bg);
  cursor:pointer;
  transition:
    transform .25s ease,
    box-shadow .25s ease;
  display:flex;
  flex-direction:column;
  outline:none;
  height:100%;
}

.ufm-card:hover,
.ufm-card:focus{
  transform:translateY(-6px);
  box-shadow:0 14px 30px rgba(0,0,0,.12);
}

.ufm-card-image{
  width:100%;
  height:180px;
  object-fit:cover;
  display:block;
  flex-shrink:0;
}

.ufm-card-content{
  padding:22px;
  display:flex;
  flex-direction:column;
  gap:10px;
  flex:1;
}

.ufm-card-tag{
  font-size:12px;
  text-transform:uppercase;
  font-weight:700;
  opacity:.65;
  letter-spacing:.08em;
}

.ufm-card-title{
  font-size:24px;
  font-weight:700;
  line-height:1.3;
}

.ufm-card-desc{
  font-size:15px;
  line-height:1.7;
  opacity:.82;
}

/* =========================================================
   MODAL
========================================================= */

.ufm-modal{
  position:fixed;
  inset:0;
  width:100%;
  height:100%;
  background:rgba(0,0,0,.65);
  display:none;
  align-items:center;
  justify-content:center;
  z-index:999999;
  padding:20px;
  box-sizing:border-box;
}

.ufm-modal.ufm-active{
  display:flex;
}

.ufm-modal-box{
  width:min(900px,100%);
  max-height:90vh;
  overflow:auto;
  border-radius:22px;
  background:var(--ufm-bg);
  border:1px solid var(--ufm-border);
  position:relative;
  animation:ufmModalIn .28s ease;
}

@keyframes ufmModalIn{
  from{
    opacity:0;
    transform:scale(.92);
  }
  to{
    opacity:1;
    transform:scale(1);
  }
}

.ufm-close-btn{
  position:absolute;
  top:14px;
  right:14px;
  width:42px;
  height:42px;
  border-radius:50%;
  background:rgba(255,255,255,.12);
  backdrop-filter:blur(6px);
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:28px;
  cursor:pointer;
  color:white;
  z-index:20;
}

.ufm-modal-img{
  width:100%;
  height:320px;
  object-fit:cover;
  display:block;
}

.ufm-modal-content{
  padding:28px;
}

.ufm-modal-title{
  font-size:30px;
  font-weight:700;
  margin-bottom:14px;
}

.ufm-modal-text{
  font-size:16px;
  line-height:1.8;
  opacity:.85;
}

/* =========================================================
   VIDEO
========================================================= */

.ufm-video-container{
  width:100%;
  aspect-ratio:16/9;
  display:none;
  background:black;
}

.ufm-video-container iframe{
  width:100%;
  height:100%;
  border:none;
  display:block;
}

.ufm-modal-box.ufm-video-mode .ufm-modal-img,
.ufm-modal-box.ufm-video-mode .ufm-modal-content{
  display:none;
}

.ufm-modal-box.ufm-video-mode .ufm-video-container{
  display:block;
}

/* =========================================================
   RESPONSIVE
========================================================= */

@media(max-width:900px){

  .ufm-module-wrapper{
    padding:20px 14px;
  }

  .ufm-module{
    height:auto;
    min-height:auto;
    padding:20px;
  }

  .ufm-heading{
    font-size:28px;
  }

  .ufm-cards{
    grid-auto-columns:85%;
  }

  .ufm-card-image{
    height:200px;
  }

  .ufm-modal-img{
    height:220px;
  }

  .ufm-modal-content{
    padding:22px;
  }

}

</style>
</head>

