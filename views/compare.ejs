<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bike Compare</title>

<style>
:root{
  --primary:#ff6b00;
  --bg:#f5f7fb;
  --card:#fff;
  --border:#e5e7eb;
  --text:#1f2937;
  --success:#dcfce7;
}

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:Inter,Arial,sans-serif;
}

body{
  background:var(--bg);
  color:var(--text);
}

.container{
    width:60%;
    min-width:900px;
    margin:40px auto;
}

@media (max-width:1200px){
    .container{
        width:80%;
        min-width:auto;
    }
}

@media (max-width:768px){
    .container{
        width:95%;
    }
}

h1{
  margin-bottom:20px;
}

.bike-grid{
    display:grid;
    grid-template-columns:repeat(5,1fr);
    gap:16px;
    margin-bottom:24px;
}

.bike-card{
  min-width:260px;
  background:var(--card);
  border-radius:18px;
  overflow:hidden;
  box-shadow:0 8px 20px rgba(0,0,0,.08);
  position:relative;
}

.bike-card img{
    width:100%;
    height:100px;
    object-fit:cover;
}

.card-content{
  padding:12px;
}

.bike-name{
  font-size:14px;
  font-weight:700;
  margin-bottom:8px;
}

.price{
  color:var(--primary);
  font-weight:700;
  font-size: 13px;
}

.remove-btn{
  position:absolute;
  top:10px;
  right:10px;
  width:32px;
  height:32px;
  border:none;
  border-radius:50%;
  background:#ef4444;
  color:white;
  cursor:pointer;
}

.add-card{
    height:220px;
    max-width: 200px;
    border:2px dashed #d1d5db;
    border-radius:16px;
    display:flex;
    align-items:center;
    justify-content:center;
    cursor:pointer;
    background:#fff;
}

.add-card:hover{
  border-color:var(--primary);
}

.plus{
  font-size:42px;
  color:var(--primary);
}

.compare-box{
  margin-top:30px;
  background:white;
  border-radius:20px;
  overflow-x:auto;
  box-shadow:0 8px 20px rgba(0,0,0,.08);
}

table{
  width:100%;
  min-width:900px;
  border-collapse:collapse;
}

th,td{
  padding:18px;
  text-align:center;
  border-bottom:1px solid #eee;
}

th{
  background:#fafafa;
}

.spec{
  text-align:left;
  font-weight:700;
  background:#fafafa;
  width:220px;
}

.best{
  background:var(--success);
  font-weight:700;
}

.modal{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.6);
  display:none;
  justify-content:center;
  align-items:center;
}

.modal-content{
  width:90%;
  max-width:500px;
  background:white;
  padding:25px;
  border-radius:18px;
}

.modal h2{
  margin-bottom:15px;
}

select{
  width:100%;
  padding:14px;
  border-radius:10px;
  border:1px solid #ddd;
}

.modal-buttons{
  margin-top:20px;
  display:flex;
  gap:10px;
}

button{
  border:none;
  padding:12px 20px;
  border-radius:10px;
  cursor:pointer;
}

.primary{
  background:var(--primary);
  color:white;
}

.secondary{
  background:#e5e7eb;
}

@media(max-width:768px){
  .bike-card,
  .add-card{
      min-width:220px;
  }
}
.page-layout{
    display:grid;
    grid-template-columns:60% 40%;
    gap:24px;
    max-width:1600px;
    margin:auto;
    padding:30px;
}

.compare-section{
    width:100%;
}

.sidebar{
    width:100%;
}
</style>
</head>
<body>

<div class="container">

<h1>🏍 Compare Bikes</h1>

<div class="bike-grid" id="bikeGrid"></div>

<div class="compare-box">
<table id="compareTable"></table>
</div>

</div>

<div class="modal" id="modal">
<div class="modal-content">

<h2>Select Bike</h2>

<select id="bikeSelect"></select>

<div class="modal-buttons">
<button class="primary" onclick="addBike()">Add Bike</button>
<button class="secondary" onclick="closeModal()">Cancel</button>
</div>

</div>
</div>
<div class="page-layout">

    <div class="compare-section">
        <!-- Bike compare cards + table -->
    </div>

    <aside class="sidebar">
        <!-- Related bikes -->
        <!-- Popular comparisons -->
        <!-- Ads -->
    </aside>

</div>

<script>

const bikes = [
{
name:"Hunter 350",
price:"₹1.50 Lakh",
engine:349,
power:20.2,
mileage:36,
weight:181,
image:"https://images.unsplash.com/photo-1558981806-ec527fa84c39?w=800"
},
{
name:"Pulsar N160",
price:"₹1.32 Lakh",
engine:164,
power:16,
mileage:50,
weight:154,
image:"https://images.unsplash.com/photo-1609630875171-b1321377ee65?w=800"
},
{
name:"TVS Raider",
price:"₹95,000",
engine:124,
power:11.2,
mileage:57,
weight:123,
image:"https://images.unsplash.com/photo-1580310614729-ccd69652491d?w=800"
},
{
name:"Yamaha R15",
price:"₹1.85 Lakh",
engine:155,
power:18.4,
mileage:45,
weight:141,
image:"https://images.unsplash.com/photo-1517846693594-1567da72af75?w=800"
},
{
name:"Apache RTR 200",
price:"₹1.55 Lakh",
engine:197,
power:20.8,
mileage:41,
weight:152,
image:"https://images.unsplash.com/photo-1449965408869-eaa3f722e40d?w=800"
}
];

let selected = [bikes[0], bikes[1]];

const modal = document.getElementById("modal");

function renderCards(){

const grid = document.getElementById("bikeGrid");

grid.innerHTML = "";

selected.forEach((bike,index)=>{

grid.innerHTML += `
<div class="bike-card">
<button class="remove-btn" onclick="removeBike(${index})">×</button>

<img src="${bike.image}">

<div class="card-content">
<div class="bike-name">${bike.name}</div>
<div class="price">${bike.price}</div>
</div>
</div>
`;

});

if(selected.length < 5){

grid.innerHTML += `
<div class="add-card" onclick="openModal()">
<div class="plus">+</div>
</div>
`;

}

renderTable();

}

function renderTable(){

const table = document.getElementById("compareTable");

const maxEngine = Math.max(...selected.map(x=>x.engine));
const maxPower = Math.max(...selected.map(x=>x.power));
const maxMileage = Math.max(...selected.map(x=>x.mileage));

table.innerHTML = `
<tr>
<th class="spec">Specification</th>
${selected.map(b=>`<th>${b.name}</th>`).join("")}
</tr>

${row("Price","price")}
${row("Engine (cc)","engine",maxEngine)}
${row("Power (PS)","power",maxPower)}
${row("Mileage","mileage",maxMileage)}
${row("Weight","weight")}
`;

function row(label,key,best=null){

return `
<tr>
<td class="spec">${label}</td>

${selected.map(b=>`
<td class="${best===b[key]?'best':''}">
${b[key]}
</td>
`).join("")}

</tr>
`;

}

}

function openModal(){

const select = document.getElementById("bikeSelect");

select.innerHTML = bikes.map((bike,index)=>
`<option value="${index}">${bike.name}</option>`
).join("");

modal.style.display = "flex";

}

function closeModal(){
modal.style.display = "none";
}

function addBike(){

const index =
document.getElementById("bikeSelect").value;

const bike = bikes[index];

if(selected.some(x=>x.name===bike.name)){
alert("Bike already selected");
return;
}

selected.push(bike);

closeModal();
renderCards();

}

function removeBike(index){

if(selected.length <= 2){
alert("Minimum 2 bikes required");
return;
}

selected.splice(index,1);
renderCards();

}

renderCards();

</script>

</body>
</html>