<script>
const toggle = document.getElementById("darkToggle");

if (toggle) {
  toggle.addEventListener("change", () => {
    document.documentElement.classList.toggle("dark", toggle.checked);
  });
}

const brandData = {
  "Royal Enfield": {
    "Cruiser Bikes": [
      { name: "Classic 350", cc: 349, img: "https://via.placeholder.com/200" },
      { name: "Meteor 350", cc: 349, img: "https://via.placeholder.com/200" },
      { name: "Hunter 350", cc: 349, img: "https://via.placeholder.com/200" },
      { name: "Classic 350", cc: 349, img: "https://via.placeholder.com/200" },
      { name: "Meteor 350", cc: 349, img: "https://via.placeholder.com/200" },
      { name: "Hunter 350", cc: 349, img: "https://via.placeholder.com/200" },{ name: "Classic 350", cc: 349, img: "https://via.placeholder.com/200" },
      { name: "Meteor 350", cc: 349, img: "https://via.placeholder.com/200" },
      { name: "Hunter 350", cc: 349, img: "https://via.placeholder.com/200" }
    ],
    "Adventure Bikes": [
      { name: "Himalayan 450", cc: 452, img: "https://via.placeholder.com/200" },
      { name: "Himalayan 450", cc: 452, img: "https://via.placeholder.com/200" },
      { name: "Himalayan 450", cc: 452, img: "https://via.placeholder.com/200" },
      { name: "Himalayan 450", cc: 452, img: "https://via.placeholder.com/200" },
      { name: "Himalayan 450", cc: 452, img: "https://via.placeholder.com/200" },
      { name: "Himalayan 450", cc: 452, img: "https://via.placeholder.com/200" }
    ]
  },

  "Bajaj": {
    "Street Bikes": [
      { name: "Pulsar NS200", cc: 199, img: "https://via.placeholder.com/200" },
      { name: "Dominar 400", cc: 373, img: "https://via.placeholder.com/200" }
    ]
  }
};

function openDrawer(brand) {
  document.getElementById("drawer").classList.add("active");
  document.getElementById("backdrop").classList.add("active");
  document.getElementById("brandTitle").innerText = brand;

  const container = document.getElementById("brandDetails");
  container.innerHTML = "";

  const data = brandData[brand];

  if (!data) {
    container.innerHTML = "<p>No bikes available</p>";
    return;
  }

  for (let category in data) {
    container.innerHTML += `
      <h3 style="margin:15px 0 10px;color:#4CAF50">${category}</h3>

      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;">
        ${data[category].map(bike => `
          <div onclick="openBike('${bike.name}', ${bike.cc})"
            style="
              background:#2a2a2a;
              border-radius:8px;
              padding:8px;
              text-align:center;
              font-size:12px;
              cursor:pointer;
              transition:0.2s;
            "
            onmouseover="this.style.transform='scale(1.05)'"
            onmouseout="this.style.transform='scale(1)'">
            <img src="${bike.img}" 
                 style="width:100%;height:80px;object-fit:cover;border-radius:6px;">

            <div style="margin-top:6px;font-weight:600;">
              ${bike.name}
            </div>

            <div style="font-size:11px;color:#aaa;">
              ${bike.cc}cc
            </div>
          </div>
        `).join("")}
      </div>
    `;
  }
}
function closeDrawer() {
  document.getElementById("drawer").classList.remove("active");
  document.getElementById("backdrop").classList.remove("active");
}
function openLogin() {
  document.getElementById("loginModal").classList.add("active");
}

function closeLogin() {
  document.getElementById("loginModal").classList.remove("active");
}

// close when clicking outside
document.getElementById("loginModal").addEventListener("click", function(e) {
  if (e.target === this) {
    closeLogin();
  }
});
function showSignup() {
  document.getElementById("loginForm").style.display = "none";
  document.getElementById("signupForm").style.display = "block";
}

function showLogin() {
  document.getElementById("signupForm").style.display = "none";
  document.getElementById("loginForm").style.display = "block";
}
function loginUser() {
  // fake login success
  localStorage.setItem("loggedIn", "true");
  localStorage.setItem("profilePic", "https://i.pravatar.cc/150");

  updateAuthUI();
  closeLogin();
}

function handleAuth() {
  const isLoggedIn = localStorage.getItem("loggedIn");

  if (isLoggedIn) {
    toggleMenu(); // 👈 open dropdown menu
  } else {
    openLogin(); // 👈 open login popup
  }
}
function toggleMenu() {
  document.getElementById("profileMenu").classList.toggle("show");
}

function updateAuthUI() {
  const btn = document.getElementById("authBtn");
  const isLoggedIn = localStorage.getItem("loggedIn");

  if (isLoggedIn) {
    const img = document.createElement("img");
    img.src = localStorage.getItem("profilePic");
    img.className = "profile-pic";

    btn.innerHTML = "";
    btn.appendChild(img);
    btn.onclick = handleAuth;
  } else {
    btn.innerText = "Login";
  }
}
