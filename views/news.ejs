<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>Latest Updates</title>

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

:root{
  --bg:#ffffff;
  --text:#111111;
  --border:#d8d8d8;
  --tab-bg:#f4f4f4;
  --active:#111111;
  --active-text:#ffffff;
}

body.dark{
  --bg:#0f0f0f;
  --text:#f5f5f5;
  --border:#343434;
  --tab-bg:#1b1b1b;
  --active:#ffffff;
  --active-text:#111111;
}

body{
  background:var(--bg);
  color:var(--text);
  font-family:Inter,sans-serif;
  display:flex;
  justify-content:center;
  padding:50px 20px;
}

/* MODULE */

.updates-module{
  width:60%;
  border:1px solid var(--border);
  border-radius:22px;
  padding:24px;
  overflow:hidden;
  background:transparent;
}

/* HEADING */

.heading{
  font-size:32px;
  font-weight:700;
  margin-bottom:24px;
}

/* TABS */

.tabs{
  display:flex;
  gap:12px;
  margin-bottom:24px;
  flex-wrap:wrap;
}

.tab-btn{
  padding:10px 18px;
  border-radius:10px;
  border:1px solid var(--border);
  background:var(--tab-bg);
  color:var(--text);
  cursor:pointer;
  font-weight:600;
  transition:.2s ease;
}

.tab-btn.active{
  background:var(--active);
  color:var(--active-text);
}

/* TAB CONTENT */

.tab-content{
  display:none;
}

.tab-content.active{
  display:block;
}

/* CARDS */

.cards{
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr));
  gap:18px;
}

.card{
  border:1px solid var(--border);
  border-radius:18px;
  overflow:hidden;
  background:transparent;
  min-width:0;
}

/* IMAGE */

.card-image{
  width:100%;
  height:190px;
  object-fit:cover;
  display:block;
  border-bottom:1px solid var(--border);
}

/* CONTENT */

.card-content{
  padding:18px;
}

.card-tag{
  font-size:12px;
  text-transform:uppercase;
  letter-spacing:.5px;
  opacity:.7;
  margin-bottom:12px;
  font-weight:700;
}

.card-title{
  font-size:22px;
  line-height:1.4;
  font-weight:700;
  margin-bottom:14px;
  overflow-wrap:anywhere;
}

.card-desc{
  font-size:15px;
  line-height:1.7;
  opacity:.82;
  overflow-wrap:anywhere;
}

/* RESPONSIVE */

@media(max-width:1200px){

  .updates-module{
    width:80%;
  }

}

@media(max-width:900px){

  .updates-module{
    width:95%;
  }

  .cards{
    grid-template-columns:1fr;
  }

}

</style>
</head>

<body>

<div class="updates-module">

  <div class="heading">
    Latest Updates
  </div>

  <!-- Tabs -->

  <div class="tabs">

    <button class="tab-btn active" data-tab="news">
      News
    </button>

    <button class="tab-btn" data-tab="reviews">
      Expert Reviews
