<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Steam Bike Garage</title>

<style>

:root{
  --bg:#f5f6f8;
  --text:#111;
  --sub:#666;
  --border:#d9dbe1;
  --accent:#4c8bf5;
}

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  background:var(--bg);
  font-family:Arial, sans-serif;
  color:var(--text);
}

.container{
  max-width:1200px;
  margin:auto;
  padding:40px 20px;
}

/* PROFILE */

.profile-top{
  display:flex;
  gap:40px;
  align-items:center;
  border-bottom:1px solid var(--border);
  padding-bottom:25px;
}

.profile-image{
  width:130px;
  height:130px;
  border-radius:50%;
  overflow:hidden;
  border:3px solid var(--border);
}

.profile-image img{
  width:100%;
  height:100%;
  object-fit:cover;
}

.username{
  font-size:28px;
  font-weight:700;
}

.meta{
  color:var(--sub);
  margin-top:6px;
  font-size:14px;
}

/* GARAGE */

.showcase{
  margin-top:40px;
}

.garage-title{
  font-size:22px;
  font-weight:700;
  margin-bottom:15px;
}

/* BIKE GRID */

.bike-grid{
  display:flex;
  gap:15px;
  overflow-x:auto;
  padding-bottom:10px;
}

.bike-card{
  width:220px;
  height:300px;
  flex-shrink:0;
  background:#fff;
  border:1px solid var(--border);
  border-radius:14px;
  overflow:hidden;
  cursor:pointer;
  display:flex;
  flex-direction:column;
  transition:.25s;
}

.bike-card:hover{
  transform:translateY(-6px);
}

.bike-card img{
  width:100%;
  height:170px;
  object-fit:cover;
}

.bike-info{
  padding:12px;
}

.bike-name{
  font-weight:700;
  font-size:15px;
}

.bike-desc{
  margin-top:8px;
  color:var(--sub);
  font-size:13px;
}

/* ADD TILE */

.add-tile{
  width:220px;
  height:300px;
  flex-shrink:0;
  border:2px dashed #bbb;
  border-radius:14px;
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  background:#fafafa;
  transition:.25s;
}

.add-tile:hover{
  border-color:var(--accent);
  background:#eef5ff;
}

.add-plus{
  font-size:45px;
  color:#888;
}

/* TABS */

.tabs{
  display:flex;
  gap:12px;
  margin-top:60px;
  margin-bottom:20px;
}

.tab{
  padding:12px 20px;
  border-radius:10px;
  background:#e5e7eb;
  cursor:pointer;
  font-weight:600;
  transition:.2s;
}

.tab.active{
  background:var(--accent);
  color:#fff;
}

/* TAB CONTENT */

.tab-content{
  display:none;
}

.tab-content.active{
  display:block;
}

/* MEDIA */

.media-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:12px;
}

.media-post{
  overflow:hidden;
  border-radius:14px;
  aspect-ratio:1/1;
  background:#ddd;
  cursor:pointer;
}

.media-post img{
  width:100%;
  height:100%;
  object-fit:cover;
  transition:.3s;
}

.media-post:hover img{
  transform:scale(1.05);
}

/* REVIEWS */

.review-list{
  display:flex;
  flex-direction:column;
  gap:18px;
}

.review-card{
  background:#fff;
  border:1px solid var(--border);
  border-radius:16px;
  padding:18px;
}

.review-bike{
  display:flex;
  align-items:center;
  gap:14px;
}

.review-bike img{
  width:70px;
  height:70px;
  border-radius:12px;
  object-fit:cover;
}

.review-bike-name{
  font-size:18px;
  font-weight:700;
}

.review-date{
  margin-top:4px;
  color:var(--sub);
  font-size:13px;
}

.review-stars{
  margin-top:14px;
  color:#f59e0b;
  font-size:20px;
}

.review-text{
  margin-top:12px;
  color:var(--sub);
  line-height:1.7;
  font-size:14px;
}

/* MODALS */

.modal,
.inspect{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.65);
  display:none;
  justify-content:center;
  align-items:center;
  z-index:1000;
}

.modal-box{
  width:360px;
  background:#fff;
  padding:20px;
  border-radius:14px;
}

.modal-box input,
.modal-box textarea{
  width:100%;
  padding:12px;
  margin-bottom:12px;
  border-radius:8px;
  border:1px solid #ddd;
}

.modal-box textarea{
  min-height:90px;
}

.save{
  width:100%;
  padding:12px;
  border:none;
  border-radius:8px;
  background:var(--accent);
  color:#fff;
  cursor:pointer;
}

/* INSPECT */

.inspect-box{
  width:430px;
  background:#fff;
  border-radius:14px;
  overflow:hidden;
}

.inspect-box img{
  width:100%;
  height:240px;
  object-fit:cover;
}

.inspect-content{
  padding:16px;
}

.inspect-title{
  font-size:20px;
  font-weight:700;
}

.inspect-desc{
  margin-top:8px;
  color:var(--sub);
}

.actions{
  display:flex;
  justify-content:space-between;
  margin-top:18px;
}

.btn{
  border:none;
  padding:10px 16px;
  border-radius:8px;
  cursor:pointer;
}

.edit{background:#e5e7eb;}
.del{background:#ef4444;color:#fff;}

/* MOBILE */

@media(max-width:700px){
  .profile-top{
    flex-direction:column;
    text-align:center;
  }

  .media-grid{
    grid-template-columns:repeat(2,1fr);
  }
}

</style>
</head>

<body>

<div class="container">

  <!-- PROFILE -->
  <div class="profile-top">
    <div class="profile-image">
      <img src="https://i.pravatar.cc/400?img=12">
    </div>
    <div>
      <div class="username">Rider_X</div>
      <div class="meta">Mumbai • Steam Garage System</div>
    </div>
  </div>

  <!-- GARAGE -->
  <div class="showcase">
    <div class="garage-title">Bike Garage</div>
    <div class="bike-grid" id="grid"></div>
  </div>

  <!-- TABS -->
  <div class="tabs">
    <div class="tab active" onclick="switchTab('media',this)">Media</div>
    <div class="tab" onclick="switchTab('reviews',this)">Reviews</div>
  </div>

  <!-- MEDIA TAB -->
  <div class="tab-content active" id="media">
    <div class="media-grid">

      <div class="media-post"><img src="https://images.unsplash.com/photo-1511919884226-fd3cad34687c"></div>
      <div class="media-post"><img src="https://images.unsplash.com/photo-1493238792000-8113da705763"></div>
      <div class="media-post"><img src="https://images.unsplash.com/photo-1503376780353-7e6692767b70"></div>
      <div class="media-post"><img src="https://images.unsplash.com/photo-1489824904134-891ab64532f1"></div>
      <div class="media-post"><img src="https://images.unsplash.com/photo-1544636331-e26879cd4d9b"></div>
      <div class="media-post"><img src="https://images.unsplash.com/photo-1502877338535-766e1452684a"></div>

    </div>
  </div>

  <!-- REVIEWS TAB -->
  <div class="tab-content" id="reviews">

    <div class="review-list">

      <div class="review-card">

        <div class="review-bike">
          <img src="https://images.unsplash.com/photo-1558981806-ec527fa84c39">
          <div>
            <div class="review-bike-name">KTM Duke 390</div>
            <div class="review-date">May 17, 2026</div>
          </div>
        </div>

        <div class="review-stars">★★★★★</div>
        <div class="review-text">
          Absolute street monster. Insane acceleration and sharp handling.
        </div>

      </div>

      <div class="review-card">

        <div class="review-bike">
          <img src="https://images.unsplash.com/photo-1609630875171-b1321377ee65">
          <div>
            <div class="review-bike-name">BMW G 310 GS</div>
            <div class="review-date">April 28, 2026</div>
          </div>
        </div>

        <div class="review-stars">★★★★☆</div>
        <div class="review-text">
          Great touring comfort and stability, but slightly underpowered.
        </div>

      </div>

      <div class="review-card">

        <div class="review-bike">
          <img src="https://images.unsplash.com/photo-1580310614729-ccd69652491d">
          <div>
            <div class="review-bike-name">Yamaha R15 V4</div>
            <div class="review-date">March 11, 2026</div>
          </div>
        </div>

        <div class="review-stars">★★★★★</div>
        <div class="review-text">
          Best entry-level sport bike with amazing mileage and handling.
        </div>

      </div>

    </div>

  </div>

</div>

<!-- MODAL -->
<div class="modal" id="modal">
  <div class="modal-box">
    <input id="name" placeholder="Bike Name">
    <input id="img" placeholder="Image URL">
    <textarea id="desc" placeholder="Description"></textarea>
    <button class="save" onclick="saveBike()">SAVE</button>
  </div>
</div>

<!-- INSPECT -->
<div class="inspect" id="inspect" onclick="closeInspect(event)">
  <div class="inspect-box">
    <img id="iimg">
    <div class="inspect-content">
      <div class="inspect-title" id="ititle"></div>
      <div class="inspect-desc" id="idesc"></div>
      <div class="actions">
        <button class="btn edit" onclick="editBike()">Edit</button>
        <button class="btn del" onclick="deleteBike()">Delete</button>
      </div>
    </div>
  </div>
</div>

<script>

const modal = document.getElementById("modal");
const inspect = document.getElementById("inspect");

const nameInput = document.getElementById("name");
const imgInput = document.getElementById("img");
const descInput = document.getElementById("desc");

const grid = document.getElementById("grid");

const iimg = document.getElementById("iimg");
const ititle = document.getElementById("ititle");
const idesc = document.getElementById("idesc");

let bikes = JSON.parse(localStorage.getItem("bikes")) || [
  {
    name:"KTM Duke 390",
    img:"https://images.unsplash.com/photo-1558981806-ec527fa84c39",
    desc:"Street performance beast"
  },
  {
    name:"BMW G 310 GS",
    img:"https://images.unsplash.com/photo-1609630875171-b1321377ee65",
    desc:"Adventure touring machine"
  },
  {
    name:"Yamaha R15 V4",
    img:"https://images.unsplash.com/photo-1580310614729-ccd69652491d",
    desc:"Light supersport"
  }
];

let currentIndex = null;

function saveStorage(){
  localStorage.setItem("bikes", JSON.stringify(bikes));
}

function render(){
  grid.innerHTML = "";

  bikes.forEach((b,i)=>{
    const card = document.createElement("div");
    card.className = "bike-card";

    card.innerHTML = `
      <img src="${b.img}">
      <div class="bike-info">
        <div class="bike-name">${b.name}</div>
        <div class="bike-desc">${b.desc}</div>
      </div>
    `;

    card.onclick = ()=>openInspect(i);
    grid.appendChild(card);
  });

  const add = document.createElement("div");
  add.className = "add-tile";
  add.innerHTML = `<div class="add-plus">+</div>`;
  add.onclick = ()=>{ currentIndex=null; resetForm(); modal.style.display="flex"; };

  grid.appendChild(add);
}

function resetForm(){
  nameInput.value="";
  imgInput.value="";
  descInput.value="";
}

function saveBike(){
  const data = {
    name:nameInput.value,
    img:imgInput.value,
    desc:descInput.value
  };

  if(currentIndex!==null){
    bikes[currentIndex]=data;
  }else{
    bikes.push(data);
  }

  saveStorage();
  render();
  modal.style.display="none";
  resetForm();
}

function openInspect(i){
  currentIndex=i;
  const b=bikes[i];

  ititle.innerText=b.name;
  idesc.innerText=b.desc;
  iimg.src=b.img;

  inspect.style.display="flex";
}

function closeInspect(e){
  if(e.target===inspect){
    inspect.style.display="none";
  }
}

function deleteBike(){
  bikes.splice(currentIndex,1);
  saveStorage();
  render();
  inspect.style.display="none";
}

function editBike(){
  const b=bikes[currentIndex];
  nameInput.value=b.name;
  imgInput.value=b.img;
  descInput.value=b.desc;

  inspect.style.display="none";
  modal.style.display="flex";
}

/* TABS */

function switchTab(id,el){
  document.querySelectorAll(".tab").forEach(t=>t.classList.remove("active"));
  document.querySelectorAll(".tab-content").forEach(c=>c.classList.remove("active"));

  el.classList.add("active");
  document.getElementById(id).classList.add("active");
}

window.addEventListener("click",(e)=>{
  if(e.target===modal) modal.style.display="none";
});

render();

</script>

</body>
</html>